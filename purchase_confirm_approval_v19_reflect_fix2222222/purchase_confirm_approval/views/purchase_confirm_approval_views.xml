<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_purchase_confirm_approval_rule_list" model="ir.ui.view">
        <field name="name">purchase.confirm.approval.rule.list</field>
        <field name="model">purchase.confirm.approval.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_confirm_approval_rule_form" model="ir.ui.view">
        <field name="name">purchase.confirm.approval.rule.form</field>
        <field name="model">purchase.confirm.approval.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Approval Steps">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="required"/>
                                    <field name="group_id"/>
                                    <field name="specific_user_ids" widget="many2many_tags"/>
                                    <field name="user_to_notify_ids" widget="many2many_tags"/>
                                    <field name="exclusive_approval"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_purchase_confirm_approval_rule" model="ir.actions.act_window">
        <field name="name">Purchase Confirm Approvals</field>
        <field name="res_model">purchase.confirm.approval.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
