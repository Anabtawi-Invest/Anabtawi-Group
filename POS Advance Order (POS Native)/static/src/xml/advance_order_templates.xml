<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Button -->
    <t t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class,'control-buttons')]" position="inside">
            <button class="control-button" t-on-click="onClickAdvanceOrderNative" title="Advance Order">
                <span>Advance Order</span>
            </button>
        </xpath>
    </t>

    <!-- Screen -->
    <t t-name="pos_advance_order_new.AdvanceOrderNativeScreen" owl="1">
        <div class="pos-content">
            <div class="pos-adv-header">
                <div style="display:flex; gap:8px;">
                    <button class="button back" t-on-click="back">Back</button>
                    <button class="button" t-on-click="clear">Clear</button>
                </div>
                <h2>Advance Order</h2>
                <button class="button validate" t-on-click="save">Save</button>
            </div>

            <div class="pos-adv-body">
                <div class="pos-adv-grid">
                    <div class="pos-adv-row">
                        <div class="pos-adv-field">
                            <label>Type</label>
                            <select t-model="state.adv_type">
                                <option value="pickup">Pickup</option>
                                <option value="delivery">Delivery</option>
                            </select>
                        </div>
                        <div class="pos-adv-field">
                            <label>Requested date/time</label>
                            <input type="datetime-local" t-model="state.requested_datetime"/>
                        </div>
                    </div>

                    <div class="pos-adv-row">
                        <div class="pos-adv-field">
                            <label>Contact name</label>
                            <input type="text" placeholder="Customer name" t-model="state.contact_name"/>
                        </div>
                        <div class="pos-adv-field">
                            <label>Phone</label>
                            <input type="tel" placeholder="+962..." t-model="state.phone"/>
                        </div>
                    </div>

                    <div class="pos-adv-field">
                        <label>Address (for delivery)</label>
                        <textarea rows="2" placeholder="Street, building, city..." t-model="state.address"></textarea>
                    </div>

                    <div class="pos-adv-row">
                        <div class="pos-adv-field">
                            <label>Deposit</label>
                            <input type="number" step="0.01" min="0" t-model="state.deposit"/>
                        </div>
                        <div class="pos-adv-field">
                            <label>Note</label>
                            <input type="text" placeholder="Any instructions..." t-model="state.note"/>
                        </div>
                    </div>

                    <div style="opacity:.8;">
                        Tip: After saving, validate the order normally (Payment → Validate). The advance info will be saved on the backend POS Order.
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- Receipt: show advance info if present -->
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class,'pos-receipt')]" position="inside">
            <t t-if="props.data.pos_adv_is_advance_order">
                <div style="margin-top:10px;">
                    <div><strong>Advance Order</strong></div>
                    <div>Type: <t t-esc="props.data.pos_adv_type"/></div>
                    <t t-if="props.data.pos_adv_requested_datetime">
                        <div>Requested: <t t-esc="props.data.pos_adv_requested_datetime"/></div>
                    </t>
                    <t t-if="props.data.pos_adv_contact_name">
                        <div>Name: <t t-esc="props.data.pos_adv_contact_name"/></div>
                    </t>
                    <t t-if="props.data.pos_adv_phone">
                        <div>Phone: <t t-esc="props.data.pos_adv_phone"/></div>
                    </t>
                    <t t-if="props.data.pos_adv_address">
                        <div>Address: <t t-esc="props.data.pos_adv_address"/></div>
                    </t>
                    <t t-if="props.data.pos_adv_deposit">
                        <div>Deposit: <t t-esc="props.data.pos_adv_deposit"/></div>
                    </t>
                    <t t-if="props.data.pos_adv_note">
                        <div>Note: <t t-esc="props.data.pos_adv_note"/></div>
                    </t>
                </div>
            </t>
        </xpath>
    </t>

</templates>
