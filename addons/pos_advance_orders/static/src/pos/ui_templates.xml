<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="pos_advance_orders.AdvanceOrdersButton" owl="1">
    <button class="control-button" t-on-click="onClick">
      <i class="fa fa-calendar-check-o me-1"/>
      Advance Orders
    </button>
  </t>

  <t t-name="pos_advance_orders.AdvanceOrdersPopup" owl="1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="popup popup-textinput">
          <div class="title">Create Advance Order</div>

          <div class="body">
            <div class="mb-2">
              <label>Customer Mobile</label>
              <input class="form-control" t-model="state.mobile" placeholder="07xxxxxxxx"/>
            </div>

            <div class="mb-2">
              <label>Due Date</label>
              <input class="form-control" type="date" t-model="state.dueDate"/>
            </div>

            <div class="mb-2">
              <label>Note</label>
              <textarea class="form-control" t-model="state.note"/>
            </div>

            <div class="mb-2">
              <label>Deposit Amount (optional)</label>
              <input class="form-control" type="number" step="0.01" t-model="state.depositAmount"/>
              <small class="text-muted">If set, POS creates a deposit line and goes to Payment.</small>
            </div>
          </div>

          <div class="footer">
            <button class="button cancel" t-on-click="cancel">Cancel</button>
            <button class="button confirm" t-on-click="confirm">Create</button>
          </div>
        </div>
      </div>
    </div>
  </t>

</templates>
