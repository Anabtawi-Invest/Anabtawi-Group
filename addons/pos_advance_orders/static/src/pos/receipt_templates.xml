<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Extend POS receipt lines -->
    <t t-inherit="point_of_sale.OrderReceiptLines"
       t-inherit-mode="extension"
       owl="1">

        <!-- Replace receipt lines rendering -->
        <xpath expr="//t[@t-foreach='props.lines']" position="replace">

            <t t-set="lines" t-value="props.lines"/>

            <t t-if="props.order.__print_mode === 'products'">
                <t t-set="lines"
                   t-value="props.lines.filter(l => !l.is_pledge_line && !l.is_advance_deposit_line)"/>
            </t>

            <t t-if="props.order.__print_mode === 'deposit'">
                <t t-set="lines"
                   t-value="props.lines.filter(l => l.is_pledge_line || l.is_advance_deposit_line)"/>
            </t>

            <t t-foreach="lines" t-as="line" t-key="line.uuid">
                <div class="pos-receipt-line">
                    <span t-esc="line.product_name"/>
                    <span class="float-end" t-esc="line.price_display"/>
                </div>
            </t>

        </xpath>

    </t>

</templates>
