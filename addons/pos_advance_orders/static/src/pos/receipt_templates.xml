<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">

    <xpath expr="//t[@t-foreach='props.order.orderlines']" position="replace">
      <t t-set="lines" t-value="props.order.orderlines"/>

      <t t-if="props.order.__print_mode === 'products'">
        <t t-set="lines" t-value="props.order.orderlines.filter(l =&gt; !l.is_pledge_line &amp;&amp; !l.is_advance_deposit_line)"/>
      </t>

      <t t-if="props.order.__print_mode === 'deposit'">
        <t t-set="lines" t-value="props.order.orderlines.filter(l =&gt; l.is_pledge_line || l.is_advance_deposit_line)"/>
      </t>

      <t t-foreach="lines" t-as="line" t-key="line.uuid">
        <div class="pos-receipt-line">
          <span t-esc="line.product_name"/>
          <span class="float-end" t-esc="line.price_display"/>
        </div>
      </t>
    </xpath>

    <xpath expr="//div[contains(@class,'pos-receipt')]" position="inside">
      <t t-if="props.order.__print_mode === 'products'">
        <div class="text-center fw-bold mb-2">PRODUCT RECEIPT</div>
      </t>
      <t t-if="props.order.__print_mode === 'deposit'">
        <div class="text-center fw-bold mb-2">PLEDGE / DEPOSIT RECEIPT</div>
      </t>
    </xpath>

  </t>

</templates>
