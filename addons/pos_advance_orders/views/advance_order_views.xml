<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- List View -->
  <record id="view_pos_advance_order_list" model="ir.ui.view">
    <field name="name">pos.advance.order.list</field>
    <field name="model">pos.advance.order</field>
    <field name="arch" type="xml">
      <list string="Advance Orders">
        <field name="name"/>
        <field name="state"/>
        <field name="pos_config_id"/>
        <field name="partner_id"/>
        <field name="partner_mobile"/>
        <field name="due_date"/>
        <field name="amount_total"/>
        <field name="amount_paid"/>
        <field name="amount_due"/>
        <field name="invoice_id"/>
      </list>
    </field>
  </record>

  <!-- Form View -->
  <record id="view_pos_advance_order_form" model="ir.ui.view">
    <field name="name">pos.advance.order.form</field>
    <field name="model">pos.advance.order</field>
    <field name="arch" type="xml">
      <form string="Advance Order">

        <header>
          <button name="action_confirm"
                  type="object"
                  string="Confirm"
                  class="btn-primary"
                  invisible="state != 'draft'"/>

          <button name="action_fulfill_create_invoice"
                  type="object"
                  string="Fulfill &amp; Invoice"
                  class="btn-primary"
                  invisible="state != 'confirmed'"/>

          <button name="action_cancel"
                  type="object"
                  string="Cancel"
                  class="btn-secondary"
                  invisible="state in ('cancelled','fulfilled')"/>

          <field name="state"
                 widget="statusbar"
                 statusbar_visible="draft,confirmed,fulfilled,cancelled"/>
        </header>

        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" readonly="1"/>
            </h1>
          </div>

          <group>
            <group>
              <field name="pos_config_id" readonly="state != 'draft'"/>
              <field name="partner_id" readonly="state != 'draft'"/>
              <field name="partner_mobile" readonly="state != 'draft'"/>
              <field name="due_date" readonly="state != 'draft'"/>
            </group>
            <group>
              <field name="amount_total" readonly="1"/>
              <field name="amount_paid" readonly="1"/>
              <field name="amount_due" readonly="1"/>
              <field name="invoice_id" readonly="1"/>
            </group>
          </group>

          <notebook>

            <page string="Lines">
              <field name="line_ids" readonly="state != 'draft'">
                <list>
                  <field name="product_id"/>
                  <field name="name"/>
                  <field name="qty"/>
                  <field name="price_unit"/>
                  <field name="price_subtotal" readonly="1"/>
                </list>
              </field>
            </page>

            <page string="Payments">
              <field name="payment_ids" readonly="1">
                <list>
                  <field name="journal_id"/>
                  <field name="amount"/>
                  <field name="state"/>
                  <field name="move_id"/>
                </list>
              </field>
              <label string="Phase 1: post payments from the payment record (Action Post)."/>
            </page>

            <page string="Revisions" groups="pos_advance_orders.group_pos_advance_manager">
              <field name="revision_ids" readonly="1">
                <list>
                  <field name="create_date"/>
                  <field name="user_id"/>
                  <field name="partner_id"/>
                  <field name="partner_mobile"/>
                  <field name="due_date"/>
                </list>
              </field>
            </page>

            <page string="Notes">
              <field name="note" readonly="state != 'draft'"/>
            </page>

          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_pos_advance_orders" model="ir.actions.act_window">
    <field name="name">Advance Orders</field>
    <field name="res_model">pos.advance.order</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- Menus -->
  <menuitem id="menu_pos_advance_root"
            name="Advance Orders"
            parent="point_of_sale.menu_point_root"
            sequence="75"/>

  <menuitem id="menu_pos_advance_orders"
            name="Advance Orders"
            parent="pos_advance_orders.menu_pos_advance_root"
            action="pos_advance_orders.action_pos_advance_orders"
            sequence="10"/>

</odoo>
