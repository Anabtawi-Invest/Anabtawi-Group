<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- List View -->
  <record id="view_pos_advance_order_list" model="ir.ui.view">
    <field name="name">pos.advance.order.list</field>
    <field name="model">pos.advance.order</field>
    <field name="arch" type="xml">
      <list string="Advance Orders">
        <field name="name"/>
        <field name="state"/>
        <field name="pos_config_id"/>
        <field name="partner_id"/>
        <field name="partner_mobile"/>
        <field name="due_date"/>
        <field name="amount_total"/>
        <field name="amount_paid"/>
        <field name="amount_due"/>
        <field name="invoice_id"/>
      </list>
    </field>
  </record>

  <!-- Form View -->
  <record id="view_pos_advance_order_form" model="ir.ui.view">
    <field name="name">pos.advance.order.form</field>
    <field name="model">pos.advance.order</field>
    <field name="arch" type="xml">
      <form string="Advance Order">

        <header>
          <button name="action_confirm"
                  type="object"
                  string="Confirm"
                  class="btn-primary"
                  invisible="state != 'draft'"/>

          <button name="action_fulfill_create_invoice"
                  type="object"
                  string="Fulfill &amp; Invoice"
                  class="btn-primary"
                  invisible="state != 'confirmed'"/>

          <button name="action_cancel"
                  type="object"
                  string="Cancel"
                  class="btn-secondary"
                  invisible="state in ('cancelled','fulfilled')"/>

          <field name="state"
                 widget="statusbar"
                 statusbar_visible="draft,confirmed,fulfilled,cancelled"/>
        </header>

        <sheet>
          <group>
            <group>
              <field name="pos_config_id"/>
              <field name="partner_id"/>
              <field name="partner_mobile"/>
              <field name="due_date"/>
            </group>
            <group>
              <field name="amount_total" readonly="1"/>
              <field name="amount_paid" readonly="1"/>
              <field name="amount_due" readonly="1"/>
              <field name="invoice_id" readonly="1"/>
            </group>
          </group>

          <notebook>

            <page string="Lines">
              <field name="line_ids">
                <list>
                  <field name="product_id"/>
                  <field name="name"/>
                  <field name="qty"/>
                  <field name="price_unit"/>
                  <field name="price_subtotal"/>
                </list>
              </field>
            </page>

            <page string="Payments">
              <field name="payment_ids">
                <list>
                  <field name="journal_id"/>
                  <field name="amount"/>
                  <field name="state"/>
                  <field name="move_id"/>
                </list>
              </field>
            </page>

            <page string="Notes">
              <field name="note"/>
            </page>

          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_pos_advance_orders" model="ir.actions.act_window">
    <field name="name">Advance Orders</field>
    <field name="res_model">pos.advance.order</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
