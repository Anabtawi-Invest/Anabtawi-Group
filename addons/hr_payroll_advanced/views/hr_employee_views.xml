<odoo>

    <record id="view_employee_form_ot_bank" model="ir.ui.view">
        <field name="name">hr.employee.form.ot.bank</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet//group[1]" position="inside">

                <field name="overtime_bank_balance" readonly="1"/>

            </xpath>

        </field>
    </record>

</odoo>
