<odoo>

    <!-- ============================= -->
    <!-- Payslip FORM BUTTON + BADGE -->
    <!-- ============================= -->
    <record id="hr_payslip_form_reconcile_btn" model="ir.ui.view">
        <field name="name">hr.payslip.form.reconcile.btn</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">

            <!-- SAFE HEADER INSERT -->
            <xpath expr="//header" position="inside">

                <button name="action_reconcile_lateness_engine"
                        type="object"
                        string="Reconcile Lateness"
                        class="btn-primary"/>

                <field name="reconciliation_state" widget="badge"/>

            </xpath>

        </field>
    </record>


    <!-- ============================= -->
    <!-- Payslip LIST SAFE COLUMNS -->
    <!-- ============================= -->
    <record id="hr_payslip_tree_reconcile_cols" model="ir.ui.view">
        <field name="name">hr.payslip.tree.reconcile.cols</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="arch" type="xml">

            <!-- SAFE ANCHOR -->
            <xpath expr="//field[@name='employee_id']" position="after">

                <field name="reconciliation_state" widget="badge"/>

            </xpath>

        </field>
    </record>

</odoo>
