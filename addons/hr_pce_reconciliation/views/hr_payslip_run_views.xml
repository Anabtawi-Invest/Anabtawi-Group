<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_run_form_pce_ultra" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.pce.ultra</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_run_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_pce_mass_reconcile"
                        type="object"
                        string="Reconcile All"
                        class="btn-primary"
                        groups="hr_payroll.group_hr_payroll_user"/>

                <button name="action_open_pce_smart_review"
                        type="object"
                        string="Smart Review"
                        class="btn-secondary"
                        groups="hr_payroll.group_hr_payroll_user"/>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">

                <button type="object"
                        name="action_open_pce_smart_review"
                        class="oe_stat_button"
                        icon="fa-check-square"
                        groups="hr_payroll.group_hr_payroll_user">
                    <field name="pce_to_reconcile_count" widget="statinfo" string="To Reconcile"/>
                </button>

                <button type="object"
                        name="action_open_pce_smart_review"
                        class="oe_stat_button"
                        icon="fa-exclamation-triangle"
                        groups="hr_payroll.group_hr_payroll_user">
                    <field name="pce_need_salary_deduction_count" widget="statinfo" string="Needs Salary Deduction"/>
                </button>

            </xpath>

        </field>
    </record>

</odoo>
