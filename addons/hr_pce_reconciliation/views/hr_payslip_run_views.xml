<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ULTRA SAFE PAYRUN INHERIT (NO XMLID DEPENDENCY) -->

    <record id="view_hr_payslip_run_form_pce_ultra" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.pce.ultra</field>
        <field name="model">hr.payslip.run</field>

        <!-- 🔥 SAFE: no inherit_id -->
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_run_form" optional="True"/>

        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_pce_mass_reconcile"
                        type="object"
                        string="Reconcile All"
                        class="btn-primary"
                        groups="hr_payroll.group_hr_payroll_user"/>

                <button name="action_open_pce_smart_review"
                        type="object"
                        string="Smart Review"
                        class="btn-secondary"
                        groups="hr_payroll.group_hr_payroll_user"/>
            </xpath>

        </field>
    </record>

</odoo>
