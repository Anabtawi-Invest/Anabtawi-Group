<odoo>
  <template id="packing_list_template">
    <!-- html_container يضمن وجود <main> في الناتج -->
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-set="lines" t-value="lines_map.get(o.id, [])"/>
        <t t-set="tot" t-value="totals_map.get(o.id, {})"/>
        <t t-set="terms" t-value="terms_map.get(o.id, '')"/>

        <!-- external_layout يضيف الهيدر/الفوتر + main -->
        <t t-call="web.external_layout">
          <div class="page">

            <h2 style="text-align:center;">Packing List</h2>

            <div class="row">
              <div class="col-6">
                <strong t-esc="o.company_id.name"/>
                <div>Invoice No: <span t-esc="o.name"/></div>
                <div t-if="o.invoice_date">Date: <span t-esc="o.invoice_date"/></div>
              </div>
              <div class="col-6" style="text-align:right;">
                <div>Customer: <span t-esc="o.partner_id.name"/></div>
                <div t-if="o.partner_id.vat">VAT: <span t-esc="o.partner_id.vat"/></div>
                <div t-if="o.partner_id.phone">Tel: <span t-esc="o.partner_id.phone"/></div>
                <div t-if="o.partner_id.email">Email: <span t-esc="o.partner_id.email"/></div>
              </div>
            </div>

            <br/>

            <table class="table table-sm table-bordered">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Product</th>
                  <th>Barcode</th>
                  <th>HS Code</th>
                  <th>Package Type</th>
                  <th>Qty/Carton</th>
                  <th>Units</th>
                  <th>Total Cartons</th>
                  <th>Net Wt/Kg</th>
                  <th>Gross Wt/Kg</th>
                  <th>Total Net Wt/Kg</th>
                  <th>Total Gross Wt/Kg</th>
                </tr>
              </thead>

              <tbody>
                <t t-set="i" t-value="0"/>
                <t t-foreach="lines" t-as="l">
                  <t t-set="i" t-value="i + 1"/>
                  <tr>
                    <td t-esc="i"/>
                    <td t-esc="l.get('product_name', '')"/>
                    <td t-esc="l.get('barcode', '')"/>
                    <td t-esc="l.get('hs_code', '')"/>
                    <td t-esc="l.get('package_type', '')"/>
                    <td t-esc="l.get('qty_per_carton', 0)"/>
                    <td t-esc="l.get('units', 0.0)"/>
                    <td t-esc="l.get('cartons', 0.0)"/>
                    <td t-esc="l.get('net_w', 0.0)"/>
                    <td t-esc="l.get('gross_w', 0.0)"/>
                    <td t-esc="l.get('net_total', 0.0)"/>
                    <td t-esc="l.get('gross_total', 0.0)"/>
                  </tr>
                </t>
              </tbody>

              <tfoot>
                <tr>
                  <th colspan="6" style="text-align:right;">Totals</th>
                  <th t-esc="tot.get('tot_units', 0.0)"/>
                  <th t-esc="tot.get('tot_cartons', 0.0)"/>
                  <th></th>
                  <th></th>
                  <th t-esc="tot.get('tot_net', 0.0)"/>
                  <th t-esc="tot.get('tot_gross', 0.0)"/>
                </tr>
              </tfoot>
            </table>

            <t t-if="terms">
              <br/>
              <strong>Terms &amp; Conditions</strong>
              <pre style="white-space:pre-wrap;" t-esc="terms"/>
            </t>

          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
