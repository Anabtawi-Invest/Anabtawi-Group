<!-- report/packing_list_template.xml -->
<odoo>
  <template id="packing_list_template">
    <t t-call="web.external_layout">
      <t t-foreach="docs" t-as="d">
        <t t-set="o" t-value="d['move']"/>

        <div class="page">
          <h2 style="text-align:center;">Packing List</h2>

          <div class="row">
            <div class="col-6">
              <strong t-esc="o.company_id.name"/>
              <div>Invoice No: <span t-esc="o.name"/></div>
              <div>Date: <span t-esc="o.invoice_date"/></div>
            </div>
            <div class="col-6" style="text-align:right;">
              <div>Customer: <span t-esc="o.partner_id.name"/></div>
              <div t-if="o.partner_id.vat">VAT: <span t-esc="o.partner_id.vat"/></div>
              <div t-if="o.partner_id.phone">Tel: <span t-esc="o.partner_id.phone"/></div>
              <div t-if="o.partner_id.email">Email: <span t-esc="o.partner_id.email"/></div>
            </div>
          </div>

          <br/>

          <table class="table table-sm table-bordered">
            <thead>
              <tr>
                <th>#</th>
                <th>Product</th>
                <th>Barcode</th>
                <th>HS Code</th>
                <th>Package Type</th>
                <th>Qty/Carton</th>
                <th>Units</th>
                <th>Total Cartons</th>
                <th>Net Wt/Kg</th>
                <th>Gross Wt/Kg</th>
                <th>Total Net Wt/Kg</th>
                <th>Total Gross Wt/Kg</th>
              </tr>
            </thead>
            <tbody>
              <t t-set="i" t-value="0"/>
              <t t-foreach="d['lines']" t-as="l">
                <t t-set="i" t-value="i + 1"/>
                <tr>
                  <td t-esc="i"/>
                  <td t-esc="l['product_name']"/>
                  <td t-esc="l['barcode']"/>
                  <td t-esc="l['hs_code']"/>
                  <td t-esc="l['package_type']"/>
                  <td t-esc="l['qty_per_carton']"/>
                  <td t-esc="l['units']"/>
                  <td t-esc="l['cartons']"/>
                  <td t-esc="l['net_w']"/>
                  <td t-esc="l['gross_w']"/>
                  <td t-esc="l['net_total']"/>
                  <td t-esc="l['gross_total']"/>
                </tr>
              </t>
            </tbody>
            <tfoot>
              <tr>
                <th colspan="6" style="text-align:right;">Totals</th>
                <th t-esc="d['tot_units']"/>
                <th t-esc="d['tot_cartons']"/>
                <th></th>
                <th></th>
                <th t-esc="d['tot_net']"/>
                <th t-esc="d['tot_gross']"/>
              </tr>
            </tfoot>
          </table>

          <t t-if="d['terms']">
            <br/>
            <strong>Terms &amp; Conditions</strong>
            <pre style="white-space:pre-wrap;" t-esc="d['terms']"/>
          </t>
        </div>
      </t>
    </t>
  </template>
</odoo>
