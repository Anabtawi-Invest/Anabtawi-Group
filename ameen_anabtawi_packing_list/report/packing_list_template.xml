<odoo>
  <template id="packing_list_template">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-set="lines" t-value="lines_map.get(o.id, [])"/>
        <t t-set="tot" t-value="totals_map.get(o.id, {})"/>

        <t t-call="web.external_layout">
          <div class="page" style="text-align:center;">

            <h2 style="text-align:center;">Packing List</h2>

            <div class="row" style="text-align:center;">
              <div class="col-6" style="text-align:center;">
                <strong t-esc="o.company_id.name"/>
                <div>Invoice No: <span t-esc="o.name"/></div>
                <div t-if="o.invoice_date">Date: <span t-esc="o.invoice_date"/></div>
              </div>
              <div class="col-6" style="text-align:center;">
                <div>Customer: <span t-esc="o.partner_id.name"/></div>
                <div t-if="o.partner_id.vat">VAT: <span t-esc="o.partner_id.vat"/></div>
                <div t-if="o.partner_id.phone">Tel: <span t-esc="o.partner_id.phone"/></div>
                <div t-if="o.partner_id.email">Email: <span t-esc="o.partner_id.email"/></div>
              </div>
            </div>

            <br/>

            <table class="table table-sm table-bordered" style="text-align:center;">
              <thead>
                <tr style="text-align:center;">
                  <th style="text-align:center;">#</th>
                  <th style="text-align:center;">Product</th>
                  <th style="text-align:center;">Barcode</th>
                  <th style="text-align:center;">HS Code</th>
                  <th style="text-align:center;">Package Type</th>
                  <th style="text-align:center;">Qty/Carton</th>
                  <th style="text-align:center;">Units</th>
                  <th style="text-align:center;">Total Cartons</th>
                  <th style="text-align:center;">Net Wt/Kg</th>
                  <th style="text-align:center;">Gross Wt/Kg</th>
                  <th style="text-align:center;">Total Net Wt/Kg</th>
                  <th style="text-align:center;">Total Gross Wt/Kg</th>
                </tr>
              </thead>

              <tbody>
                <t t-set="i" t-value="0"/>
                <t t-foreach="lines" t-as="l">
                  <t t-set="i" t-value="i + 1"/>
                  <tr style="text-align:center;">
                    <td style="text-align:center;" t-esc="i"/>
                    <td style="text-align:center;" t-esc="l.get('product_name', '')"/>
                    <td style="text-align:center;" t-esc="l.get('barcode', '')"/>
                    <td style="text-align:center;" t-esc="l.get('hs_code', '')"/>
                    <td style="text-align:center;" t-esc="l.get('package_type', '')"/>
                    <td style="text-align:center;" t-esc="l.get('qty_per_carton', 0)"/>

                    <td style="text-align:center;">
                      <t t-esc="'%.2f' % (l.get('units', 0.0) or 0.0)"/>
                    </td>
                    <td style="text-align:center;">
                      <t t-esc="'%.2f' % (l.get('cartons', 0.0) or 0.0)"/>
                    </td>
                    <td style="text-align:center;">
                      <t t-esc="'%.2f' % (l.get('net_w', 0.0) or 0.0)"/>
                    </td>
                    <td style="text-align:center;">
                      <t t-esc="'%.2f' % (l.get('gross_w', 0.0) or 0.0)"/>
                    </td>
                    <td style="text-align:center;">
                      <t t-esc="'%.2f' % (l.get('net_total', 0.0) or 0.0)"/>
                    </td>
                    <td style="text-align:center;">
                      <t t-esc="'%.2f' % (l.get('gross_total', 0.0) or 0.0)"/>
                    </td>
                  </tr>
                </t>
              </tbody>

              <tfoot>
                <tr style="text-align:center;">
                  <th colspan="6" style="text-align:center;">Totals</th>

                  <th style="text-align:center;">
                    <t t-esc="'%.2f' % (tot.get('tot_units', 0.0) or 0.0)"/>
                  </th>
                  <th style="text-align:center;">
                    <t t-esc="'%.2f' % (tot.get('tot_cartons', 0.0) or 0.0)"/>
                  </th>

                  <th></th>
                  <th></th>

                  <th style="text-align:center;">
                    <t t-esc="'%.2f' % (tot.get('tot_net', 0.0) or 0.0)"/>
                  </th>
                  <th style="text-align:center;">
                    <t t-esc="'%.2f' % (tot.get('tot_gross', 0.0) or 0.0)"/>
                  </th>
                </tr>
              </tfoot>
            </table>

          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
