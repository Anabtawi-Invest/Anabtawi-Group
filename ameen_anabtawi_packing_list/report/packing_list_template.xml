<tbody>
  <t t-set="i" t-value="0"/>
  <t t-foreach="lines" t-as="l">
    <t t-set="i" t-value="i + 1"/>
    <tr>
      <td t-esc="i"/>
      <td t-esc="l.get('product_name', '')"/>
      <td t-esc="l.get('barcode', '')"/>
      <td t-esc="l.get('hs_code', '')"/>
      <td t-esc="l.get('package_type', '')"/>

      <td t-esc="l.get('qty_per_carton', 0)"/>

      <td>
        <t t-esc="'%.2f' % (l.get('units', 0.0) or 0.0)"/>
      </td>
      <td>
        <t t-esc="'%.2f' % (l.get('cartons', 0.0) or 0.0)"/>
      </td>

      <td>
        <t t-esc="'%.2f' % (l.get('net_w', 0.0) or 0.0)"/>
      </td>
      <td>
        <t t-esc="'%.2f' % (l.get('gross_w', 0.0) or 0.0)"/>
      </td>

      <td>
        <t t-esc="'%.2f' % (l.get('net_total', 0.0) or 0.0)"/>
      </td>
      <td>
        <t t-esc="'%.2f' % (l.get('gross_total', 0.0) or 0.0)"/>
      </td>
    </tr>
  </t>
</tbody>

<tfoot>
  <tr>
    <th colspan="6" style="text-align:right;">Totals</th>

    <th>
      <t t-esc="'%.2f' % (tot.get('tot_units', 0.0) or 0.0)"/>
    </th>

    <th>
      <t t-esc="'%.2f' % (tot.get('tot_cartons', 0.0) or 0.0)"/>
    </th>

    <th></th>
    <th></th>

    <th>
      <t t-esc="'%.2f' % (tot.get('tot_net', 0.0) or 0.0)"/>
    </th>

    <th>
      <t t-esc="'%.2f' % (tot.get('tot_gross', 0.0) or 0.0)"/>
    </th>
  </tr>
</tfoot>
