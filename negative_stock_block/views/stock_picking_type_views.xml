<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_type_form_negative_stock_block" model="ir.ui.view">
        <field name="name">stock.picking.type.form.negative.stock.block</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <!-- Add checkbox in Operations settings -->
            <xpath expr="//group[@name='operation_group']" position="inside">
                <field name="block_negative_stock"/>
            </xpath>
        </field>
    </record>
</odoo>
