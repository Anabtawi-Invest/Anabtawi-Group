<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="invoice_add_fda"
              inherit_id="account.report_invoice_document">

        <!-- Add FDA Number inside information block properly -->
        <xpath expr="//div[@id='informations']//div[contains(@class,'col')][last()]"
               position="after">

            <div class="col-auto">
                <strong>FDA Number:</strong>
                <div>FDA-123456</div>
            </div>

        </xpath>

    </template>

</odoo>
