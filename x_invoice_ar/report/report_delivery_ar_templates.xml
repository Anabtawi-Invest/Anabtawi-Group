<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Arabic Delivery Slip Template -->
    <template id="delivery_ar">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="o" t-value="o.with_context(lang='ar_001')"/>
                <t t-call="stock.report_deliveryslip"
                   t-lang="'ar_001'"/>
            </t>
        </t>
    </template>

    <!-- Report Action -->
    <record id="action_delivery_ar" model="ir.actions.report">
        <field name="name">Delivery Slip (Arabic)</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">x_invoice_ar.delivery_ar</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
