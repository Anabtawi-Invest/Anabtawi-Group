<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Arabic Invoice Wrapper        -->
    <!-- ============================= -->
    <template id="x_invoice_ar_wrapper">
        <t t-call="web.html_container">

            <t t-set="proforma" t-value="False"/>
            <t t-set="print_with_payments" t-value="False"/>

            <t t-foreach="docs" t-as="o">
                <!-- Force Arabic language -->
                <t t-set="o" t-value="o.with_context(lang='ar_001')"/>

                <!-- Call original invoice document -->
                <t t-call="account.report_invoice_document"
                   t-lang="'ar_001'"/>
            </t>

        </t>
    </template>

    <!-- ============================= -->
    <!-- Report Action                 -->
    <!-- ============================= -->
    <record id="action_report_invoice_ar" model="ir.actions.report">
        <field name="name">Invoice (Arabic)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>

        <!-- IMPORTANT: must be one single line, no spaces -->
        <field name="report_name">x_invoice_ar.x_invoice_ar_wrapper</field>

        <!-- Make it appear in Print menu -->
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
