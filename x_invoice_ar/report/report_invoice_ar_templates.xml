<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Template Wrapper -->
    <template id="x_invoice_ar_wrapper">
        <t t-call="web.html_container">

            <t t-set="proforma" t-value="False"/>
            <t t-set="print_with_payments" t-value="False"/>

            <t t-foreach="docs" t-as="o">
                <!-- فرض اللغة العربية -->
                <t t-set="o" t-value="o.with_context(lang='ar_001')"/>

                <!-- استدعاء تقرير الفاتورة القياسي -->
                <t t-call="account.report_invoice_document"
                   t-lang="'ar_001'"/>
            </t>

        </t>
    </template>

    <!-- Report Action -->
    <record id="action_report_invoice_ar"
            model="ir.actions.report">

        <field name="name">Invoice (Arabic)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>

        <!-- لازم يطابق _name في report model -->
        <field name="report_name">
            x_invoice_ar.x_invoice_ar_wrapper
        </field>

        <!-- حتى يظهر في Print -->
        <field name="binding_model_id"
               ref="account.model_account_move"/>
        <field name="binding_type">report</field>

    </record>

</odoo>
