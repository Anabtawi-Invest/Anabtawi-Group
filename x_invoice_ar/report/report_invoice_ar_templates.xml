<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- بدون الدفعات -->
  <template id="x_invoice_ar_wrapper">
    <t t-call="web.html_container">
      <t t-set="proforma" t-value="False"/>
      <t t-set="print_with_payments" t-value="False"/>

      <t t-foreach="docs" t-as="o">
        <t t-set="o" t-value="o.with_context(lang='ar_001')"/>
        <t t-call="account.report_invoice_document" t-lang="'ar_001'"/>
      </t>
    </t>
  </template>

  <!-- مع الدفعات -->
  <template id="x_invoice_ar_wrapper_with_payments">
    <t t-call="web.html_container">
      <t t-set="proforma" t-value="False"/>
      <t t-set="print_with_payments" t-value="True"/>

      <t t-foreach="docs" t-as="o">
        <t t-set="o" t-value="o.with_context(lang='ar_001')"/>
        <t t-call="account.report_invoice_document" t-lang="'ar_001'"/>
      </t>
    </t>
  </template>
</odoo>
