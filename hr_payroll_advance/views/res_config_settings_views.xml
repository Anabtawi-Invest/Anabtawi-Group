<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_res_config_settings_pce" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.pce</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[hasclass('settings')]" position="inside">
        <div class="app_settings_block" data-string="Payroll Control Engine" string="Payroll Control Engine">
          <h2>Payroll Control Engine</h2>
          <div class="row mt16 o_settings_container">
            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane"/>
              <div class="o_setting_right_pane">
                <field name="pce_annual_leave_type_id"/>
                <div class="text-muted">Select the Annual Leave type used for lateness offset after OT bank.</div>
              </div>
            </div>

            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane"/>
              <div class="o_setting_right_pane">
                <field name="pce_lateness_code"/>
                <div class="text-muted">Worked Days code for lateness (e.g. LAT).</div>
              </div>
            </div>

            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane"/>
              <div class="o_setting_right_pane">
                <field name="pce_ot_codes"/>
                <div class="text-muted">Comma-separated OT worked days codes (e.g. OTW,OTR,PHO).</div>
              </div>
            </div>

            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane"/>
              <div class="o_setting_right_pane">
                <field name="pce_default_month_hours"/>
                <div class="text-muted">Fallback hours when month worked hours can't be detected (hourly rate).</div>
              </div>
            </div>

          </div>
        </div>
      </xpath>
    </field>
  </record>
</odoo>
