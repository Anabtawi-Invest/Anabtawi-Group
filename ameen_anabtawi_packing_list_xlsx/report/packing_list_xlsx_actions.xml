<odoo>
  <record id="action_report_packing_list_xlsx" model="ir.actions.report">
    <field name="name">Packing List (XLSX)</field>
    <field name="model">account.move</field>
    <field name="report_type">xlsx</field>
    <field name="report_name">ameen_anabtawi_packing_list_xlsx.pl_xlsx_nodate</field>
    <field name="report_file">packing_list</field>
    <field name="print_report_name">'Packing_List_%s' % (object.name or '')</field>
    <field name="binding_model_id" ref="account.model_account_move"/>
    <field name="binding_type">report</field>
  </record>

  <record id="action_report_packing_list_xlsx_dates" model="ir.actions.report">
    <field name="name">Packing List (XLSX - With Dates)</field>
    <field name="model">account.move</field>
    <field name="report_type">xlsx</field>
    <field name="report_name">ameen_anabtawi_packing_list_xlsx.pl_xlsx_date</field>
    <field name="report_file">packing_list_dates</field>
    <field name="print_report_name">'Packing_List_Dates_%s' % (object.name or '')</field>
    <field name="binding_model_id" ref="account.model_account_move"/>
    <field name="binding_type">report</field>
  </record>
</odoo>
