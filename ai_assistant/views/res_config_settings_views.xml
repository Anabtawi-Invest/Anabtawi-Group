<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ai_assistant</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="AI Assistant" name="ai_assistant" groups="base.group_system">
                    <block title="AI Assistant">
                        <setting id="ai_assistant_enabled_setting" string="AI Assistant Enabled" help="Turn the floating AI chat widget on or off for all users.">
                            <field name="ai_assistant_enabled"/>
                        </setting>
                        <setting id="ai_assistant_provider_setting" string="AI Provider" help="Mock uses built-in intent routing with real Odoo ORM tools. OpenAI uses ChatGPT with dynamic tool calling.">
                            <field name="ai_assistant_provider" class="o_light_label"/>
                        </setting>
                        <setting id="ai_assistant_openai_api_key_setting" string="OpenAI API Key" help="Your OpenAI API key. Only used when AI Provider is OpenAI." invisible="ai_assistant_provider != 'openai'">
                            <field name="ai_assistant_openai_api_key" password="True" placeholder="sk-..."/>
                        </setting>
                        <setting id="ai_assistant_openai_model_setting" string="OpenAI Model Name" help="Model passed to the OpenAI Chat Completions API." invisible="ai_assistant_provider != 'openai'">
                            <field name="ai_assistant_openai_model" placeholder="gpt-4o-mini"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
