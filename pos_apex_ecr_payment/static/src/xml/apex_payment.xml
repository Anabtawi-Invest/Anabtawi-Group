<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!--
        ApexPaymentDialog
        Full-screen modal shown while waiting for the EFTPOS terminal.
        Displayed over the POS PaymentScreen during a pending transaction.
    -->
    <t t-name="pos_apex_ecr_payment.ApexPaymentDialog">
        <div class="apex-payment-overlay">
            <div class="apex-payment-dialog">
                <div class="apex-dialog-header">
                    <h3 class="apex-dialog-title">Card Payment</h3>
                </div>

                <div class="apex-dialog-body">
                    <!-- Waiting -->
                    <t t-if="state.status === 'waiting'">
                        <div class="apex-spinner-wrap">
                            <div class="apex-spinner"/>
                        </div>
                        <p class="apex-status-text">Please follow the instructions on the terminal…</p>
                        <p class="apex-amount-text"><t t-esc="state.amountLabel"/></p>
                    </t>

                    <!-- Approved -->
                    <t t-elif="state.status === 'approved'">
                        <div class="apex-result-icon apex-approved">✓</div>
                        <p class="apex-status-text">Payment Approved</p>
                        <p class="apex-detail-text">
                            <t t-if="state.result.card_scheme">
                                <t t-esc="state.result.card_scheme"/>
                            </t>
                            <t t-if="state.result.masked_pan">
                                &nbsp;·&nbsp;<t t-esc="state.result.masked_pan"/>
                            </t>
                        </p>
                        <p class="apex-detail-text">
                            Auth: <strong><t t-esc="state.result.auth_code"/></strong>
                            &nbsp;|&nbsp;RRN: <t t-esc="state.result.rrn"/>
                        </p>
                    </t>

                    <!-- Declined -->
                    <t t-elif="state.status === 'declined'">
                        <div class="apex-result-icon apex-declined">✕</div>
                        <p class="apex-status-text">Payment Declined</p>
                        <p class="apex-detail-text">
                            <t t-esc="state.result.resp_text"/>
                            (<t t-esc="state.result.resp_code"/>)
                        </p>
                    </t>

                    <!-- Error -->
                    <t t-elif="state.status === 'error'">
                        <div class="apex-result-icon apex-error">!</div>
                        <p class="apex-status-text">Terminal Error</p>
                        <p class="apex-detail-text"><t t-esc="state.errorMessage"/></p>
                    </t>
                </div>

                <div class="apex-dialog-footer">
                    <t t-if="state.status === 'waiting'">
                        <button class="btn btn-secondary apex-btn-cancel" t-on-click="onCancel">
                            Cancel
                        </button>
                    </t>
                    <t t-if="state.status !== 'waiting'">
                        <button class="btn btn-primary apex-btn-close" t-on-click="onClose">
                            Close
                        </button>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>
