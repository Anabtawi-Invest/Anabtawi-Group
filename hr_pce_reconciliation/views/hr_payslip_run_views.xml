<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_run_form_pce" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.pce</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_run_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_open_pce_review"
                        type="object"
                        string="Smart Review"
                        class="btn-secondary"
                        groups="hr_pce_reconciliation.group_pce_manager"/>

                <button name="action_pce_mass_reconcile"
                        type="object"
                        string="Mass Reconciliation"
                        class="btn-primary"
                        groups="hr_pce_reconciliation.group_pce_manager"
                        attrs="{'invisible': [('state','not in', ['draft','verify'])]}"/>
            </xpath>

            <!-- Stat button badge -->
            <xpath expr="//sheet//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_open_pce_review"
                        class="oe_stat_button"
                        icon="fa-check-square"
                        groups="hr_pce_reconciliation.group_pce_manager">
                    <field name="pce_deduction_count" widget="statinfo" string="PCE Deductions"/>
                </button>
            </xpath>

        </field>
    </record>

</odoo>
