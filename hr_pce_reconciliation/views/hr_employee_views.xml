<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_pce_ot_bank" model="ir.ui.view">
        <field name="name">hr.employee.form.pce.ot.bank</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="PCE Balances" groups="hr_pce_reconciliation.group_pce_manager">
                    <field name="overtime_bank_hours" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
