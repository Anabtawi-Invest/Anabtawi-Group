<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_pce_review_line_tree" model="ir.ui.view">
        <field name="name">hr.pce.review.line.tree</field>
        <field name="model">hr.pce.review.line</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0">
                <field name="employee_id"/>
                <field name="ot_total_hours"/>
                <field name="lateness_hours"/>
                <field name="annual_available_hours"/>
                <field name="remaining_hours"/>

                <field name="badge_state"
                       widget="badge"
                       decoration-success="badge_state=='ok'"
                       decoration-warning="badge_state=='warning'"
                       decoration-danger="badge_state=='danger'"/>
            </tree>
        </field>
    </record>

</odoo>
