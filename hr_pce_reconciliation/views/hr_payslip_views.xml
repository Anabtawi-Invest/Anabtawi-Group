<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =====================================================
         Payroll Control Engine - Payslip View Extension
         Odoo 19 SAFE VERSION
    ====================================================== -->

    <record id="view_hr_payslip_form_pce" model="ir.ui.view">
        <field name="name">hr.payslip.form.pce</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_view_form"/>
        <field name="arch" type="xml">

            <!-- ===============================
                 HEADER BUTTON (RECONCILIATION)
            ================================ -->

            <xpath expr="//header" position="inside">

                <button name="action_pce_reconcile"
                        string="Reconciliation"
                        type="object"
                        class="btn-primary"
                        modifiers="{'invisible': [['state','!=','draft']]}"/>

            </xpath>

            <!-- ===============================
                 ENTERPRISE DASHBOARD FIELDS
            ================================ -->

            <xpath expr="//sheet//group" position="inside">

                <group string="Payroll Control Engine">

                    <field name="pce_lateness_hours" readonly="1"/>
                    <field name="pce_ot_total_hours" readonly="1"/>
                    <field name="pce_annual_used_hours" readonly="1"/>
                    <field name="pce_salary_deduction_hours" readonly="1"/>

                </group>

            </xpath>

        </field>
    </record>

</odoo>
