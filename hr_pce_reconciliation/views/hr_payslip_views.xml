<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_pce" model="ir.ui.view">
        <field name="name">hr.payslip.form.pce</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_pce_reconcile" type="object" string="Reconcile" class="btn-primary"
                        groups="hr_pce_reconciliation.group_pce_manager"
                        modifiers="{'invisible': [('pce_reconciled','=',True)]}"/>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Reconciliation" groups="hr_pce_reconciliation.group_pce_manager">
                    <group>
                        <field name="pce_reconciled" readonly="1"/>
                        <field name="pce_ot_hours_total" readonly="1"/>
                        <field name="pce_lateness_hours" readonly="1"/>
                        <field name="pce_annual_hours_used" readonly="1"/>
                        <field name="pce_salary_hours_deducted" readonly="1"/>
                        <field name="pce_reconciled_on" readonly="1"/>
                        <field name="pce_reconciled_by" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_hr_payslip_tree_pce" model="ir.ui.view">
        <field name="name">hr.payslip.tree.pce</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="pce_reconciled" optional="show"/>
                <field name="pce_ot_hours_total" optional="show"/>
                <field name="pce_lateness_hours" optional="show"/>
                <field name="pce_annual_hours_used" optional="show"/>
                <field name="pce_salary_hours_deducted" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
