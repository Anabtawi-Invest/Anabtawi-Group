<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_hr_payslip_run_form_pce" model="ir.ui.view">
    <field name="name">hr.payslip.run.form.pce</field>
    <field name="model">hr.payslip.run</field>
    <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet/group" position="after">
        <group string="Payroll Control Totals">
          <field name="pce_total_lateness_hours" readonly="1"/>
          <field name="pce_total_ot_hours" readonly="1"/>
          <field name="pce_total_unpaid_hours" readonly="1"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
