<odoo>
    <!-- Payslip FORM: status badge + reconcile button -->
    <record id="hr_payslip_form_reconcile_badge" model="ir.ui.view">
        <field name="name">hr.payslip.form.reconcile.badge</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="reconciliation_state" widget="badge"/>
                <button name="action_reconcile_lateness_engine_v2"
                        type="object"
                        string="Reconcile Lateness"
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <!-- Payslip TREE/LIST: add badge and key columns (safe anchor: employee_id) -->
    <record id="hr_payslip_tree_reconcile_badge" model="ir.ui.view">
        <field name="name">hr.payslip.tree.reconcile.badge</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="reconciliation_state" widget="badge"/>
                <field name="late_hours"/>
                <field name="ot_total_hours"/>
                <field name="leave_hours_available"/>
                <field name="ot_deduct_hours"/>
                <field name="leave_deduct_hours"/>
                <field name="salary_deduct_hours"/>
            </xpath>
        </field>
    </record>
</odoo>
