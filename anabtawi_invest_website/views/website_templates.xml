        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty anabtawi-theme bg-charcoal">
                <!-- Page Title / Header -->
                <section class="anabtawi-page-header py-6 text-center text-white position-relative overflow-hidden">
                    <div class="anabtawi-hero-overlay"></div>
                    <div class="container position-relative z-index-2 scroll-fade-in">
