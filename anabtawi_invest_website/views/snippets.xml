    <!-- Custom Subsidiaries Marquee Snippet Markup (English Only) -->
    <template id="snippet_anabtawi_portfolio" name="Anabtawi Companies Loop">
        <section class="anabtawi-companies-section py-6 bg-matte text-white">
            <div class="container">
                <div class="text-center mb-5 scroll-fade-in">
                    <span class="text-uppercase tracking-wider brand-gold d-inline-block mb-2 font-weight-bold">Our Subsidiaries</span>
                    <h2 class="h1 font-serif text-white font-weight-bold">Investment Sectors</h2>
                    <div class="divider-gold mx-auto my-3"></div>
                </div>
            </div>
            
            <!-- Scrolling Marquee Ticker Track (Loop Right to Left, English only) -->
            <div class="marquee-container py-4 overflow-hidden position-relative">
                <div class="marquee-track d-flex">
                    <!-- 6 original interactive cards -->
                    <a href="/companies/anabtawi-sweets" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Anabtawi Sweets" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Anabtawi Sweets</div>
                    </a>
                    <a href="/companies/united-food" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="United Food Trading" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">United Food Trading</div>
                    </a>
                    <a href="/companies/anabtawi-coffee" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Anabtawi Coffee" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Anabtawi Coffee</div>
                    </a>
                    <a href="/companies/ein-jaloot" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Ein Jaloot" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Ein Jaloot</div>
                    </a>
                    <a href="/companies/tryaq-honey" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Tryaq Honey" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Tryaq Honey</div>
                    </a>
                    <a href="/companies/holy-land-sweets" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Holy Land Sweets" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Holy Land Sweets</div>
                    </a>
                    
                    <!-- Duplicate items to create a seamless infinite scrolling loop -->
                    <a href="/companies/anabtawi-sweets" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Anabtawi Sweets" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Anabtawi Sweets</div>
                    </a>
                    <a href="/companies/united-food" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="United Food Trading" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">United Food Trading</div>
                    </a>
                    <a href="/companies/anabtawi-coffee" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Anabtawi Coffee" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Anabtawi Coffee</div>
                    </a>
                    <a href="/companies/ein-jaloot" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Ein Jaloot" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Ein Jaloot</div>
                    </a>
                    <a href="/companies/tryaq-honey" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Tryaq Honey" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Tryaq Honey</div>
                    </a>
                    <a href="/companies/holy-land-sweets" class="marquee-item text-decoration-none flex-shrink-0">
                        <div class="company-logo-placeholder">
                            <img src="/web/static/img/placeholder.png" alt="Holy Land Sweets" class="company-logo-img"/>
                        </div>
                        <div class="company-name text-center mt-3 font-serif text-white">Holy Land Sweets</div>
                    </a>
                </div>
            </div>
        </section>
    </template>

    <!-- Register custom snippets in the website editor sidebar under 'Anabtawi Invest' category -->
    <template id="snippets" inherit_id="website.snippets" name="Anabtawi Invest Snippets">
        <xpath expr="//t[@id='installed_snippets_hook']" position="after">
            <t snippet-group="anabtawi" t-snippet="website.s_snippet_group" string="Anabtawi Invest"
               t-thumbnail="/website/static/src/img/snippets_thumbs/s_cover.svg"/>
        </xpath>
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="anabtawi_invest_website.snippet_anabtawi_hero"
               string="Anabtawi Invest Hero"
               group="anabtawi"
               t-thumbnail="/website/static/src/img/snippets_thumbs/s_cover.svg"/>
            <t t-snippet="anabtawi_invest_website.snippet_anabtawi_portfolio"
               string="Anabtawi Companies Loop"
               group="anabtawi"
               t-thumbnail="/website/static/src/img/snippets_thumbs/s_three_columns.svg"/>
        </xpath>
    </template>
</odoo>
