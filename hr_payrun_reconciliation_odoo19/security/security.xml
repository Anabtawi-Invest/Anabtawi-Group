<odoo>

    <!-- Explicit model declaration (MANDATORY in Odoo 19 for access rules) -->
    <record id="model_hr_payrun_reconciliation" model="ir.model">
        <field name="name">Payrun Lateness Reconciliation</field>
        <field name="model">hr.payrun.reconciliation</field>
        <field name="state">manual</field>
    </record>

    <!-- HR users can see reconciliation records -->
    <record id="rule_hr_payrun_reconciliation_hr" model="ir.rule">
        <field name="name">Payrun Reconciliation - HR Access</field>
        <field name="model_id" ref="model_hr_payrun_reconciliation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>

</odoo>
