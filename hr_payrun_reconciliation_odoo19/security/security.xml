<odoo>
    <!-- HR users can access reconciliation records -->
    <record id="rule_hr_payrun_reconciliation_hr" model="ir.rule">
        <field name="name">Payrun Reconciliation - HR Access</field>
        <field name="model_id" ref="hr_payrun_reconciliation.model_hr_payrun_reconciliation"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>
</odoo>
