<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res_config_settings_health_view_form</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="150"/>
            <field name="inherit_id" ref="hr_payroll.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@id='hr_payroll_settings']" position="after">
                    <block title="Health Insurance Configuration" id="health_insurance_block"
                           groups="base.group_multi_company">
                        <setting id="health_account_setting">
                            <field name="hi_account_id"
                                   domain="[('company_ids', 'in', [company_id]), ('active', '=', True)]"/>
                        </setting>
                        <setting id="health_reference_employee_setting">
                            <field name="hi_reference_employee_in_journal_entries"/>
                        </setting>
                        <setting id="health_before_expiry_date_setting">
                            <field name="before_the_expiry_date"/>
                        </setting>
                    </block>
                </xpath>

            </field>
        </record>
    </data>
</odoo>
