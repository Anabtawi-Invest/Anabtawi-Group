<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_prr" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.prr</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Odoo 19 SAFE insertion point -->
            <xpath expr="//form" position="inside">

                <app name="payroll_reconciliation" string="Payroll Reconciliation">

                    <block title="Payroll Reconciliation">

                        <setting string="Lateness Work Entry Type"
                                 help="Work Entry Type used to represent lateness hours.">
                            <field name="prr_lateness_work_entry_type_id"/>
                        </setting>

                        <setting string="OT Work Entry Types (Bank)"
                                 help="Optional. Select Work Entry Types that represent accrued overtime.">
                            <field name="prr_ot_work_entry_type_ids" widget="many2many_tags"/>
                        </setting>

                        <setting string="Annual Leave Type (Hours)"
                                 help="Time Off Type (in hours) consumed when lateness exceeds overtime.">
                            <field name="prr_annual_leave_type_id"/>
                        </setting>

                    </block>

                </app>

            </xpath>

        </field>
    </record>
</odoo>
