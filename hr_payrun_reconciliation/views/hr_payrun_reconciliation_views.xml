<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payrun_reconciliation_list" model="ir.ui.view">
        <field name="name">hr.payrun.reconciliation.list</field>
        <field name="model">hr.payrun.reconciliation</field>
        <field name="arch" type="xml">
            <list>
                <field name="pay_run_id"/>
                <field name="employee_id"/>
                <field name="lateness_hours"/>
                <field name="ot_used_hours"/>
                <field name="annual_used_hours"/>
                <field name="late_unpaid_hours"/>
                <field name="execution_datetime"/>
                <field name="executed_by"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hr_payrun_reconciliation_form" model="ir.ui.view">
        <field name="name">hr.payrun.reconciliation.form</field>
        <field name="model">hr.payrun.reconciliation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="pay_run_id" readonly="1"/>
                        <field name="employee_id" readonly="1"/>
                        <field name="company_id" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                    <group string="Hours">
                        <field name="lateness_hours" readonly="1"/>
                        <field name="ot_used_hours" readonly="1"/>
                        <field name="annual_used_hours" readonly="1"/>
                        <field name="late_unpaid_hours" readonly="1"/>
                    </group>
                    <group string="Traceability">
                        <field name="execution_datetime" readonly="1"/>
                        <field name="executed_by" readonly="1"/>
                    </group>
                    <group string="Generated Records">
                        <field name="payslip_id" readonly="1"/>
                        <field name="ot_input_id" readonly="1"/>
                        <field name="annual_input_id" readonly="1"/>
                        <field name="late_unpaid_input_id" readonly="1"/>
                        <field name="annual_leave_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_payrun_reconciliation" model="ir.actions.act_window">
        <field name="name">Pay Run Reconciliation</field>
        <field name="res_model">hr.payrun.reconciliation</field>
        <field name="view_mode">list,form</field>
    </record>

<menuitem
    id="menu_hr_payrun_reconciliation_root"
    name="Pay Run Reconciliation"
    parent="hr.menu_hr_root"
    sequence="90"
    action="action_hr_payrun_reconciliation"
    groups="hr_payroll.group_hr_payroll_manager"
/>

</odoo>
