<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payroll Manager: full access -->
    <record id="access_hr_payrun_reconciliation_manager" model="ir_model_access">
        <field name="name">hr.payrun.reconciliation manager</field>
        <field name="model_id" ref="model_hr_payrun_reconciliation"/>
        <field name="group_id" ref="hr_payroll.group_hr_payroll_manager"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <!-- HR User: read-only -->
    <record id="access_hr_payrun_reconciliation_user" model="ir_model_access">
        <field name="name">hr.payrun.reconciliation user</field>
        <field name="model_id" ref="model_hr_payrun_reconciliation"/>
        <field name="group_id" ref="hr.group_hr_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

</odoo>
