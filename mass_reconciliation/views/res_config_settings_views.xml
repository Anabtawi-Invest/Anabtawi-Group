<odoo>
  <record id="res_config_settings_view_form_lateness_coverage" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.lateness.coverage</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//form" position="inside">
        <app string="Lateness Coverage" name="lateness_coverage">
          <block title="Lateness Coverage Settings">
            <setting
              string="Annual Leave Type"
              help="Select the hour-based Annual Leave type that will be deducted when OT buckets are not enough."
            >
              <field name="annual_leave_type_id"/>
            </setting>
          </block>
        </app>
      </xpath>
    </field>
  </record>
</odoo>