<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_mass_reconciliation_pay_run" model="ir.actions.server">
        <field name="name">Mass Reconciliation</field>
        <field name="model_id" ref="hr_payroll.model_hr_payslip_run"/>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip_run"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
for run in records:
    run.slip_ids.action_reconcile_lateness_no_ot_bank()
action = {'type': 'ir.actions.client', 'tag': 'reload'}
        </field>
    </record>

    <record id="action_mass_reconciliation_payslips" model="ir.actions.server">
        <field name="name">Mass Reconciliation (Payslips)</field>
        <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
action = records.action_reconcile_lateness_no_ot_bank()
        </field>
    </record>
</odoo>
