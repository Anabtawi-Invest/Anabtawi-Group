<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_pos_advance" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.pos.advance</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="90"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//form" position="inside">

                    <app name="pos_advance"
                         string="POS Advance Payments"
                         data-string="POS Advance Payments"
                         groups="point_of_sale.group_pos_manager">

                        <block title="Advance Payments"
                               name="pos_advance_payment_settings"
                               help="Configure how advance payments are handled in Point of Sale.">

                            <setting id="pos_advance_journal_setting"
                                     string="Advance Payment Journal"
                                     help="Journal used to record advance payments taken from customers in POS.">
                                <field name="pos_advance_journal_id"
                                       options="{'no_create': True}"/>
                            </setting>
                            <setting id="pos_advance_account_setting"
                                     string="Advance Liability Account"
                                     help="Account used to hold customer advance amounts until invoiced.">
                                <field name="pos_advance_account_id"
                                       />
                            </setting>
                             <setting id="pos_journal_setting"
                                     string="Payment Journal"
                                     help="Journal used to record  payments taken from customers in POS.">
                                <field name="second_journal_id"
                                       />
                            </setting>
                             <setting id="pos_cash_journal_id_setting"
                                     string="POS Cash Journal"
                                     help="Cash Journal used to record  payments taken from customers in POS.">
                                <field name="pos_cash_journal_id"
                                       />
                             </setting>
                            <setting id="pos_card_journal_id_setting"
                                     string="POS Card Journal"
                                     help="Card Journal used to record  payments taken from customers in POS.">
                                <field name="pos_card_journal_id"
                                       />
                            </setting>


                        </block>

                    </app>

                </xpath>

            </field>
        </record>

    </data>
</odoo>
