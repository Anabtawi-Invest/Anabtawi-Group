<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_advance_payment_tree" model="ir.ui.view">
        <field name="name">pos.advance.payment.tree</field>
        <field name="model">pos.advance.payment</field>
        <field name="arch" type="xml">
            <list string="POS Advances">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_paid"/>
                <field name="remaining_amount"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>


    <record id="view_pos_advance_payment_form" model="ir.ui.view">
        <field name="name">pos.advance.payment.form</field>
        <field name="model">pos.advance.payment</field>
        <field name="arch" type="xml">
            <form string="POS Advance Payment">
                <header>
                    <field name="state" widget="statusbar"/>

                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-danger"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="payment_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>

                        <group>
                            <field name="total_expected" readonly="1"/>
                            <field name="amount_paid" readonly="1"/>
                            <field name="remaining_amount" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Products -->
                        <page string="Products">
                            <field name="line_ids" readonly="1" create='0' delete='0'>
                                <list>
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal"/>
                                </list>
                            </field>
                        </page>

                        <!-- Accounting -->
                        <page string="Accounting">
                            <group>
                                <field name="payment_id" readonly="1"/>
                                <field name="invoice_id" readonly="1"/>
                            </group>
                        </page>

                        <!-- Notes -->
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_advance_payment" model="ir.actions.act_window">
        <field name="name">POS Advances</field>
        <field name="res_model">pos.advance.payment</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create and manage POS customer advances.
            </p>
        </field>
    </record>

    <menuitem id="menu_pos_advance_root"
              name="POS Advances"
              parent="point_of_sale.menu_point_root"
              sequence="50"/>

    <menuitem id="menu_pos_advance_payment"
              name="Customer Advances"
              parent="menu_pos_advance_root"
              action="action_pos_advance_payment"
              sequence="10"/>
</odoo>
