<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit POS Config Form View to Add Advance Payment Settings -->
        <record id="view_pos_config_form_advance" model="ir.ui.view">
            <field name="name">pos.config.form.advance</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                
                <!-- Add settings at the end of the sheet -->
                <xpath expr="//sheet" position="inside">
                    <group string="Advance Payment Configuration" name="advance_payment_config">
                        <group>
                            <field name="pos_advance_account_id" 
                                   options="{'no_create': True}"/>
                            <field name="pos_cash_journal_id" 
                                   options="{'no_create': True}"/>
                            <field name="pos_card_journal_id" 
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                </xpath>
                
            </field>
        </record>
    </data>
</odoo>
