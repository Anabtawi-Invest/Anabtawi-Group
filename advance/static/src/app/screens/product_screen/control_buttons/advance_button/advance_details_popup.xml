<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_advance.AdvanceDetailsPopup">
        <Dialog title="'Advance Payment Details'" size="'md'">
            <div class="popup-body p-4">
                
                <!-- Due Date Field -->
                <div class="mb-4">
                    <label class="form-label fw-bold">
                        Due Date <span class="text-danger">*</span>
                    </label>
                    <input 
                        type="date" 
                        class="form-control form-control-lg"
                        t-model="state.dueDate"
                        t-on-change="onDueDateChange"
                        required="true"
                    />
                    <small class="text-muted">Expected date for order completion/pickup</small>
                </div>

                <!-- Pickup Location Field -->
                <div class="mb-4">
                    <label class="form-label fw-bold">
                        Pickup Location (POS) <span class="text-danger">*</span>
                    </label>
                    <select 
                        class="form-select form-select-lg"
                        t-model="state.pickupPosId"
                        t-on-change="onPickupPosChange"
                        required="true"
                    >
                        <option value="">-- Select Pickup Location --</option>
                        <t t-foreach="state.availablePos" t-as="posConfig" t-key="posConfig.id">
                            <option t-att-value="posConfig.id">
                                <t t-esc="posConfig.name"/>
                            </option>
                        </t>
                    </select>
                    <small class="text-muted">Point of Sale where the order will be collected</small>
                </div>

            </div>

            <!-- Footer Buttons -->
            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="onCancel">
                    Cancel
                </button>
                <button class="btn btn-primary" t-on-click="onConfirm">
                    Confirm
                </button>
            </t>
        </Dialog>
    </t>

</templates>
