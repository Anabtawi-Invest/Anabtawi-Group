<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="pos_advance.AdvanceOrderListPopup">

    <!-- ===============================
         ADVANCE LIST
         =============================== -->
    <Dialog title="'Complete Advance Order'">
        <div class="p-3">
<div class="mb-3">
    <input type="text"
           class="form-control"
           placeholder="Search by advance number or customer..."
           t-on-input="onSearchInput"
           t-on-keydown="onSearchKeydown"/>

</div>
            <t t-if="!state.advances.length">
                <p>No advance payments found.</p>
            </t>

            <ul class="list-group" t-if="state.advances.length">
                <t t-foreach="state.advances" t-as="adv" t-key="adv.id">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong t-esc="adv.name"/>
                            <br/>
                            <small>
                                Customer:
                                <t t-esc="adv.partner_id[1]"/>
                            </small>
                        </div>

                        <button class="btn btn-primary"
                                t-on-click="selectAdvance.bind(this, adv)">
                            Open
                        </button>
                    </li>
                </t>
            </ul>

        </div>
    </Dialog>

    <!-- ===============================
         SELECTED ADVANCE DETAILS
         =============================== -->
    <Dialog t-if="state.selectedAdvance" title="'Advance Details'">
        <div class="p-3">

            <!-- Customer & Amounts -->
            <div><b>Advance #</b>
                <t t-esc="state.selectedAdvance.name"/></div>

            <div><b>Customer:</b>
                <t t-esc="state.selectedAdvance.customer"/></div>
            <div><b>Total:</b>
                <t t-esc="state.selectedAdvance.total"/></div>
            <div><b>Paid:</b>
                <t t-esc="state.selectedAdvance.paid"/></div>
            <div class="text-danger mb-3">
                <b>Remaining:</b>
                <t t-esc="state.selectedAdvance.remaining"/>
            </div>

            <!-- ===============================
                 PRODUCTS TABLE
                 =============================== -->
            <t t-if="state.selectedAdvance.products and state.selectedAdvance.products.length">
                <table class="table table-sm table-bordered mt-3">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.selectedAdvance.products" t-as="p" t-key="p.product_id">
                            <tr>
                                <td>
                                    <t t-esc="p.product_name"/>
                                </td>
                                <td class="text-end">
                                    <t t-esc="p.qty"/>
                                </td>
                                <td class="text-end">
                                    <t t-esc="p.price_unit"/>
                                </td>
                                <td class="text-end">
                                    <t t-esc="p.subtotal"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>

            <t t-if="!state.selectedAdvance.products or !state.selectedAdvance.products.length">
                <p class="text-muted mt-3">
                    No products found for this advance.
                </p>
            </t>
            <div class="mt-2">
    <label class="form-label">Payment Method</label>
    <select class="form-select" t-model="state.paymentType">
        <option value="cash">Cash</option>
        <option value="card">Card</option>
    </select>
</div>

            <!-- Actions -->
            <div class="mt-3 text-end">
                <button class="btn btn-success"
                        t-on-click="createInvoice">
                    Create Invoice
                </button>
            </div>

        </div>
    </Dialog>

</t>

</templates>
