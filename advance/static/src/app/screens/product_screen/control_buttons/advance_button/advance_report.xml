<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="advance.AdvanceReceipt">
    <div class="pos-receipt">
        <div>Advance Receipt</div>

        <!-- ✅ FOREACH WITH t-key + props -->
        <t t-foreach="props.lines" t-as="line" t-key="line.key">
            <div>
                <t t-esc="line.name"/>
                <span class="pos-receipt-right-align">
                    <t t-esc="line.qty"/> x
                    <t t-esc="props.formatCurrency(line.price, false)"/>
                </span>
            </div>
        </t>

        <div>-------------------</div>

        <div>
            Advance Paid:
            <span class="pos-receipt-right-align">
                <t t-esc="props.formatCurrency(props.advance_amount, false)"/>
            </span>
        </div>

        <div>
            Remaining:
            <span class="pos-receipt-right-align">
                <t t-esc="props.formatCurrency(props.remaining_amount, false)"/>
            </span>
        </div>
    </div>
</t>

</templates>
