<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_advance.ControlButtons"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">

        <xpath expr="//t[@t-if='props.showRemainingButtons']/div" position="after">

            <button class="btn btn-secondary btn-lg"
                    t-on-click="() => this.onClickCompleteAdvanceOrder()">
                Complete Advance Order
            </button>
        </xpath>

    </t>

</templates>
