<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_purge_wizard_form" model="ir.ui.view">
        <field name="name">pos.purge.wizard.form</field>
        <field name="model">pos.purge.wizard</field>
        <field name="arch" type="xml">
            <form string="POS Historical Purge">
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="cutoff_date"/>
                        <field name="mode" widget="radio"/>
                        <field name="state_preset"/>
                    </group>
                    <group string="Order statuses">
                        <field name="include_state_draft" readonly="state_preset != 'custom'"/>
                        <field name="include_state_cancel" readonly="state_preset != 'custom'"/>
                        <field name="include_state_paid" readonly="state_preset != 'custom'"/>
                        <field name="include_state_done" readonly="state_preset != 'custom'"/>
                    </group>
                    <group>
                        <field name="stock_handling"/>
                        <field name="purge_sessions"/>
                        <field name="block_submitted_einvoices"/>
                        <field name="batch_size"/>
                    </group>
                </group>
                <group invisible="mode != 'purge'">
                    <field name="confirm_purge"/>
                    <field name="ignore_blockers"/>
                    <field name="stop_on_error"/>
                </group>
                <group invisible="state != 'analyzed'">
                    <group string="Analysis summary">
                        <field name="order_count"/>
                        <field name="session_count"/>
                        <field name="full_session_count"/>
                        <field name="mixed_session_count"/>
                    </group>
                    <group>
                        <field name="invoice_count"/>
                        <field name="picking_count"/>
                        <field name="done_picking_count"/>
                        <field name="error_count"/>
                        <field name="warning_count"/>
                    </group>
                </group>
                <field name="state" invisible="1"/>
                <notebook invisible="state != 'analyzed'">
                    <page string="Report" name="report">
                        <field name="report_line_ids" nolabel="1">
                            <list decoration-danger="level == 'error'" decoration-warning="level == 'warning'">
                                <field name="level"/>
                                <field name="category"/>
                                <field name="order_id"/>
                                <field name="message"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_analyze" type="object" string="Analyze (dry-run)" class="btn-primary"/>
                    <button name="action_execute_purge" type="object" string="Execute purge"
                            class="btn-danger" invisible="mode != 'purge'"/>
                    <button string="Close" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_purge_wizard" model="ir.actions.act_window">
        <field name="name">POS Historical Purge</field>
        <field name="res_model">pos.purge.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
