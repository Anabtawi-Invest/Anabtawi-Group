<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sequence for overtime request reference numbers -->
    <record id="seq_overtime_request" model="ir.sequence">
        <field name="name">Overtime Request</field>
        <field name="code">attendance.overtime.request</field>
        <field name="prefix">OT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Record rule: employees can only see their own requests -->
    <record id="rule_overtime_request_employee_own" model="ir.rule">
        <field name="name">Overtime Request: Employee sees own only</field>
        <field name="model_id" ref="model_attendance_overtime_request"/>
        <field name="groups" eval="[(4, ref('hr_attendance.group_hr_attendance_user'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Managers can see all requests (no domain restriction) -->
    <record id="rule_overtime_request_manager_all" model="ir.rule">
        <field name="name">Overtime Request: Manager sees all</field>
        <field name="model_id" ref="model_attendance_overtime_request"/>
        <field name="groups" eval="[(4, ref('hr_attendance.group_hr_attendance_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
