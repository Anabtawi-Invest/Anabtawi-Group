<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend the attendance list view -->
    <record id="view_hr_attendance_list_inherit" model="ir.ui.view">
        <field name="name">hr.attendance.list.inherit.att_tracking</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='check_out']" position="after">
                <field name="is_auto_checkout"
                       string="Auto C/O"
                       optional="show"
                       widget="boolean_toggle"/>
                <field name="extra_hours"
                       optional="show"
                       widget="float_time"
                       string="Extra Hours"/>
                <field name="overtime_request_id"
                       optional="show"
                       string="OT Request"/>
            </xpath>
        </field>
    </record>

    <!-- Extend the attendance form view -->
    <record id="view_hr_attendance_form_inherit" model="ir.ui.view">
        <field name="name">hr.attendance.form.inherit.att_tracking</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='check_out']" position="after">
                <field name="scheduled_check_out" readonly="1"/>
                <field name="overtime_request_id" readonly="1"/>
                <field name="is_auto_checkout" readonly="1"/>
                <field name="extra_hours" readonly="1" widget="float_time"/>
                <field name="checkin_note" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
