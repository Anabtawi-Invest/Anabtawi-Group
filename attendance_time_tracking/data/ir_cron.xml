<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Auto-checkout cron: runs every 5 minutes.
        Checks all open attendance records and closes them
        if the auto-checkout trigger time has been reached.
    -->
    <record id="ir_cron_auto_checkout" model="ir.cron">
        <field name="name">Attendance: Auto Check-out</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_checkout()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
        <field name="priority">5</field>
    </record>

</odoo>
