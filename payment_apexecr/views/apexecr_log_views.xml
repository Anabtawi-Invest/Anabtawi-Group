<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_apexecr_log_tree" model="ir.ui.view">
        <field name="name">apexecr.log.tree</field>
        <field name="model">apexecr.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="operation"/>
                <field name="status"/>
                <field name="reference_number"/>
                <field name="payment_method_id"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <record id="view_apexecr_log_form" model="ir.ui.view">
        <field name="name">apexecr.log.form</field>
        <field name="model">apexecr.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="create_date"/>
                        <field name="operation"/>
                        <field name="status"/>
                        <field name="reference_number"/>
                        <field name="payment_method_id"/>
                        <field name="error_message"/>
                    </group>
                    <group>
                        <field name="request_payload"/>
                        <field name="response_payload"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_apexecr_log" model="ir.actions.act_window">
        <field name="name">ApexECR Logs</field>
        <field name="res_model">apexecr.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_apexecr_root" name="ApexECR" parent="point_of_sale.menu_point_root" sequence="95"/>
    <menuitem id="menu_apexecr_log" name="Logs" parent="menu_apexecr_root" action="action_apexecr_log" sequence="10"/>
</odoo>

