<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="purchase_order_list_inherit_confirm_approval" model="ir.ui.view">
        <field name="name">purchase.order.list.confirm.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="confirm_approval_status_text" optional="show"/>
                <field name="current_approval_group_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_form_inherit_confirm_approval" model="ir.ui.view">
        <field name="name">purchase.order.form.confirm.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//notebook" position="inside">
                <page string="Confirmation Approvals">
                    <group>
                        <field name="confirm_approval_status" readonly="1"/>
                        <field name="confirm_approval_status_text" readonly="1"/>
                        <field name="current_approval_group_id" readonly="1"/>
                    </group>

                    <field name="confirm_approval_ids" readonly="1">
                        <list>
                            <field name="sequence"/>
                            <field name="group_id"/>
                            <field name="required"/>
                            <field name="state"/>
                            <field name="approved_by_id"/>
                            <field name="approved_date"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
