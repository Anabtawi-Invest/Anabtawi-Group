<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="pos_pledge.PledgeListPopup">
    <Dialog title="'Select Pledge to Return'">
        <div class="p-3">
            
            <!-- SEARCH BAR -->
            <div class="mb-3">
                <input type="text"
                       class="form-control"
                       placeholder="Search by pledge number, customer name, or employee name..."
                       t-on-input="onSearchInput"
                       t-on-keydown="onSearchKeydown"
                       autofocus="autofocus"/>
            </div>

            <!-- NO PLEDGES FOUND -->
            <t t-if="!state.pledges.length">
                <div class="alert alert-warning">
                    <i class="fa fa-exclamation-triangle me-2"/>
                    No active pledges found.
                </div>
            </t>

            <!-- NO SEARCH RESULTS -->
            <t t-if="state.pledges.length and !filteredPledges.length">
                <div class="alert alert-info">
                    <i class="fa fa-search me-2"/>
                    No pledges match your search.
                </div>
            </t>

            <!-- PLEDGE LIST -->
            <div class="pledge-list" t-if="filteredPledges.length" style="max-height: 400px; overflow-y: auto;">
                <t t-foreach="filteredPledges" t-as="pledge" t-key="pledge.id">
                    <div class="card mb-2" style="cursor: pointer; transition: all 0.2s;"
                         t-on-click="() => this.selectPledge(pledge)"
                         onmouseover="this.style.backgroundColor='#f0f0f0'"
                         onmouseout="this.style.backgroundColor='white'">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="card-title mb-1">
                                        <i class="fa fa-handshake-o me-2 text-info"/>
                                        <t t-esc="pledge.name"/>
                                    </h5>
                                    <p class="card-text mb-1">
                                        <i class="fa fa-user me-1 text-muted"/>
                                        <strong><t t-esc="pledge.partner_id[1]"/></strong>
                                    </p>
                                    <t t-if="pledge.employee_name">
                                        <p class="card-text mb-1">
                                            <i class="fa fa-user-tie me-1 text-primary"/>
                                            <strong><t t-esc="pledge.employee_name"/></strong>
                                        </p>
                                    </t>
                                    <small class="text-muted">
                                        <i class="fa fa-tag me-1"/>
                                        <t t-esc="pledge.case_type.toUpperCase()"/>
                                    </small>
                                </div>
                                <div class="text-end">
                                    <h4 class="mb-0 text-success">
                                        <t t-esc="formatCurrency(pledge.pledge_amount)"/>
                                    </h4>
                                    <button class="btn btn-sm btn-primary mt-2">
                                        <i class="fa fa-check me-1"/>
                                        Select
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <!-- FOOTER -->
            <div class="mt-3 text-end">
                <button class="btn btn-secondary" t-on-click="cancel">
                    <i class="fa fa-times me-1"/>
                    Cancel
                </button>
            </div>

        </div>
    </Dialog>
</t>

</templates>
