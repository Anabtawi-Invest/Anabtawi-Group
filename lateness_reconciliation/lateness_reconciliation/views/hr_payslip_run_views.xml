<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Pay Run form: add FINAL enterprise dashboard summary -->
    <record id="view_hr_payslip_run_form_enterprise_dashboard" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.enterprise.dashboard</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">

            <!-- Add button to header (safe spot in Odoo 19) -->
            <xpath expr="//header" position="inside">
                <button name="action_mass_reconcile_lateness_enterprise"
                        type="object"
                        string="Mass Reconcile Lateness"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
            </xpath>

            <!-- Add summary bar under title -->
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="enterprise_lateness_dashboard" style="margin-bottom: 8px;">
                    <button type="action" class="oe_stat_button" icon="fa-clock-o" name="%(hr_payroll.action_payslip_run_payslips)d">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="dashboard_total_lateness"/>
                            </span>
                            <span class="o_stat_text">Total Lateness (h)</span>
                        </div>
                    </button>

                    <button type="button" class="oe_stat_button" icon="fa-plus-circle">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="dashboard_total_overtime"/>
                            </span>
                            <span class="o_stat_text">Total Overtime (h)</span>
                        </div>
                    </button>

                    <button type="button" class="oe_stat_button" icon="fa-exclamation-triangle">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="dashboard_total_remaining"/>
                            </span>
                            <span class="o_stat_text">Total Remaining (h)</span>
                        </div>
                    </button>

                    <button type="button" class="oe_stat_button" icon="fa-percent">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="dashboard_coverage_pct"/>
                            </span>
                            <span class="o_stat_text">Coverage %</span>
                        </div>
                    </button>
                </div>

                <group name="enterprise_lateness_kpis" col="6" style="margin-bottom: 8px;">
                    <field name="dashboard_slips_count" readonly="1"/>
                    <field name="dashboard_slips_with_lateness" readonly="1"/>
                    <field name="dashboard_slips_remaining" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
