<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_hr_payslip_form_inherit_lateness" model="ir.ui.view">
        <field name="name">hr.payslip.form.lateness.reconciliation</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>

        <field name="arch" type="xml">

            <!-- Header Button -->
            <xpath expr="//header" position="inside">
                <button name="action_reconcile_lateness"
                        string="Reconcile Lateness"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft' or lateness_reconciled"/>
            </xpath>

            <!-- Info Block -->
            <xpath expr="//sheet/notebook" position="before">
                <group string="Lateness Reconciliation">
                    <field name="lateness_hours" readonly="1"/>
                    <field name="ot_used" readonly="1"/>
                    <field name="leave_used" readonly="1"/>
                    <field name="unreconciled_lateness" readonly="1"/>
                    <field name="lateness_reconciled" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
