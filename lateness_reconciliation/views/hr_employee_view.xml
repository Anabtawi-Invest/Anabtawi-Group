<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_reconcile" model="ir.ui.view">
        <field name="name">hr.employee.form.reconcile</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="after">
                <group string="Lateness Reconciliation">
                    <field name="ot_hours_bank"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>