<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payslip list: show Lateness / Overtime / Remaining (NO OT Bank) -->
    <record id="view_hr_payslip_tree_lateness_coverage" model="ir.ui.view">
        <field name="name">hr.payslip.tree.lateness.coverage</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//*[self::tree or self::list]" position="inside">
                <field name="lateness_hours" optional="show"/>
                <field name="overtime_hours" optional="show"/>
                <field name="remaining_lateness_hours" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
