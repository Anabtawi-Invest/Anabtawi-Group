<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payslip list: add enterprise dashboard columns -->
    <record id="view_hr_payslip_tree_enterprise_dashboard" model="ir.ui.view">
        <field name="name">hr.payslip.tree.enterprise.dashboard</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//tree" position="attributes">
                <!-- Color entire row when remaining exists -->
                <attribute name="decoration-danger">dashboard_remaining &gt; 0</attribute>
                <attribute name="decoration-warning">dashboard_lateness_hours &gt; 0</attribute>
            </xpath>

            <xpath expr="//tree/field[@name='employee_id']" position="after">

                <field name="dashboard_lateness_hours"
                       string="Lateness"
                       readonly="1"/>

                <field name="dashboard_ot_hours"
                       string="Overtime"
                       readonly="1"
                       decoration-success="dashboard_ot_hours &gt; 0"/>

                <field name="dashboard_ot_bank"
                       string="OT Bank"
                       readonly="1"
                       decoration-success="dashboard_ot_bank &gt; 0"/>

                <field name="dashboard_remaining"
                       string="Remaining"
                       readonly="1"/>

            </xpath>

        </field>
    </record>

</odoo>
