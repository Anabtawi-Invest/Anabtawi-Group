<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_hr_payslip_tree_enterprise_dashboard"
        model="ir.ui.view">
    <field name="name">hr.payslip.tree.enterprise.dashboard</field>
    <field name="model">hr.payslip</field>
    <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
    <field name="arch" type="xml">

        <xpath expr="//*[self::tree or self::list]" position="inside">
            <field name="lateness_hours"/>
            <field name="ot_hours"/>
            
            <field name="remaining"/>
        </xpath>

    </field>
</record>

</odoo>
