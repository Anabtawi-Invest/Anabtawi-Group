<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_hr_payslip_list_enterprise_dashboard"
        model="ir.ui.view">
    <field name="name">hr.payslip.list.enterprise.dashboard</field>
    <field name="model">hr.payslip</field>
    <field name="inherit_id" ref="hr_payroll.view_hr_payslip_list"/>
    <field name="arch" type="xml">

        <xpath expr="//list" position="inside">
            <field name="dashboard_lateness_hours"/>
            <field name="dashboard_ot_hours"/>
            <field name="dashboard_ot_bank"/>
            <field name="dashboard_remaining"/>
        </xpath>

    </field>
</record>

</odoo>
