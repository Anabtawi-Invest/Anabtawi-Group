<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Enterprise Safe List Extension (Odoo 19 Compatible) -->
    <record id="view_hr_payslip_list_enterprise_dashboard"
            model="ir.ui.view">

        <field name="name">hr.payslip.list.enterprise.dashboard</field>
        <field name="model">hr.payslip</field>

        <!-- 🔥 NO XMLID GUESSING -->
        <field name="inherit_id"
               search="[('model','=','hr.payslip'),('type','=','list')]"/>

        <field name="arch" type="xml">

            <xpath expr="//list" position="inside">

                <field name="lateness_hours"/>
                <field name="ot_hours"/>
                <field name="ot_bank"/>
                <field name="late hours remaining"/>

            </xpath>

        </field>

    </record>

</odoo>
