<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_payslip_run_form_inherit_lateness_bulk" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.lateness.bulk</field>
        <field name="model">hr.payslip.run</field>

        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>

        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_bulk_reconcile_lateness"
                        type="object"
                        string="Reconcile Lateness"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>
