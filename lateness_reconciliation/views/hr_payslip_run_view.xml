<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_hr_payslip_run_form_inherit_lateness_bulk"
            model="ir.ui.view">

        <field name="name">hr.payslip.run.form.lateness.bulk</field>
        <field name="model">hr.payslip.run</field>

        <!-- Inherit base Pay Run form -->
        <field name="inherit_id"
               search="[('model','=','hr.payslip.run'), ('type','=','form')]"/>

        <field name="arch" type="xml">

            <!-- Insert button at top of sheet -->
            <xpath expr="//sheet" position="inside">

                <div class="oe_button_box" name="lateness_button_box">
                    <button name="action_bulk_reconcile_lateness"
                            type="object"
                            string="Reconcile Lateness"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                </div>

            </xpath>

        </field>
    </record>

</odoo>
