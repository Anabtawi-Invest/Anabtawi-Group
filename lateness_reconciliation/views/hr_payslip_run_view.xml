<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_run_form_inherit_lateness_bulk"
            model="ir.ui.view">

        <field name="name">hr.payslip.run.form.lateness.bulk</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_run_form"/>
        <field name="arch" type="xml">

            <!-- Insert button inside header (safe in all versions) -->
            <xpath expr="//header" position="inside">

                <button name="action_bulk_reconcile_lateness"
                        type="object"
                        string="Reconcile Lateness"
                        class="btn-primary"
                        invisible="state != 'draft'"/>

            </xpath>

        </field>
    </record>

</odoo>
