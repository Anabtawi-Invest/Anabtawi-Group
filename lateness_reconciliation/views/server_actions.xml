<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action on Payslip Runs (Pay Runs) -->
    <record id="action_server_mass_reconcile_lateness_run" model="ir.actions.server">
        <field name="name">Mass Reconcile Lateness</field>
        <field name="state">code</field>
        <field name="model_id" ref="hr_payroll.model_hr_payslip_run"/>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip_run"/>
        <field name="binding_view_types">form</field>
        <field name="code">
action = records.action_mass_reconcile_lateness_enterprise()
        </field>
    </record>

    <!-- Action on Payslips list (Pay Run Payslips / Payslips) -->
    <record id="action_server_mass_reconcile_lateness_slip" model="ir.actions.server">
        <field name="name">Mass Reconcile Lateness</field>
        <field name="state">code</field>
        <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_view_types">list,form</field>
        <field name="code">
for slip in records:
    slip._lateness_reconcile_for_slip()
action = True
        </field>
    </record>

</odoo>
