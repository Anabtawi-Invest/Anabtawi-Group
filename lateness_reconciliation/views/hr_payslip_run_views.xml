<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_run_form_enterprise_dashboard" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.enterprise.dashboard</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">

            <!-- ✅ Odoo 19 SAFE: do NOT target header/sheet -->
            <xpath expr="//form" position="inside">

                <!-- Button (will appear on top area of the form) -->
                <button name="action_mass_reconcile_lateness_enterprise"
                        type="object"
                        string="Mass Reconcile Lateness"
                        class="btn-primary"
                        invisible="state != 'draft'"/>

                <!-- KPI block (works even if parent form has no <sheet>) -->
                <div class="o_form_sheet" name="enterprise_lateness_kpis" style="margin-top: 8px;">

                    <group col="4">
                        <field name="dashboard_total_lateness" readonly="1"/>
                        <field name="dashboard_total_overtime" readonly="1"/>
                        <field name="dashboard_total_remaining" readonly="1"/>
                        <field name="dashboard_coverage_pct" readonly="1"/>
                    </group>

                </div>

            </xpath>

        </field>
    </record>

</odoo>
