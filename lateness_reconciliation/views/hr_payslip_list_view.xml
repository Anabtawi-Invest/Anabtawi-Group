<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_hr_payslip_list_inherit_lateness" model="ir.ui.view">
    <field name="name">hr.payslip.tree.lateness.reconciliation</field>
    <field name="model">hr.payslip</field>
    <field name="inherit_id" ref="hr_payroll.hr_payslip_view_tree"/>
    <field name="arch" type="xml">
      <xpath expr="//tree" position="attributes">
        <attribute name="create">false</attribute>
      </xpath>
      <xpath expr="//field[@name='employee_id']" position="after">
        <field name="lateness_hours" invisible="1"/>
      </xpath>
    </field>
  </record>
</odoo>
