<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_menu_check_in" inherit_id="portal.portal_my_home" priority="40">
        <!-- Hide all default portal home categories -->
        <xpath expr="//div[@id='portal_alert_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_client_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_service_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_vendor_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>

        <!-- Replace common category with Attendance card only -->
        <xpath expr="//div[@id='portal_common_category']" position="replace">
            <div class="o_portal_category row g-2 mt-3" id="portal_common_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                    <t t-set="title">Attendance</t>
                    <t t-set="text">Check in and check out</t>
                    <t t-set="url" t-value="'/my/check-in'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </div>
        </xpath>
    </template>

    <template id="portal_breadcrumbs_check_in" inherit_id="portal.portal_breadcrumbs">
        <xpath expr="//ol" position="inside">
            <li t-if="page_name == 'my_check_in'" class="breadcrumb-item">Attendance</li>
        </xpath>
    </template>

    <template id="portal_my_check_in" name="Portal Attendance Check In">
        <t t-call="portal.portal_layout">
            <style>
                .pc-check-card {
                    max-width: 420px;
                    margin: 0 auto;
                    border: 0;
                    border-radius: 18px;
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
                }
                .pc-check-head {
                    font-size: 1.9rem;
                    font-weight: 700;
                    line-height: 1.2;
                }
                .pc-check-circle-wrap {
                    display: flex;
                    justify-content: center;
                    margin: 1rem 0 1.5rem;
                }
                .pc-check-circle-btn {
                    width: 170px;
                    height: 170px;
                    border-radius: 50%;
                    border: 0;
                    color: #fff;
                    font-weight: 700;
                    letter-spacing: 0.03em;
                    box-shadow: 0 8px 22px rgba(189, 73, 157, 0.45);
                    background: linear-gradient(145deg, #7e4cd6, #e44789);
                }
                .pc-check-circle-btn i {
                    display: block;
                    font-size: 2rem;
                    margin-bottom: 0.4rem;
                }
                .pc-check-stats {
                    display: grid;
                    grid-template-columns: repeat(3, 1fr);
                    gap: 0.5rem;
                    text-align: center;
                }
                .pc-check-stat-value {
                    font-weight: 700;
                    font-size: 1rem;
                }
                .pc-check-stat-label {
                    color: #6c757d;
                    font-size: 0.78rem;
                }
                .pc-check-history td, .pc-check-history th {
                    font-size: 0.84rem;
                    padding-top: 0.45rem;
                    padding-bottom: 0.45rem;
                }
            </style>
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-12 col-lg-6">
                        <div class="card pc-check-card">
                            <div class="card-body p-4">
                                <div class="text-muted">Hello</div>
                                <div class="pc-check-head mb-2">
                                    <t t-esc="employee.name if employee else request.env.user.name"/>
                                </div>

                                <div t-if="show_success" class="alert alert-success py-2" role="alert">
                                    Attendance updated successfully.
                                </div>
                                <div t-if="show_no_employee or not employee" class="alert alert-warning py-2" role="alert">
                                    Your user is not linked to an employee profile.
                                </div>

                                <t t-if="employee">
                                    <div class="pc-check-circle-wrap">
                                        <form action="/my/check-in/toggle" method="post">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="pc-check-circle-btn">
                                                <i class="fa fa-hand-pointer-o"/>
                                                <t t-if="state == 'checked_in'">CHECK OUT</t>
                                                <t t-else="">CHECK IN</t>
                                            </button>
                                        </form>
                                    </div>

                                    <div class="pc-check-stats mb-3">
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <span t-if="today_check_in"
                                                      t-esc="today_check_in"/>
                                                <span t-else="">-/-</span>
                                            </div>
                                            <div class="pc-check-stat-label">Check In</div>
                                        </div>
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <span t-if="today_check_out"
                                                      t-esc="today_check_out"/>
                                                <span t-else="">-/-</span>
                                            </div>
                                            <div class="pc-check-stat-label">Check Out</div>
                                        </div>
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <t t-esc="hours_today_display"/>
                                            </div>
                                            <div class="pc-check-stat-label">Working Hours</div>
                                        </div>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-sm mb-0 pc-check-history">
                                            <thead>
                                                <tr>
                                                    <th>Check In</th>
                                                    <th>Check Out</th>
                                                    <th>Hours</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="recent_attendances" t-as="att">
                                                    <td>
                                                        <span t-field="att.check_in" t-options='{"format": "HH:mm"}'/>
                                                    </td>
                                                    <td>
                                                        <span t-if="att.check_out" t-field="att.check_out" t-options='{"format": "HH:mm"}'/>
                                                        <span t-else="">-/-</span>
                                                    </td>
                                                    <td>
                                                        <t t-esc="'%0.2f' % (att.worked_hours or 0.0)"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
