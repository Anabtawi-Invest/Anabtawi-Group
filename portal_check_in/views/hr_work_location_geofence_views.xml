<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_work_location_form_view_geofence_coords" model="ir.ui.view">
        <field name="name">hr.work.location.form.geofence.coords</field>
        <field name="model">hr.work.location</field>
        <field name="inherit_id" ref="hr.hr_work_location_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='address_id']" position="after">
                <label for="geo_latitude" string="Coordinates"/>
                <div class="o_row">
                    <field name="geo_latitude" class="oe_inline" nolabel="1"/>
                    <span class="mx-1">,</span>
                    <field name="geo_longitude" class="oe_inline" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
