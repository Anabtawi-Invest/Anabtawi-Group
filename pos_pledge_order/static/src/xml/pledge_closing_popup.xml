<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.ClosePosPopup" t-inherit-mode="extension" owl="1">
        <!-- Same anchor as pos_advance_order: always present (do not depend on payment_amount). -->
        <xpath expr="//PaymentMethodBreakdown[@title.translate='Cash In / Out']" position="before">
            <div
                t-if="shouldShowPledgeCashLine()"
                class="d-flex align-items-center justify-content-between text-muted border-start ps-2">
                <span t-esc="pledgeCashLineLabel()"/>
                <span class="align-top" t-esc="env.utils.formatCurrency(props.default_cash_details.pledge_payment_amount || 0)"/>
            </div>
        </xpath>
        <xpath expr="//span[@t-esc='pm.name']/parent::div" position="after">
            <div
                t-if="shouldShowPledgeBankLine(pm)"
                class="d-flex align-items-center justify-content-between text-muted border-start ps-2">
                <span t-esc="pledgeBankLineLabel(pm)"/>
                <span class="align-top" t-esc="env.utils.formatCurrency(pm.pledge_payment_amount || 0)"/>
            </div>
        </xpath>
    </t>
</templates>
