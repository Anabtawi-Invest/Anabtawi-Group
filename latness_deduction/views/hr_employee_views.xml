<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_lateness_annual_leave_balance" model="ir.ui.view">
        <field name="name">hr.employee.form.lateness.annual.leave</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']/group[@name='settings_group']" position="inside">
                <group string="Lateness Coverage" name="lateness_coverage_group" groups="hr.group_hr_user">
                    <field name="annual_leave_balance_hours" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
