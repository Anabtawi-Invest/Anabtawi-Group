<odoo>
    <!-- Payslip form: show lateness fields under Other Info -->
    <record id="hr_payslip_view_form_lateness_action_button" model="ir.ui.view">
        <field name="name">hr.payslip.form.lateness.action.button</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button
                    name="action_reconcile_lateness_no_ot_bank"
                    type="object"
                    string="Reconcile Lateness"
                    class="btn-secondary"
                    invisible="state != 'draft' or lateness_reconciled"/>
                <button
                    name="action_reset_lateness_reconciliation"
                    type="object"
                    string="Reset Reconciliation"
                    class="btn-secondary"
                    invisible="state != 'draft' or not lateness_reconciled"/>
            </xpath>
        </field>
    </record>

    <record id="hr_payslip_view_tree_lateness_columns" model="ir.ui.view">
        <field name="name">hr.payslip.tree.lateness.columns</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='account_info']/group" position="inside">
                <group string="Lateness Summary">
                    <field name="lateness_reconciled" invisible="1"/>
                    <field name="annual_leave_hours_before" readonly="1"/>
                    <field name="ot_balance_before" readonly="1"/>
                    <field name="lateness_before" readonly="1"/>
                    <field name="annual_leave_hours_after" readonly="1"/>
                    <field name="ot_balance_after" readonly="1"/>
                    <field name="lateness_after" readonly="1"/>
                    <field name="annual_leave_balance_hours" readonly="1" string="Annual Leave Hours" invisible="1"/>
                    <field name="ot_wallet_total_before_deduction_equiv" readonly="1" invisible="1"/>
                    <field name="overtime_equivalent_hours" readonly="1" invisible="1"/>
                    <field name="lateness_hours" readonly="1" invisible="1"/>
                    <field name="ot_wallet_consumed_equiv" readonly="1" string="Over Time Hours" invisible="1"/>
                    <field name="overtime_hours" readonly="1" invisible="1"/>
                    <field name="ot_wallet_carry_in_equiv" readonly="1" invisible="1"/>
                    <field name="ot_wallet_earned_equiv" readonly="1" invisible="1"/>
                    <field name="ot_wallet_carry_out_equiv" readonly="1" invisible="1"/>
                    <field name="remaining_lateness_hours" readonly="1" invisible="1"/>
                    <field name="remaining_annual_leave_balance_hours" readonly="1" string="Remaining Annual Leave Hours" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
