<odoo>
  <record id="res_config_settings_view_form_lateness_coverage" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.lateness.coverage</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="hr_payroll.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//app[@name='hr_payroll']" position="inside">
        <block title="Lateness Coverage" id="lateness_coverage_settings">
          <setting string="Annual Leave Type for Lateness"
                   help="Select the hour-based leave type used to cover remaining lateness after consuming overtime buckets.">
            <field name="annual_leave_type_id"/>
          </setting>
        </block>
      </xpath>
    </field>
  </record>
</odoo>