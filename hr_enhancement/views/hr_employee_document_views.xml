<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_ae_documents_form" model="ir.ui.view">
        <field name="name">hr.employee.form.ae.documents</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="ae_documents" string="Employee documents" groups="hr.group_hr_user">
                    <field name="ae_document_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="document_type_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="document_file" filename="document_filename"/>
                            <field name="document_filename" column_invisible="1"/>
                            <field name="expiry_date"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
