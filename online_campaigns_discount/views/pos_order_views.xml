<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_order_form_online_campaign" model="ir.ui.view">
        <field name="name">pos.order.form.online.campaign</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lines']/list/field[@name='discount']" position="after">
                <field name="online_campaign_id" optional="show" readonly="1"/>
                <field name="online_aggregator_id" optional="show" readonly="1"/>
                <field name="online_discount_amount" optional="show" readonly="1" widget="monetary"/>
                <field name="aggregator_contribution_amount" optional="hide" readonly="1" widget="monetary"/>
                <field name="company_contribution_amount" optional="hide" readonly="1" widget="monetary"/>
                <field name="aggregator_commission_amount" optional="hide" readonly="1" widget="monetary"/>
            </xpath>
            <xpath expr="//group[@name='order_total']/field[@name='amount_tax']" position="before">
                <field name="amount_before_online_discount" widget="monetary" readonly="1"/>
                <field name="online_discount_total" widget="monetary" readonly="1"/>
                <field name="aggregator_contribution_total" widget="monetary" readonly="1"/>
                <field name="company_contribution_total" widget="monetary" readonly="1"/>
                <field name="aggregator_commission_total" widget="monetary" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_online_campaign_discount_report_list" model="ir.ui.view">
        <field name="name">pos.order.line.online.campaign.report.list</field>
        <field name="model">pos.order.line</field>
        <field name="arch" type="xml">
            <list string="Online Campaign Results" create="0" edit="0" delete="0" default_order="online_order_date desc">
                <field name="online_order_date" string="Date"/>
                <field name="online_aggregator_id" string="Aggregator"/>
                <field name="online_campaign_id" string="Campaign"/>
                <field name="order_id" string="Order"/>
                <field name="product_id"/>
                <field name="online_gross_amount" string="Gross" widget="monetary" sum="Gross"/>
                <field name="online_discount_amount" string="Discount" widget="monetary" sum="Discount"/>
                <field name="aggregator_contribution_amount" string="Aggregator Contribution" widget="monetary" sum="Aggregator"/>
                <field name="company_contribution_amount" string="Company Contribution" widget="monetary" sum="Company"/>
                <field name="aggregator_commission_amount" string="Estimated Commission" widget="monetary" sum="Commission"/>
                <field name="online_customer_paid_amount" string="Customer Paid" widget="monetary" sum="Customer Paid"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="online_session_id" string="POS Session"/>
                <field name="online_cashier_id" string="Cashier"/>
            </list>
        </field>
    </record>

    <record id="view_online_campaign_discount_report_search" model="ir.ui.view">
        <field name="name">pos.order.line.online.campaign.report.search</field>
        <field name="model">pos.order.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="online_aggregator_id"/>
                <field name="online_campaign_id"/>
                <field name="order_id"/>
                <field name="product_id"/>
                <field name="online_session_id"/>
                <filter name="group_aggregator" string="Aggregator" context="{'group_by': 'online_aggregator_id'}"/>
                <filter name="group_campaign" string="Campaign" context="{'group_by': 'online_campaign_id'}"/>
                <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                <filter name="group_session" string="POS Session" context="{'group_by': 'online_session_id'}"/>
                <filter name="group_date" string="Date" context="{'group_by': 'online_order_date:day'}"/>
            </search>
        </field>
    </record>

    <record id="action_online_campaign_discount_report" model="ir.actions.act_window">
        <field name="name">Campaign Results</field>
        <field name="res_model">pos.order.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_online_campaign_discount_report_list"/>
        <field name="search_view_id" ref="view_online_campaign_discount_report_search"/>
        <field name="domain">[('online_campaign_id', '!=', False)]</field>
    </record>
</odoo>
