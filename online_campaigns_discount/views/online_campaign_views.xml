<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_online_campaign_aggregator_list" model="ir.ui.view">
        <field name="name">online.campaign.aggregator.list</field>
        <field name="model">online.campaign.aggregator</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="name"/>
                <field name="default_commission_percent" string="Default Commission %"/>
                <field name="partner_id" optional="show"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="receivable_account_id" optional="show" groups="online_campaigns_discount.group_online_campaign_finance_manager,account.group_account_manager"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_online_campaign_aggregator_form" model="ir.ui.view">
        <field name="name">online.campaign.aggregator.form</field>
        <field name="model">online.campaign.aggregator</field>
        <field name="arch" type="xml">
            <form string="Online Aggregator">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Talabat, Careem, MyThings"/></h1>
                    </div>
                    <group>
                        <group string="Commercial Setup">
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="partner_id" domain="[('company_id', 'in', [False, company_id])]"/>
                            <field name="default_commission_percent"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group string="Accounting" groups="online_campaigns_discount.group_online_campaign_finance_manager,account.group_account_manager">
                            <field name="receivable_account_id" options="{'no_create': True}"/>
                            <field name="discount_expense_account_id" options="{'no_create': True}"/>
                            <field name="commission_expense_account_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Internal Notes">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_online_campaign_aggregators" model="ir.actions.act_window">
        <field name="name">Aggregators</field>
        <field name="res_model">online.campaign.aggregator</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_online_discount_campaign_list" model="ir.ui.view">
        <field name="name">online.discount.campaign.list</field>
        <field name="model">online.discount.campaign</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'approved'" decoration-warning="state == 'pending'"
                  decoration-danger="state == 'rejected'" decoration-muted="state == 'cancelled' or not active"
                  default_order="start_datetime desc, priority">
                <field name="name"/>
                <field name="aggregator_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="discount_percent" string="Discount %"/>
                <field name="discount_cap_amount" widget="monetary"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="aggregator_commission_percent" string="Commission %" optional="show"/>
                <field name="ecommerce_approved" optional="show"/>
                <field name="finance_approved" optional="show"/>
                <field name="state" widget="badge"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_online_discount_campaign_calendar" model="ir.ui.view">
        <field name="name">online.discount.campaign.calendar</field>
        <field name="model">online.discount.campaign</field>
        <field name="arch" type="xml">
            <calendar string="Online Campaign Calendar" date_start="start_datetime" date_stop="end_datetime"
                      color="aggregator_id" mode="month" quick_create="0" event_open_popup="1">
                <field name="name"/>
                <field name="aggregator_id"/>
                <field name="discount_percent"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_online_discount_campaign_form" model="ir.ui.view">
        <field name="name">online.discount.campaign.form</field>
        <field name="model">online.discount.campaign</field>
        <field name="arch" type="xml">
            <form string="Online Campaign">
                <header>
                    <button name="action_submit" type="object" string="Submit for Approval" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_ecommerce_approve" type="object" string="E-commerce Approve" class="btn-primary"
                            groups="online_campaigns_discount.group_online_campaign_ecommerce_manager"
                            invisible="state != 'pending' or ecommerce_approved"/>
                    <button name="action_finance_approve" type="object" string="Finance Approve" class="btn-primary"
                            groups="online_campaigns_discount.group_online_campaign_finance_manager"
                            invisible="state != 'pending' or finance_approved"/>
                    <button name="action_reject" type="object" string="Reject"
                            groups="online_campaigns_discount.group_online_campaign_approver"
                            invisible="state != 'pending'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('cancelled', 'approved')"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            groups="online_campaigns_discount.group_online_campaign_approver"
                            invisible="state not in ('approved', 'rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Talabat July 50% Campaign"/></h1>
                    </div>
                    <group>
                        <group string="Schedule and Channel">
                            <field name="company_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="currency_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="aggregator_id" domain="[('company_id', '=', company_id)]" readonly="state != 'draft'"/>
                            <field name="start_datetime" readonly="state != 'draft'"/>
                            <field name="end_datetime" readonly="state != 'draft'"/>
                            <field name="pos_config_ids" widget="many2many_tags" domain="[('company_id', '=', company_id)]" readonly="state != 'draft'"/>
                            <field name="pricelist_ids" widget="many2many_tags" domain="[('currency_id', '=', currency_id)]" readonly="state != 'draft'"/>
                        </group>
                        <group string="Commercial Terms">
                            <field name="discount_type" readonly="state != 'draft'"/>
                            <field name="discount_percent" readonly="state != 'draft'"/>
                            <field name="discount_cap_amount" widget="monetary" readonly="state != 'draft'"/>
                            <field name="cap_application" readonly="state != 'draft'"/>
                            <field name="aggregator_commission_percent" readonly="state != 'draft'"/>
                            <field name="aggregator_contribution_percent" readonly="state != 'draft'"/>
                            <field name="company_contribution_percent" readonly="state != 'draft'"/>
                            <field name="priority" readonly="state != 'draft'"/>
                            <field name="allow_stacking" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Eligible Products">
                        <field name="apply_scope" widget="radio" options="{'horizontal': True}" readonly="state != 'draft'"/>
                        <field name="product_ids" widget="many2many_tags" invisible="apply_scope != 'specific_products'" readonly="state != 'draft'"/>
                        <field name="category_ids" widget="many2many_tags" invisible="apply_scope != 'specific_categories'" readonly="state != 'draft'"/>
                    </group>
                    <group string="Required Approvals">
                        <group>
                            <field name="ecommerce_approved"/>
                            <field name="ecommerce_approved_by" invisible="not ecommerce_approved"/>
                            <field name="ecommerce_approved_at" invisible="not ecommerce_approved"/>
                        </group>
                        <group>
                            <field name="finance_approved"/>
                            <field name="finance_approved_by" invisible="not finance_approved"/>
                            <field name="finance_approved_at" invisible="not finance_approved"/>
                        </group>
                    </group>
                    <group string="Rejection and Internal Notes">
                        <field name="rejection_reason" placeholder="Required operational explanation when a campaign is rejected."/>
                        <field name="note"/>
                    </group>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_online_discount_campaign_search" model="ir.ui.view">
        <field name="name">online.discount.campaign.search</field>
        <field name="model">online.discount.campaign</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="aggregator_id"/>
                <field name="pricelist_ids"/>
                <field name="pos_config_ids"/>
                <filter name="waiting" string="Waiting for Approval" domain="[('state', '=', 'pending')]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="active_now" string="Active Now" domain="[('state', '=', 'approved'), ('start_datetime', '&lt;=', context_today()), ('end_datetime', '&gt;=', context_today())]"/>
                <separator/>
                <filter name="group_aggregator" string="Aggregator" context="{'group_by': 'aggregator_id'}"/>
                <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                <filter name="group_start" string="Start Month" context="{'group_by': 'start_datetime:month'}"/>
                <filter name="group_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
            </search>
        </field>
    </record>

    <record id="action_online_discount_campaigns" model="ir.actions.act_window">
        <field name="name">Online Campaigns</field>
        <field name="res_model">online.discount.campaign</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_online_discount_campaign_search"/>
    </record>
    <record id="action_online_discount_campaign_calendar" model="ir.actions.act_window">
        <field name="name">Campaign Calendar</field>
        <field name="res_model">online.discount.campaign</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="view_id" ref="view_online_discount_campaign_calendar"/>
        <field name="search_view_id" ref="view_online_discount_campaign_search"/>
    </record>
</odoo>
