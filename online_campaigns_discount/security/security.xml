<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_online_campaign_approver" model="res.groups">
        <field name="name">Online Campaign Approver</field>
        <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
    </record>
    <record id="group_online_campaign_ecommerce_manager" model="res.groups">
        <field name="name">Online Campaign E-commerce Manager</field>
        <field name="implied_ids" eval="[Command.link(ref('group_online_campaign_approver'))]"/>
    </record>
    <record id="group_online_campaign_finance_manager" model="res.groups">
        <field name="name">Online Campaign Finance Manager</field>
        <field name="implied_ids" eval="[Command.link(ref('group_online_campaign_approver')), Command.link(ref('account.group_account_manager'))]"/>
    </record>

    <record id="rule_online_campaign_multi_company" model="ir.rule">
        <field name="name">Online campaigns: allowed companies</field>
        <field name="model_id" ref="model_online_discount_campaign"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_online_aggregator_multi_company" model="ir.rule">
        <field name="name">Online aggregators: allowed companies</field>
        <field name="model_id" ref="model_online_campaign_aggregator"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_online_campaign_performance_multi_company" model="ir.rule">
        <field name="name">Campaign profitability: allowed companies</field>
        <field name="model_id" ref="model_online_campaign_performance_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_online_campaign_settlement_multi_company" model="ir.rule">
        <field name="name">Aggregator settlements: allowed companies</field>
        <field name="model_id" ref="model_online_campaign_settlement"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
