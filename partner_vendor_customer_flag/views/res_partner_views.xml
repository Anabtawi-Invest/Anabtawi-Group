<odoo>
    <record id="view_partner_form_vendor_customer_flags" model="ir.ui.view">
        <field name="name">res.partner.form.vendor.customer.flags</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Place the flags after Tags -->
            <xpath expr="//field[@name='category_id']" position="after">
                <group string="Accounting Classification" col="2">
                    <field name="x_is_vendor"/>
                    <field name="x_is_customer"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
