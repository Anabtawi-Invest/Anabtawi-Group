<odoo>
    <record id="view_move_form_partner_domain_vendor_customer_flags" model="ir.ui.view">
        <field name="name">account.move.form.partner.domain.vendor.customer.flags</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Replace domain on partner_id depending on move_type -->
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <!-- This domain is evaluated client-side -->
                <attribute name="domain">
                    [
                      '|','|',
                      '&amp;',('move_type','in',('in_invoice','in_refund','in_receipt')),('x_is_vendor','=',True),
                      '&amp;',('move_type','in',('out_invoice','out_refund','out_receipt')),('x_is_customer','=',True),
                      ('id','!=',0)
                    ]
                </attribute>
            </xpath>
        </field>
    </record>
</odoo>
