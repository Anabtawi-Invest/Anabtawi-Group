<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inject Google Fonts into Layout Head -->
    <template id="layout_head_fonts_sweets" inherit_id="website.layout" name="Anabtawi Sweets Fonts">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link href="https://fonts.googleapis.com/css2?family=Anton&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>

    <!-- Custom Header Top Bar Injection -->
    <template id="custom_header_top_bar" inherit_id="website.layout" name="Anabtawi Top Bar">
        <xpath expr="//header" position="before">
            <div class="top-bar anabtawi-theme d-none d-lg-block">
                <div class="container-fluid px-5">
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <i class="fa fa-phone me-2"></i><a href="tel:+962797121121">+962 7 97121121</a>
                        </div>
                        <div class="col-md-3">
                            <i class="fa fa-envelope me-2"></i><a href="mailto:info@anabtawisweets.com">info@anabtawisweets.com</a>
                        </div>
                        <div class="col-md-6 text-end">
                            <i class="fa fa-map-marker me-2"></i><a href="http://maps.app.goo.gl/n7EoosVvue4RFytp8" target="_blank">Anabtawi Sweets - Al madina Al Monawara St. - Amman - Jordan</a>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Custom Home Page Template -->
    <template id="home_page_template_sweets" name="Anabtawi Sweets Home" track="1">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty anabtawi-theme">
                <!-- Hero Section -->
                <section class="anabtawi-hero-section d-flex align-items-center justify-content-center text-center">
                    <div class="hero-overlay"></div>
                    <div class="container hero-content py-5">
                        <h1 class="mb-4">Welcome to Anabtawi Sweets</h1>
                        <p class="lead mb-5">Since 1983, a symbol of excellence in Arabic and Western sweets.</p>
                        <a href="/shop" class="btn btn-gold btn-lg px-4 py-2">Order Now</a>
                    </div>
                </section>

                <!-- Featured Categories Section -->
                <section class="py-5 bg-light">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="text-uppercase" style="color: #122e44; font-family: 'Anton', sans-serif;">Our Specialties</h2>
                            <hr style="width: 50px; border-top: 3px solid #c89211; margin: 20px auto; opacity: 1;"/>
                        </div>
                        <div class="row g-4 text-center">
                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <!-- Using placeholder image for now -->
                                    <img src="/web/static/img/placeholder.png" class="card-img-top" alt="Arabic Sweets"/>
                                    <div class="card-body">
                                        <h4 class="card-title" style="color: #122e44;">Arabic Sweets</h4>
                                        <p class="card-text text-muted">Authentic traditional recipes.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <img src="/web/static/img/placeholder.png" class="card-img-top" alt="Cakes"/>
                                    <div class="card-body">
                                        <h4 class="card-title" style="color: #122e44;">Cakes</h4>
                                        <p class="card-text text-muted">Custom made for your special occasions.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm h-100">
                                    <img src="/web/static/img/placeholder.png" class="card-img-top" alt="Chocolates"/>
                                    <div class="card-body">
                                        <h4 class="card-title" style="color: #122e44;">Chocolates</h4>
                                        <p class="card-text text-muted">Premium chocolates and dates.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- About Section -->
                <section class="py-5">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <h2 class="text-uppercase mb-4" style="color: #122e44; font-family: 'Anton', sans-serif;">Our Legacy</h2>
                                <p class="lead text-muted">
                                    Established in 1983, Anabtawi Sweets Company has grown to become a symbol of excellence in the Arabic and Western sweets industry.
                                </p>
                                <p class="text-muted">
                                    With our commitment to high quality ingredients and authentic recipes, we ensure that every bite brings joy to your occasions.
                                </p>
                                <a href="/aboutus" class="btn btn-gold mt-3">Read More</a>
                            </div>
                            <div class="col-md-6 text-center mt-4 mt-md-0">
                                <img src="/web/static/img/placeholder.png" class="img-fluid rounded shadow-sm" alt="About Anabtawi" style="max-height: 400px;"/>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- Custom Footer Refactoring -->
    <template id="custom_footer_sweets" inherit_id="website.layout" name="Anabtawi Sweets Custom Footer" priority="50">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="oe_structure text-break anabtawi-theme anabtawi-custom-footer" t-ignore="true" t-if="not no_footer">
                <section class="pt-5 pb-3">
                    <div class="container">
                        <div class="row g-4">
                            <!-- Column 1: Useful Links -->
                            <div class="col-md-4">
                                <h5 class="mb-4">Useful Links</h5>
                                <ul class="list-unstyled">
                                    <li class="mb-2"><a href="/">Home</a></li>
                                    <li class="mb-2"><a href="/aboutus">About Us</a></li>
                                    <li class="mb-2"><a href="/shop">Products</a></li>
                                    <li class="mb-2"><a href="/contactus">Contact Us</a></li>
                                </ul>
                            </div>
                            <!-- Column 2: Address -->
                            <div class="col-md-4">
                                <h5 class="mb-4">Find Us</h5>
                                <p class="lh-lg">
                                    Anabtawi Sweets<br/>
                                    Al Madina Al Monawara St.<br/>
                                    Amman - Jordan
                                </p>
                            </div>
                            <!-- Column 3: Connect -->
                            <div class="col-md-4">
                                <h5 class="mb-4">Connect With Us</h5>
                                <ul class="list-unstyled mb-4">
                                    <li class="mb-2">
                                        <a href="mailto:info@anabtawisweets.com"><i class="fa fa-envelope me-2 text-warning"></i>info@anabtawisweets.com</a>
                                    </li>
                                    <li class="mb-2">
                                        <a href="tel:+962797121121"><i class="fa fa-phone me-2 text-warning"></i>+962 7 97121121</a>
                                    </li>
                                </ul>
                                <div class="social-icons">
                                    <a href="https://facebook.com/anabtawisweets" target="_blank"><i class="fa fa-facebook"></i></a>
                                    <a href="https://twitter.com/Anabtawi_Sweets" target="_blank"><i class="fa fa-twitter"></i></a>
                                    <a href="https://instagram.com/anabtawisweets" target="_blank"><i class="fa fa-instagram"></i></a>
                                </div>
                            </div>
                        </div>
                        <hr class="border-secondary my-4 opacity-25"/>
                        <div class="text-center">
                            <p class="mb-0 font-size-sm">Copyright &amp;copy; 2026 Anabtawi Sweets. All rights reserved.</p>
                        </div>
                    </div>
                </section>
            </div>
        </xpath>

        <!-- Eliminate Odoo's default footer copyright -->
        <xpath expr="//div[hasclass('o_footer_copyright')]" position="replace">
        </xpath>
    </template>
</odoo>
