<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_groups_form_membership_log" model="ir.ui.view">
        <field name="name">res.groups.form.membership.log</field>
        <field name="model">res.groups</field>
        <field name="inherit_id" ref="base.view_groups_form"/>
        <field name="arch" type="xml">
            <field name="share" position="after">
                <field name="membership_log_enabled" groups="base.group_system"/>
            </field>
        </field>
    </record>

    <record id="view_groups_list_membership_log" model="ir.ui.view">
        <field name="name">res.groups.list.membership.log</field>
        <field name="model">res.groups</field>
        <field name="inherit_id" ref="base.view_groups_list"/>
        <field name="arch" type="xml">
            <field name="comment" position="after">
                <field name="membership_log_enabled" optional="hide" groups="base.group_system"/>
            </field>
        </field>
    </record>

</odoo>
