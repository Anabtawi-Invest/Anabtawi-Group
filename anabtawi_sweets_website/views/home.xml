<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="homepage" inherit_id="website.homepage" name="Anabtawi Sweets - Homepage" active="True" priority="50">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure anabtawi-theme">
                <t t-call="anabtawi_sweets_website.s_anabtawi_hero"/>

                <section class="anabtawi-video-section py-5" data-name="Brand film" data-snippet="s_text_image">
                    <div class="container py-4">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-5">
                                <span class="anabtawi-eyebrow">Made with passion</span>
                                <h2 class="display-5 mt-2 mb-4">A tradition you can taste</h2>
                                <p class="lead mb-4">
                                    From classic kunafeh and warbat to chocolates, cakes, coffee, and honey, every collection reflects our commitment to quality.
                                </p>
                                <a href="/aboutus" class="btn btn-outline-light">Discover our story</a>
                            </div>
                            <div class="col-lg-7">
                                <div class="ratio ratio-16x9 rounded overflow-hidden shadow-lg">
                                    <iframe src="https://www.youtube-nocookie.com/embed/VORKhyJTVZM?rel=0&amp;modestbranding=1" title="Anabtawi Sweets brand film" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen="allowfullscreen"></iframe>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <t t-call="anabtawi_sweets_website.s_anabtawi_categories"/>

                <section class="anabtawi-news py-5" data-name="Latest news" data-snippet="s_three_columns">
                    <div class="container py-4">
                        <div class="text-center mb-5">
                            <span class="anabtawi-eyebrow">Latest news</span>
                            <h2 class="display-5 mt-2">From the Anabtawi family</h2>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-4">
                                <article class="anabtawi-news-card h-100">
                                    <img src="/anabtawi_sweets_website/static/src/img/content/news-youth-growth.png" alt="Youth for Growth initiative" class="img-fluid" loading="lazy"/>
                                    <div class="p-4">
                                        <span class="anabtawi-eyebrow">Community</span>
                                        <h3 class="h5 mt-2">Youth for Growth</h3>
                                        <p class="mb-0">Supporting the next generation through opportunity, skills, and community partnership.</p>
                                    </div>
                                </article>
                            </div>
                            <div class="col-md-4">
                                <article class="anabtawi-news-card h-100">
                                    <img src="/anabtawi_sweets_website/static/src/img/content/news-sial-canada.png" alt="Anabtawi Sweets at SIAL Canada" class="img-fluid" loading="lazy"/>
                                    <div class="p-4">
                                        <span class="anabtawi-eyebrow">Events</span>
                                        <h3 class="h5 mt-2">SIAL Canada</h3>
                                        <p class="mb-0">Sharing authentic Jordanian confectionery with partners and food professionals worldwide.</p>
                                    </div>
                                </article>
                            </div>
                            <div class="col-md-4">
                                <article class="anabtawi-news-card h-100">
                                    <img src="/anabtawi_sweets_website/static/src/img/content/news-ramadan-iftar.png" alt="Anabtawi Ramadan iftar" class="img-fluid" loading="lazy"/>
                                    <div class="p-4">
                                        <span class="anabtawi-eyebrow">Anabtawi family</span>
                                        <h3 class="h5 mt-2">Ramadan Iftar</h3>
                                        <p class="mb-0">Celebrating generosity, togetherness, and the traditions that bring our community closer.</p>
                                    </div>
                                </article>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="anabtawi-partner py-5 text-center" data-name="Become a partner" data-snippet="s_call_to_action">
                    <div class="container py-5">
                        <img src="/anabtawi_sweets_website/static/src/img/content/logo.png" alt="Anabtawi Sweets" class="anabtawi-partner-logo mb-4" loading="lazy"/>
                        <h2 class="display-5 mb-3">Grow with Anabtawi Sweets</h2>
                        <p class="lead mx-auto mb-4">Connect with our team to discuss distribution, partnerships, events, and corporate orders.</p>
                        <a href="/contactus" class="btn btn-primary btn-lg">Become a partner</a>
                    </div>
                </section>
            </div>
        </xpath>
    </template>
</odoo>
