<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="page_catalog" model="website.page">
        <field name="name">Anabtawi Product Catalog</field>
        <field name="is_published" eval="True"/>
        <field name="key">anabtawi_sweets_website.page_catalog</field>
        <field name="url">/our-catalog</field>
        <field name="website_id" ref="website.default_website"/>
        <field name="type">qweb</field>
        <field name="arch" type="xml">
            <t t-name="anabtawi_sweets_website.page_catalog">
                <t t-call="website.layout">
                    <div id="wrap" class="oe_structure anabtawi-theme">
                        <section class="anabtawi-page-hero py-5" data-name="Catalog title" data-snippet="s_title">
                            <div class="container py-4 text-center">
                                <span class="anabtawi-eyebrow">Our specialties</span>
                                <h1 class="display-4 mt-2 mb-3">Product catalog</h1>
                                <p class="lead mx-auto mb-0">Explore the signature categories prepared across the Anabtawi Sweets collection.</p>
                            </div>
                        </section>

                        <section class="anabtawi-section py-5" data-name="Catalog categories" data-snippet="s_three_columns">
                            <div class="container py-4">
                                <div class="row g-4">
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-kunafeh.png" alt="Kunafeh and Warbat" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Kunafeh and Warbat</h2><p>Classic kunafeh, cheese-filled specialties, and crisp warbat.</p><a href="/contactus?subject=Kunafeh%20and%20Warbat" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-assorted.png" alt="Assorted Sweets" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Assorted Sweets</h2><p>Gift-ready selections of favorite Arabic sweets and pastries.</p><a href="/contactus?subject=Assorted%20Sweets" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-cakes.png" alt="Cakes and Western Sweets" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Cakes and Western Sweets</h2><p>Cakes, desserts, and celebration pieces for every occasion.</p><a href="/contactus?subject=Cakes%20and%20Western%20Sweets" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-mediterranean.png" alt="Mediterranean Sweets" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Mediterranean Sweets</h2><p>Regional recipes shaped by Mediterranean flavors and hospitality.</p><a href="/contactus?subject=Mediterranean%20Sweets" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-chocolate.png" alt="Anabtawi Chocolates and Gifts" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Chocolates and Gifts</h2><p>Premium chocolate assortments and elegant gifting collections.</p><a href="/contactus?subject=Chocolates%20and%20Gifts" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-coffee.png" alt="Anabtawi Coffee" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Coffee</h2><p>Carefully roasted coffee blends made to complement every sweet.</p><a href="/contactus?subject=Anabtawi%20Coffee" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-honey.png" alt="Tryaq Honey Anabtawi Apiaries" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Tryaq Honey</h2><p>Natural honey from Anabtawi Apiaries in distinctive varieties.</p><a href="/contactus?subject=Tryaq%20Honey" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                    <div class="col-sm-6 col-lg-3">
                                        <article class="anabtawi-catalog-card h-100">
                                            <img src="/anabtawi_sweets_website/static/src/img/content/category-maamoul.png" alt="Maamoul and Cookies" class="img-fluid" loading="lazy"/>
                                            <div class="p-4"><h2 class="h5">Maamoul and Cookies</h2><p>Traditional maamoul and baked cookies with generous fillings.</p><a href="/contactus?subject=Maamoul%20and%20Cookies" class="btn btn-sm btn-primary">Enquire</a></div>
                                        </article>
                                    </div>
                                </div>
                                <div class="anabtawi-catalog-note mt-5 p-4 p-lg-5 text-center">
                                    <h2 class="h3">Looking for availability or corporate gifting?</h2>
                                    <p class="mb-4">Collections and availability may vary by branch. Our team can help with current products, event orders, and partnership enquiries.</p>
                                    <a href="/contactus" class="btn btn-outline-secondary">Contact our team</a>
                                </div>
                            </div>
                        </section>
                    </div>
                </t>
            </t>
        </field>
    </record>
</odoo>
