<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cake_config_form" model="ir.ui.view">
        <field name="name">cake.config.form</field>
        <field name="model">cake.config</field>
        <field name="arch" type="xml">
            <form string="Custom Cake Settings | إعدادات الجاتو المخصص">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group string="Pricing | التسعير">
                        <field name="markup_pct"
                               help="Selling price = Total cost × (1 + markup%). Default 642% → ×7.42 matches Excel basic sales/cost ratio."/>
                        <field name="markup_multiplier" readonly="1"/>
                        <field name="pos_product_id"/>
                    </group>
                    <group string="Email | البريد الإلكتروني">
                        <field name="manufacturing_email"/>
                        <field name="email_subject_template"/>
                        <field name="auto_send_email"/>
                    </group>
                    <group string="POS Features | ميزات نقطة البيع">
                        <field name="enable_extra_features"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cake_config" model="ir.actions.act_window">
        <field name="name">Settings | الإعدادات</field>
        <field name="res_model">cake.config</field>
        <field name="view_mode">form</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         TOP-LEVEL MENU
    ═══════════════════════════════════════════════════════════ -->
    <menuitem id="menu_cake_root"
              name="🎂 Custom Cake | جاتو مخصص"
              sequence="85"/>

    <menuitem id="menu_cake_orders"
              name="Orders | الطلبات"
              parent="menu_cake_root"
              action="cake_order_views.action_cake_order"
              sequence="10"/>

    <menuitem id="menu_cake_ingredients"
              name="Ingredients &amp; Costs | المكونات"
              parent="menu_cake_root"
              action="action_cake_ingredient"
              sequence="20"/>

    <menuitem id="menu_cake_extra_features"
              name="Extra Features | الميزات الإضافية"
              parent="menu_cake_root"
              action="action_cake_extra_feature"
              sequence="30"/>

    <menuitem id="menu_cake_config"
              name="Settings | الإعدادات"
              parent="menu_cake_root"
              action="action_cake_config"
              sequence="40"
              groups="base.group_system"/>

</odoo>
