<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

  <!--
    Inject the Custom Cake button into POS ProductScreen.
    Uses t-inherit-mode="extension" — correct for Odoo 17+
  -->
  <t t-name="cake_pos.ProductScreenPatch"
     t-inherit="point_of_sale.ProductScreen"
     t-inherit-mode="extension">
    <xpath expr="//div[hasclass('control-buttons')]" position="inside">
      <button class="cake-pos-btn control-button"
              t-on-click="openCustomCakePopup">
        🎂 جاتو مخصص
      </button>
    </xpath>
  </t>

</templates>
