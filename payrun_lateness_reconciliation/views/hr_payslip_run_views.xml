<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_run_form_inherit_lateness" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.lateness.button</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_open_lateness_preview"
                        type="object"
                        string="Reconcile Lateness"
                        class="btn btn-primary"
                        modifiers="{'invisible': ['|', ['id', '=', false], ['slip_ids', '=', false]]}"/>
            </xpath>

        </field>
    </record>
</odoo>
