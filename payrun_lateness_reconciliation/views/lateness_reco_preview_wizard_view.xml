<odoo>
    <record id="view_lateness_preview_wizard_form" model="ir.ui.view">
        <field name="name">lateness.preview.wizard.form</field>
        <field name="model">lateness.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Preview Lateness Reconciliation">
                <group>
                    <field name="payrun_id" readonly="1"/>
                    <field name="preview_results" readonly="1" widget="text"/>
                </group>
                <footer>
                    <button name="action_preview" type="object" string="Refresh Preview" class="btn-secondary"/>
                    <button name="action_apply" type="object" string="Apply Reconciliation" class="btn-primary"/>
                    <button string="Cancel" class="btn-link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>