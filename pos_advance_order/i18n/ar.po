#. module: pos_advance_order
msgid "Advance amount cannot be negative."
msgstr "لا يمكن أن يكون مبلغ العربون سالبًا."

#. module: pos_advance_order
msgid "Advance amount cannot be greater than the total."
msgstr "لا يمكن أن يكون مبلغ العربون أكبر من الإجمالي."

#. module: pos_advance_order
msgid "Please set 'POS Advance Account' on the POS configuration first."
msgstr "يرجى تحديد 'حساب عربون نقطة البيع' في إعدادات نقطة البيع أولاً."

#. module: pos_advance_order
msgid "Please configure the Cash/Card journal on the POS configuration first."
msgstr "يرجى إعداد دفتر يومية الكاش/البطاقة في إعدادات نقطة البيع أولاً."

#. module: pos_advance_order
msgid "Payment journal is missing; please configure the POS Cash/Card journal."
msgstr "دفتر يومية الدفع غير محدد؛ يرجى إعداد دفتر يومية الكاش/البطاقة لنقطة البيع."

