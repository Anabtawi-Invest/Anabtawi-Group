<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Add a button to the Product Screen control buttons -->
    <t t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class,'control-buttons')]" position="inside">
            <button class="control-button" t-on-click="onClickAdvanceOrder" title="Advance Order">
                <span>Advance Order</span>
            </button>
        </xpath>
    </t>

    <!-- Advance Order Screen -->
    <t t-name="pos_advance_order_html.AdvanceOrderScreen" owl="1">
        <div class="pos-content">
            <div class="pos-adv-header">
                <div class="pos-adv-actions">
                    <button class="button back" t-on-click="back">Back</button>
                    <button class="button" t-on-click="clear">Clear</button>
                </div>
                <h2>Advance Order</h2>
                <button class="button validate" t-on-click="save">Save</button>
            </div>

            <div class="pos-adv-body">
                <div class="pos-adv-field">
                    <label>Requested date/time</label>
                    <input type="datetime-local" t-model="state.requested_datetime"/>
                </div>

                <div class="pos-adv-field">
                    <label>Customer note</label>
                    <textarea rows="5" t-model="state.note"></textarea>
                </div>

                <hr style="margin: 16px 0;" />

                <!-- OPTIONAL:
                     Paste your HTML markup (BODY content) here if you want it shown in the POS screen.
                     Avoid <script> tags; convert any dynamic behavior into Owl in JS.
                -->
                <div class="pos-adv-custom-html">
                    <p style="opacity:.8">
                        You can paste your <strong>advance-order-pos.html</strong> BODY markup here (without scripts).
                    </p>
                </div>
            </div>
        </div>
    </t>

</templates>
