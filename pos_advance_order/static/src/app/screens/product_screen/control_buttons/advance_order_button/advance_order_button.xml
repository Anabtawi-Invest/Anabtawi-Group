<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension" owl="1">
        <!-- Advance actions only inside the Actions dialog (never on main action pad). -->
        <xpath expr="//t[@t-if='props.showRemainingButtons']/div/NoteButton" position="after">
            <button
                t-if="pos.config.enable_advance_order"
                t-att-class="buttonClass"
                style="background-color: #6f42c1; color: #fff; border-color: #6f42c1;"
                t-on-click="onClickAdvanceOrder"
                type="button">
                <i class="fa fa-calendar-check-o me-2" role="img" aria-label="Advance Order" title="Advance Order"/>
                <span>Advance Order</span>
            </button>
            <button
                t-if="pos.config.enable_advance_order"
                t-att-class="buttonClass"
                style="background-color: #fd7e14; color: #fff; border-color: #fd7e14;"
                t-on-click="onClickCompleteAdvanceOrder"
                type="button">
                <i class="fa fa-check-square-o me-2" role="img" aria-label="Complete Advance Order" title="Complete Advance Order"/>
                <span>Complete Advance Order</span>
            </button>
        </xpath>
    </t>
</templates>
