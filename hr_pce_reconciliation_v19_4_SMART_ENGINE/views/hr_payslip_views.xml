<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_payslip_form_pce_recon" model="ir.ui.view">
        <field name="name">hr.payslip.form.pce.reconciliation</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_reconcile_lateness"
                        type="object"
                        string="Reconciliation"
                        class="btn-primary"
                        groups="hr_payroll.group_hr_payroll_user"/>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <group string="PCE Reconciliation">
                    <group>
                        <field name="lateness_hours" readonly="1"/>
                        <field name="ot_total_hours" readonly="1"/>
                        <field name="annual_leave_hours" readonly="1"/>
                        <field name="remaining_after_reconciliation_hours" readonly="1"/>
                    </group>
                    <group>
                        <field name="pce_bank_before_hours" readonly="1"/>
                        <field name="pce_bank_after_hours" readonly="1"/>
                        <field name="recon_ot_used_hours" readonly="1"/>
                        <field name="recon_leave_used_hours" readonly="1"/>
                    </group>
                    <group>
                        <field name="reconciliation_state" readonly="1"/>
                        <field name="reconciliation_date" readonly="1"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
