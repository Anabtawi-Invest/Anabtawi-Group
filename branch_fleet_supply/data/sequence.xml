<odoo>
  <record id="seq_branch_supply_order" model="ir.sequence">
    <field name="name">Branch Supply Order</field>
    <field name="code">branch.supply.order</field>
    <field name="prefix">BSO/%(year)s/</field>
    <field name="padding">5</field>
    <field name="company_id" eval="False"/>
  </record>

  <record id="seq_fleet_discrepancy_case" model="ir.sequence">
    <field name="name">Fleet Discrepancy Case</field>
    <field name="code">fleet.discrepancy.case</field>
    <field name="prefix">FDC/%(year)s/</field>
    <field name="padding">5</field>
    <field name="company_id" eval="False"/>
  </record>
</odoo>
