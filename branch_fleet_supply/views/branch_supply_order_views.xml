<odoo>

  <record id="action_branch_supply_order" model="ir.actions.act_window">
    <field name="name">Branch Supply Orders</field>
    <field name="res_model">branch.supply.order</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="view_branch_supply_order_list" model="ir.ui.view">
    <field name="name">branch.supply.order.list</field>
    <field name="model">branch.supply.order</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="state"/>
        <field name="warehouse_id"/>
        <field name="branch_warehouse_id"/>
        <field name="scheduled_date"/>
      </list>
    </field>
  </record>

  <record id="view_branch_supply_order_form" model="ir.ui.view">
    <field name="name">branch.supply.order.form</field>
    <field name="model">branch.supply.order</field>
    <field name="arch" type="xml">
      <form string="Branch Supply Order">
        <header>

          <button name="action_submit" type="object" string="Submit Request"
                  class="btn-primary"
                  modifiers="{'invisible':[('state','!=','draft')]}"/>

          <button name="action_approve" type="object" string="Approve"
                  class="btn-primary"
                  modifiers="{'invisible':[('state','!=','submitted')]}"/>

          <button name="action_factory_accept" type="object" string="Factory Accept"
                  class="btn-primary"
                  modifiers="{'invisible':[('state','!=','factory_planned')]}"/>

          <button name="action_load" type="object" string="Load (WH → Fleet)"
                  class="btn-primary"
                  modifiers="{'invisible':[('state','!=','ready_to_ship')]}"/>

          <button name="action_confirm_dispatch" type="object" string="Confirm Dispatch (Driver Verified)"
                  class="btn-primary"
                  modifiers="{'invisible':[('state','!=','loaded')]}"/>

          <button name="action_receive" type="object" string="Receive (Fleet → Branch)"
                  class="btn-primary"
                  modifiers="{'invisible':[('state','!=','in_transit')]}"/>

          <button name="action_cancel" type="object" string="Cancel"
                  class="btn-secondary"
                  modifiers="{'invisible':[('state','not in',('draft','submitted','approved','factory_planned','ready_to_ship'))]}"/>

          <field name="state" widget="statusbar"
                 statusbar_visible="draft,submitted,approved,factory_planned,ready_to_ship,loaded,in_transit,received,cancel"/>

        </header>

        <sheet>

          <group string="Supply Route">
            <group>
              <field name="warehouse_id" string="Source Warehouse (Factory)" required="1"
                     domain="[('id','!=',branch_warehouse_id)]"/>
              <div class="o_form_label oe_inline">→</div>
              <field name="branch_warehouse_id" string="Destination Warehouse (Branch)" required="1"
                     domain="[('id','!=',warehouse_id)]"/>
            </group>
            <group>
              <field name="fleet_location_id" string="Fleet Transit Location" required="1"
                     help="Temporary transit location. Drivers have NO system access."/>
              <field name="scheduled_date"/>
            </group>
          </group>

          <notebook>
            <page string="Products">
              <field name="line_ids">
                <list editable="bottom">
                  <field name="product_id"/>
                  <field name="requested_qty" string="Requested"/>
                  <field name="available_qty" string="Available" readonly="1"/>
                  <field name="shortage_qty" string="Shortage" readonly="1"/>
                  <field name="mo_id" readonly="1"/>
                  <field name="po_id" readonly="1"/>
                  <field name="loaded_qty" string="Loaded"/>
                  <field name="received_qty" string="Received"/>
                  <field name="warehouse_gap_qty" string="Req-Loaded" readonly="1"/>
                  <field name="transit_gap_qty" string="Loaded-Rec" readonly="1"/>
                </list>
              </field>
            </page>

            <page string="Stock Moves">
              <group>
                <field name="picking_wh_to_fleet_id" readonly="1"/>
                <field name="picking_fleet_to_branch_id" readonly="1"/>
              </group>
            </page>

            <page string="Notes">
              <field name="note"/>
            </page>
          </notebook>

        </sheet>

        <chatter/>
      </form>
    </field>
  </record>

</odoo>
