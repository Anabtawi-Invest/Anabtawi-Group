<odoo>

  <record id="action_fleet_discrepancy_case" model="ir.actions.act_window">
    <field name="name">Fleet Discrepancies</field>
    <field name="res_model">fleet.discrepancy.case</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="view_fleet_discrepancy_case_list" model="ir.ui.view">
    <field name="name">fleet.discrepancy.case.list</field>
    <field name="model">fleet.discrepancy.case</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="state"/>
        <field name="order_id"/>
        <field name="product_id"/>
        <field name="missing_qty"/>
        <field name="resolution_type"/>
        <field name="responsible_partner_id"/>
      </list>
    </field>
  </record>

  <record id="view_fleet_discrepancy_case_form" model="ir.ui.view">
    <field name="name">fleet.discrepancy.case.form</field>
    <field name="model">fleet.discrepancy.case</field>
    <field name="arch" type="xml">
      <form string="Fleet Discrepancy Case">
        <header>
          <button name="action_mark_reviewed" type="object" string="Mark Reviewed"
                  class="btn-primary"
                  modifiers="{'invisible':[('state','!=','open')]}"/>
          <button name="action_close" type="object" string="Close"
                  class="btn-secondary"
                  modifiers="{'invisible':[('state','not in',('open','reviewed'))]}"/>
          <button name="action_cancel" type="object" string="Cancel"
                  class="btn-secondary"
                  modifiers="{'invisible':[('state','=','closed')]}"/>
          <field name="state" widget="statusbar" statusbar_visible="open,reviewed,closed,cancel"/>
        </header>

        <sheet>
          <group>
            <group>
              <field name="name" readonly="1"/>
              <field name="company_id" groups="base.group_multi_company"/>
              <field name="order_id" readonly="1"/>
              <field name="product_id" readonly="1"/>
            </group>
            <group>
              <field name="uom_id" readonly="1"/>
              <field name="missing_qty" readonly="1"/>
              <field name="resolution_type"/>
              <field name="responsible_partner_id"/>
            </group>
          </group>
          <group string="Notes">
            <field name="notes" placeholder="Add justification / investigation notes..."/>
          </group>
        </sheet>

        <chatter/>
      </form>
    </field>
  </record>

</odoo>
