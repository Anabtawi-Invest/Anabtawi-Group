<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_config_view_form_open_amount" model="ir.ui.view">
        <field name="name">pos.config.form.open.amount</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Open Amount" name="pos_open_amount_config">
                    <field name="maximum_open_amount"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
