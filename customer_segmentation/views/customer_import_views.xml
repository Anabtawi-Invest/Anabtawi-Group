<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_customer_import_form" model="ir.ui.view">
        <field name="name">customer.import.form</field>
        <field name="model">customer.import</field>
        <field name="arch" type="xml">
            <form string="Customer Import">
                <header>
                    <button name="action_validate_file" string="Validate File" type="object" class="btn-primary" invisible="import_status != 'draft'"/>
                    <button name="action_import_customers" string="Import Customers" type="object" class="btn-success" invisible="import_status != 'validated'"/>
                    <field name="import_status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Import Name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="department" readonly="import_status != 'draft'"/>
                        <field name="filename"/>
                        <field name="excel_file" widget="binary" filename="filename" readonly="import_status != 'draft'"/>
                    </group>
                    <notebook>
                        <page string="Import Lines">
                            <field name="import_lines" nolabel="1">
                                <list>
                                    <field name="row_number"/>
                                    <field name="name"/>
                                    <field name="mobile"/>
                                    <field name="email"/>
                                    <field name="status" widget="badge"/>
                                    <field name="partner_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_customer_import_list" model="ir.ui.view">
        <field name="name">customer.import.list</field>
        <field name="model">customer.import</field>
        <field name="arch" type="xml">
            <list string="Customer Imports">
                <field name="name"/>
                <field name="department"/>
                <field name="import_status" widget="badge"/>
                <field name="filename"/>
            </list>
        </field>
    </record>

    <record id="view_customer_import_search" model="ir.ui.view">
        <field name="name">customer.import.search</field>
        <field name="model">customer.import</field>
        <field name="arch" type="xml">
            <search string="Search Imports">
                <field name="name" string="Import Name"/>
                <field name="department"/>
                <field name="filename"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('import_status', '=', 'draft')]"/>
                <filter name="validated" string="Validated" domain="[('import_status', '=', 'validated')]"/>
                <filter name="completed" string="Completed" domain="[('import_status', '=', 'completed')]"/>
                <filter name="error" string="Error" domain="[('import_status', '=', 'error')]"/>
                <separator/>
                <filter name="group_by_department" string="Department" context="{'group_by': 'department'}"/>
                <filter name="group_by_status" string="Status" context="{'group_by': 'import_status'}"/>
            </search>
        </field>
    </record>

    <record id="view_customer_import_wizard_form" model="ir.ui.view">
        <field name="name">customer.import.wizard.form</field>
        <field name="model">customer.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Customers">
                <group>
                    <field name="department" required="1"/>
                    <field name="excel_file" widget="binary" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
