<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_partner_form_segmentation" model="ir.ui.view">
        <field name="name">res.partner.form.segmentation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="Department Segmentation" name="department_segmentation">
                    <group>
                        <field name="department_category" readonly="True"/>
                    </group>
                    <group string="Department Assignments">
                        <field name="is_export_customer"/>
                        <field name="is_local_customer"/>
                        <field name="is_vendor"/>
                        <field name="is_pos_customer"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_res_partner_list_segmentation" model="ir.ui.view">
        <field name="name">res.partner.list.segmentation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="complete_name" position="after">
                <field name="department_category" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_res_partner_search_segmentation" model="ir.ui.view">
        <field name="name">res.partner.search.segmentation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter name="export_customers" string="Export Customers" domain="[('is_export_customer', '=', True)]"/>
                <filter name="local_customers" string="Local Customers" domain="[('is_local_customer', '=', True)]"/>
                <filter name="vendors" string="Vendors" domain="[('is_vendor', '=', True)]"/>
                <filter name="pos_customers" string="POS Customers" domain="[('is_pos_customer', '=', True)]"/>
                <separator/>
                <filter name="group_by_department" string="Department" context="{'group_by': 'department_category'}"/>
            </xpath>
        </field>
    </record>

</odoo>
