<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Module Category -->
    <record id="module_category_sales_visit" model="ir.module.category">
        <field name="name">Sales Visit Tracking</field>
        <field name="description">Manage sales representative visit tracking and geofence check-ins.</field>
        <field name="sequence">10</field>
    </record>

    <!-- Privilege (Odoo 19 security grouping) -->
    <record id="res_groups_privilege_sales_visit" model="res.groups.privilege">
        <field name="name">Sales Visit Tracking</field>
        <field name="category_id" ref="module_category_sales_visit"/>
    </record>

    <!-- Security Groups -->
    <record id="group_sales_representative" model="res.groups">
        <field name="name">Sales Representative</field>
        <field name="privilege_id" ref="res_groups_privilege_sales_visit"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_sales_supervisor" model="res.groups">
        <field name="name">Sales Supervisor</field>
        <field name="privilege_id" ref="res_groups_privilege_sales_visit"/>
        <field name="implied_ids" eval="[(4, ref('group_sales_representative'))]"/>
    </record>

    <record id="group_sales_manager" model="res.groups">
        <field name="name">Sales Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_sales_visit"/>
        <field name="implied_ids" eval="[(4, ref('group_sales_supervisor'))]"/>
    </record>

    <record id="group_sales_director" model="res.groups">
        <field name="name">Sales Director</field>
        <field name="privilege_id" ref="res_groups_privilege_sales_visit"/>
        <field name="implied_ids" eval="[(4, ref('group_sales_manager'))]"/>
    </record>

    <!-- Record Rules (noupdate: not overwritten on upgrade) -->
    <data noupdate="1">

        <!-- Multi-Company Rules -->
        <record id="sales_visit_lead_multicompany_rule" model="ir.rule">
            <field name="name">Sales Lead Multi-Company</field>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="sales_visit_multicompany_rule" model="ir.rule">
            <field name="name">Sales Visit Multi-Company</field>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="sales_route_point_multicompany_rule" model="ir.rule">
            <field name="name">Sales Route Point Multi-Company</field>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Lead Rules -->
        <record id="sales_visit_lead_rule_representative" model="ir.rule">
            <field name="name">Sales Representative Leads</field>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="sales_visit_lead_rule_supervisor" model="ir.rule">
            <field name="name">Sales Supervisor Leads</field>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id.employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="sales_visit_lead_rule_manager" model="ir.rule">
            <field name="name">Sales Manager Leads (Global)</field>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_manager'))]"/>
        </record>

        <!-- Visit Rules -->
        <record id="sales_visit_rule_representative" model="ir.rule">
            <field name="name">Sales Representative Visits</field>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="sales_visit_rule_supervisor" model="ir.rule">
            <field name="name">Sales Supervisor Visits</field>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="sales_visit_rule_manager" model="ir.rule">
            <field name="name">Sales Manager Visits (Global)</field>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_manager'))]"/>
        </record>

        <!-- Route Point Rules -->
        <record id="sales_route_point_rule_representative" model="ir.rule">
            <field name="name">Sales Representative Route Points</field>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="sales_route_point_rule_supervisor" model="ir.rule">
            <field name="name">Sales Supervisor Route Points</field>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="sales_route_point_rule_manager" model="ir.rule">
            <field name="name">Sales Manager Route Points (Global)</field>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_manager'))]"/>
        </record>

        <!-- Audit Log Multi-Company -->
        <record id="sales_visit_audit_log_multicompany_rule" model="ir.rule">
            <field name="name">Sales Visit Audit Log Multi-Company</field>
            <field name="model_id" ref="model_sales_visit_audit_log"/>
            <field name="domain_force">[('user_id.company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Audit Log Rules -->
        <record id="sales_visit_audit_log_rule_representative" model="ir.rule">
            <field name="name">Sales Representative Audit Logs</field>
            <field name="model_id" ref="model_sales_visit_audit_log"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="sales_visit_audit_log_rule_supervisor" model="ir.rule">
            <field name="name">Sales Supervisor Audit Logs</field>
            <field name="model_id" ref="model_sales_visit_audit_log"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id.employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="sales_visit_audit_log_rule_manager" model="ir.rule">
            <field name="name">Sales Manager Audit Logs (Global)</field>
            <field name="model_id" ref="model_sales_visit_audit_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_manager'))]"/>
        </record>

    </data>
</odoo>
