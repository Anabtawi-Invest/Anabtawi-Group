<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_sales_visit_tracking" model="ir.module.category">
            <name>Sales Visit Tracking</name>
            <field name="description">Simplified Sales Representative Visit Tracking &amp; Routing</field>
            <field name="sequence">25</field>
        </record>

        <record id="group_sales_representative" model="res.groups">
            <name>Sales Representative</name>
            <field name="category_id" ref="module_category_sales_visit_tracking"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_sales_supervisor" model="res.groups">
            <name>Sales Supervisor</name>
            <field name="category_id" ref="module_category_sales_visit_tracking"/>
            <field name="implied_ids" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="group_sales_manager" model="res.groups">
            <name>Sales Manager</name>
            <field name="category_id" ref="module_category_sales_visit_tracking"/>
            <field name="implied_ids" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="group_sales_director" model="res.groups">
            <name>Sales Director</name>
            <field name="category_id" ref="module_category_sales_visit_tracking"/>
            <field name="implied_ids" eval="[(4, ref('group_sales_manager'))]"/>
        </record>

        <!-- Multi-Company Rules -->
        <record id="sales_visit_lead_multicompany_rule" model="ir.rule">
            <name>Sales Lead Multi-Company</name>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="sales_visit_multicompany_rule" model="ir.rule">
            <name>Sales Visit Multi-Company</name>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="sales_route_point_multicompany_rule" model="ir.rule">
            <name>Sales Route Point Multi-Company</name>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <!-- Record Rules for sales.visit.lead -->
        <record id="sales_visit_lead_rule_representative" model="ir.rule">
            <name>Sales Representative Leads</name>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="sales_visit_lead_rule_supervisor" model="ir.rule">
            <name>Sales Supervisor Leads</name>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id.employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="sales_visit_lead_rule_manager" model="ir.rule">
            <name>Sales Manager Leads (Global)</name>
            <field name="model_id" ref="model_sales_visit_lead"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_manager'))]"/>
        </record>

        <!-- Record Rules for sales.visit -->
        <record id="sales_visit_rule_representative" model="ir.rule">
            <name>Sales Representative Visits</name>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="sales_visit_rule_supervisor" model="ir.rule">
            <name>Sales Supervisor Visits</name>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="sales_visit_rule_manager" model="ir.rule">
            <name>Sales Manager Visits (Global)</name>
            <field name="model_id" ref="model_sales_visit"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_manager'))]"/>
        </record>

        <!-- Record Rules for sales.route.point -->
        <record id="sales_route_point_rule_representative" model="ir.rule">
            <name>Sales Representative Route Points</name>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_representative'))]"/>
        </record>

        <record id="sales_route_point_rule_supervisor" model="ir.rule">
            <name>Sales Supervisor Route Points</name>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_supervisor'))]"/>
        </record>

        <record id="sales_route_point_rule_manager" model="ir.rule">
            <name>Sales Manager Route Points (Global)</name>
            <field name="model_id" ref="model_sales_route_point"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_manager'))]"/>
        </record>
    </data>
</odoo>
