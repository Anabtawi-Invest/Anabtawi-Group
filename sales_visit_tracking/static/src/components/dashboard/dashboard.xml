<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="sales_visit_tracking.SalesVisitDashboard">
        <div class="o_sales_visit_dashboard_action">
            <!-- Header -->
            <div class="o_dashboard_header">
                <div class="title_area">
                    <h1>Visits Manager Dashboard</h1>
                    <div class="subtitle">Anabtawi Sales Visits Tracking &amp; Team Coverage</div>
                </div>
                <div class="header_actions">
                    <div class="live_indicator">
                        <span class="dot"></span>
                        <span>LIVE UPDATE ACTIVE</span>
                    </div>
                    <button class="btn_refresh" t-on-click="onRefresh">
                        <i class="fa fa-refresh me-1"></i> Refresh
                    </button>
                </div>
            </div>

            <!-- Tab Navigation Links -->
            <div class="o_dashboard_tabs">
                <button t-attf-class="tab_link #{state.activeTab === 'assignments' ? 'active' : ''}" t-on-click="() => this.switchTab('assignments')">
                    <i class="fa fa-tasks me-1"></i> Assignments
                </button>
                <button t-attf-class="tab_link #{state.activeTab === 'map' ? 'active' : ''}" t-on-click="() => this.switchTab('map')">
                    <i class="fa fa-map me-1"></i> Live Map
                </button>
                <button t-attf-class="tab_link #{state.activeTab === 'performance' ? 'active' : ''}" t-on-click="() => this.switchTab('performance')">
                    <i class="fa fa-line-chart me-1"></i> Performance
                </button>
                <button t-attf-class="tab_link #{state.activeTab === 'coverage' ? 'active' : ''}" t-on-click="() => this.switchTab('coverage')">
                    <i class="fa fa-shield me-1"></i> Customer Coverage
                </button>
            </div>

            <!-- Tab 1: Assignments Dashboard -->
            <t t-if="state.activeTab === 'assignments'">
                <div class="tab_content assignments_tab">
                    <div class="o_kpis_grid">
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">Assigned Today</div>
                                <div class="kpi_value"><t t-out="state.data.assignments.assigned"/></div>
                            </div>
                            <div class="kpi_icon bg_blue"><i class="fa fa-calendar-o"></i></div>
                        </div>
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">In Progress (Pending)</div>
                                <div class="kpi_value"><t t-out="state.data.assignments.pending"/></div>
                            </div>
                            <div class="kpi_icon bg_purple"><i class="fa fa-spinner fa-spin"></i></div>
                        </div>
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">Completed Today</div>
                                <div class="kpi_value"><t t-out="state.data.assignments.completed"/></div>
                            </div>
                            <div class="kpi_icon bg_green"><i class="fa fa-check-circle"></i></div>
                        </div>
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">Missed Visits</div>
                                <div class="kpi_value"><t t-out="state.data.assignments.missed"/></div>
                            </div>
                            <div class="kpi_icon bg_red"><i class="fa fa-times-circle"></i></div>
                        </div>
                    </div>

                    <!-- Assignments Quick Actions -->
                    <div class="dashboard_section mt-4">
                        <h3>Quick Administration</h3>
                        <div class="quick_actions_grid mt-3">
                            <button class="btn_quick btn_schedule" t-on-click="onSchedule">
                                <i class="fa fa-calendar-plus-o me-2"></i> Schedule New Visit
                            </button>
                            <button class="btn_quick btn_assign" t-on-click="onAssign">
                                <i class="fa fa-users me-2"></i> Assign / Reassign Visits
                            </button>
                        </div>
                    </div>

                    <!-- Revisit Schedule Table -->
                    <div class="dashboard_section mt-4">
                        <h3>Upcoming Revisit &amp; Follow-up Schedule</h3>
                        <div class="table_container mt-3">
                            <table class="dashboard_table">
                                <thead>
                                    <tr>
                                        <th>Visit Date</th>
                                        <th>Customer / Lead</th>
                                        <th>Salesperson</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.data.assignments.revisit_schedule" t-as="r" t-key="r.id">
                                        <tr>
                                            <td><b><t t-out="r.date"/></b></td>
                                            <td><t t-out="r.customer"/></td>
                                            <td><t t-out="r.salesperson"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="state.data.assignments.revisit_schedule.length === 0">
                                        <tr>
                                            <td colspan="3" class="text-center text-muted py-4">No upcoming revisits scheduled.</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </t>

            <!-- Tab 2: Live Map Dashboard -->
            <t t-if="state.activeTab === 'map'">
                <div class="tab_content map_tab h-100">
                    <SalesRouteMap/>
                </div>
            </t>

            <!-- Tab 3: Performance Dashboard -->
            <t t-if="state.activeTab === 'performance'">
                <div class="tab_content performance_tab">
                    <div class="o_kpis_grid">
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">Total Assigned</div>
                                <div class="kpi_value"><t t-out="state.data.performance.assigned_visits"/></div>
                            </div>
                        </div>
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">Total Completed</div>
                                <div class="kpi_value"><t t-out="state.data.performance.completed_visits"/></div>
                            </div>
                        </div>
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">Orders Generated</div>
                                <div class="kpi_value"><t t-out="state.data.performance.orders_generated"/></div>
                            </div>
                        </div>
                        <div class="kpi_card">
                            <div class="kpi_content">
                                <div class="kpi_label">Total Revenue</div>
                                <div class="kpi_value">$<t t-out="state.data.performance.revenue_generated"/></div>
                            </div>
                        </div>
                    </div>

                    <!-- Leads Breakdown -->
                    <div class="o_dashboard_details mt-4">
                        <div class="dashboard_section">
                            <h3>Leads &amp; Customer Visits Outcomes</h3>
                            <div class="outcomes_flex mt-3">
                                <div class="outcome_stat">
                                    <span class="label">New Leads Visited:</span>
                                    <span class="val"><t t-out="state.data.performance.new_leads_visited"/></span>
                                </div>
                                <div class="outcome_stat">
                                    <span class="label text-success">Approved / Converted:</span>
                                    <span class="val text-success"><t t-out="state.data.performance.approved_leads"/></span>
                                </div>
                                <div class="outcome_stat">
                                    <span class="label text-danger">Rejected Leads:</span>
                                    <span class="val text-danger"><t t-out="state.data.performance.rejected_leads"/></span>
                                </div>
                                <div class="outcome_stat">
                                    <span class="label text-warning">Revisit Leads Visited:</span>
                                    <span class="val text-warning"><t t-out="state.data.performance.revisit_leads"/></span>
                                </div>
                                <div class="outcome_stat">
                                    <span class="label text-primary">Customer Visits:</span>
                                    <span class="val text-primary"><t t-out="state.data.performance.customer_visits"/></span>
                                </div>
                                <hr/>
                                <div class="outcome_stat pt-2">
                                    <span class="label"><b>Lead Conversion Rate:</b></span>
                                    <span class="val"><b><t t-out="state.data.performance.conversion_rate"/>%</b></span>
                                </div>
                            </div>
                        </div>

                        <!-- GPS Compliance meter -->
                        <div class="dashboard_section d-flex flex-column align-items-center justify-content-center">
                            <div class="compliance_meter_container">
                                <div class="compliance_radial">
                                    <svg>
                                        <circle class="bg_circle" cx="80" cy="80" r="70"></circle>
                                        <circle class="fill_circle" cx="80" cy="80" r="70"
                                                t-att-style="'stroke-dashoffset: ' + (440 - (440 * state.data.performance.gps_compliance / 100)) + ';'"></circle>
                                    </svg>
                                    <div class="percentage_text"><t t-out="state.data.performance.gps_compliance"/>%</div>
                                </div>
                                <div class="compliance_legend text-center">
                                    <div class="compliance_heading">GPS Geofence Compliance</div>
                                    <div class="compliance_sub">Completed visits vs total check-in attempts (including blocked cheats)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>

            <!-- Tab 4: Customer Coverage Dashboard -->
            <t t-if="state.activeTab === 'coverage'">
                <div class="tab_content coverage_tab">
                    
                    <!-- 90 Days Coverage -->
                    <div class="dashboard_section">
                        <h3 class="text-danger"><i class="fa fa-exclamation-triangle me-1"></i> Customers Not Visited in 90+ Days (Critical)</h3>
                        <div class="table_container mt-3">
                            <table class="dashboard_table">
                                <thead>
                                    <tr>
                                        <th>Customer</th>
                                        <th>Responsible Salesperson</th>
                                        <th>Last Visit Date</th>
                                        <th>Days Elapsed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.data.coverage.not_visited_90" t-as="c" t-key="c.id">
                                        <tr class="table-danger-row">
                                            <td><b><t t-out="c.name"/></b></td>
                                            <td><t t-out="c.salesperson"/></td>
                                            <td><t t-out="c.last_visit_date"/></td>
                                            <td><span class="badge bg-danger"><t t-out="c.days_since"/> days</span></td>
                                        </tr>
                                    </t>
                                    <t t-if="state.data.coverage.not_visited_90.length === 0">
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-3">All customers have been visited within 90 days.</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- 60 Days Coverage -->
                    <div class="dashboard_section mt-4">
                        <h3 class="text-warning"><i class="fa fa-exclamation-circle me-1"></i> Customers Not Visited in 60-89 Days (Warning)</h3>
                        <div class="table_container mt-3">
                            <table class="dashboard_table">
                                <thead>
                                    <tr>
                                        <th>Customer</th>
                                        <th>Responsible Salesperson</th>
                                        <th>Last Visit Date</th>
                                        <th>Days Elapsed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.data.coverage.not_visited_60" t-as="c" t-key="c.id">
                                        <tr class="table-warning-row">
                                            <td><b><t t-out="c.name"/></b></td>
                                            <td><t t-out="c.salesperson"/></td>
                                            <td><t t-out="c.last_visit_date"/></td>
                                            <td><span class="badge bg-warning text-dark"><t t-out="c.days_since"/> days</span></td>
                                        </tr>
                                    </t>
                                    <t t-if="state.data.coverage.not_visited_60.length === 0">
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-3">All customers have been visited within 60 days.</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- 30 Days Coverage -->
                    <div class="dashboard_section mt-4">
                        <h3 class="text-info"><i class="fa fa-info-circle me-1"></i> Customers Not Visited in 30-59 Days (Attention Needed)</h3>
                        <div class="table_container mt-3">
                            <table class="dashboard_table">
                                <thead>
                                    <tr>
                                        <th>Customer</th>
                                        <th>Responsible Salesperson</th>
                                        <th>Last Visit Date</th>
                                        <th>Days Elapsed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.data.coverage.not_visited_30" t-as="c" t-key="c.id">
                                        <tr>
                                            <td><b><t t-out="c.name"/></b></td>
                                            <td><t t-out="c.salesperson"/></td>
                                            <td><t t-out="c.last_visit_date"/></td>
                                            <td><span class="badge bg-info text-white"><t t-out="c.days_since"/> days</span></td>
                                        </tr>
                                    </t>
                                    <t t-if="state.data.coverage.not_visited_30.length === 0">
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-3">All customers have been visited within 30 days.</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
