<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="sales_visit_tracking.SalesVisitMobileApp">
        <div class="o_sales_visit_mobile_action">
            <!-- Loading Indicator Overlay -->
            <div t-if="state.loading" class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-white bg-opacity-75" style="z-index: 1050;">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <!-- Header -->
            <div class="mobile_header">
                <div class="user_info">
                    <h3>My Visits</h3>
                    <p>Today's Route Schedule</p>
                </div>
                <button class="refresh_btn" t-on-click="onRefresh" title="Refresh list">
                    <i class="fa fa-refresh"></i>
                </button>
            </div>

            <!-- View 1: Visits List (Home) -->
            <t t-if="state.view === 'home'">
                <div class="lead_list">
                    <t t-foreach="state.visits" t-as="visit" t-key="visit.id">
                        <div class="lead_card">
                            <div class="lead_info">
                                <div class="lead_name"><t t-out="visit.name"/></div>
                                <div class="lead_phone" t-if="visit.mobile"><i class="fa fa-phone me-1"></i> <t t-out="visit.mobile"/></div>
                                <div class="lead_date"><i class="fa fa-calendar me-1"></i> <t t-out="visit.visit_date"/></div>
                                
                                <span t-attf-class="lead_badge badge_#{visit.customer_type}">
                                    <t t-if="visit.customer_type === 'lead'">New Lead</t>
                                    <t t-if="visit.customer_type === 'revisit'">Revisit Lead</t>
                                    <t t-if="visit.customer_type === 'customer'">Customer</t>
                                </span>
                            </div>
                            <div class="lead_actions">
                                <button class="btn_navigate" t-on-click="() => this.onNavigate(visit)" t-att-disabled="!visit.lat and !visit.lon">
                                    <i class="fa fa-map-marker"></i> Navigate
                                </button>
                                
                                <!-- For New Lead with unknown coordinates: Save Location -->
                                <t t-if="visit.customer_type === 'lead' and !visit.lat and !visit.lon">
                                    <button class="btn_start btn_save_location" t-on-click="() => this.onSaveLocationAndCheckIn(visit)">
                                        <i class="fa fa-map-pin"></i> Save Location
                                    </button>
                                </t>
                                <!-- For Revisit or Customer (or leads with saved location): Check In -->
                                <t t-else="">
                                    <button class="btn_start" t-on-click="() => this.onCheckIn(visit)">
                                        <i class="fa fa-sign-in"></i> Check In
                                    </button>
                                </t>
                            </div>
                        </div>
                    </t>
                    <t t-if="state.visits.length === 0">
                        <div class="text-center text-muted py-5">
                            <i class="fa fa-check-circle fa-3x text-success mb-3"></i>
                            <div>All visits completed for today!</div>
                        </div>
                    </t>
                </div>
            </t>

            <!-- View 2: Active Visit -->
            <t t-if="state.view === 'visiting'">
                <div class="active_visit_container">
                    <div class="visit_card">
                        <div class="customer_name"><t t-out="state.activeVisit.name"/></div>
                        <div class="timer_box">
                            <div class="timer_label">Active Visit Duration</div>
                            <div class="timer_value"><t t-out="state.timeElapsed"/></div>
                        </div>
                        <button class="btn_end" t-on-click="onEndVisit">
                            <i class="fa fa-stop me-2"></i> END VISIT
                        </button>
                    </div>
                </div>
            </t>

            <!-- View 3: Visit Result Outcome Selector -->
            <t t-if="state.view === 'result'">
                <div class="outcome_selection_container">
                    <h2>Select Visit Outcome</h2>
                    <p class="text-center text-muted mb-4">Choose final result for <t t-out="state.activeVisit.name"/></p>

                    <!-- Selection screen -->
                    <t t-if="state.selectedOutcome === ''">
                        <div class="choices_grid">
                            <!-- New Lead / Revisit Lead Outcome Options -->
                            <t t-if="state.activeVisit.customer_type === 'lead' || state.activeVisit.customer_type === 'revisit'">
                                <button class="btn_choice choice_revisit" t-on-click="() => this.selectOutcome('revisit')">
                                    <i class="fa fa-calendar-plus-o fa-lg"></i> REVISIT (Follow-up)
                                </button>
                                <button class="btn_choice choice_approved" t-on-click="() => this.selectOutcome('approved')">
                                    <i class="fa fa-check-circle fa-lg"></i> APPROVED (Convert Customer)
                                </button>
                                <button class="btn_choice choice_rejected" t-on-click="() => this.selectOutcome('rejected')">
                                    <i class="fa fa-times-circle fa-lg"></i> REJECTED (Not Interested)
                                </button>
                            </t>
                            
                            <!-- Approved Customer Outcome Options -->
                            <t t-if="state.activeVisit.customer_type === 'customer'">
                                <button class="btn_choice choice_order" t-on-click="() => this.selectOutcome('order')">
                                    <i class="fa fa-shopping-cart fa-lg"></i> ORDER (Sales / Quotation)
                                </button>
                                <button class="btn_choice choice_revisit" t-on-click="() => this.selectOutcome('revisit')">
                                    <i class="fa fa-calendar-plus-o fa-lg"></i> REVISIT (Follow-up)
                                </button>
                                <button class="btn_choice choice_issue" t-on-click="() => this.selectOutcome('issue')">
                                    <i class="fa fa-exclamation-circle fa-lg"></i> ISSUE (Log Complaint)
                                </button>
                            </t>
                        </div>
                    </t>

                    <!-- Details Input Form for Revisit -->
                    <t t-if="state.selectedOutcome === 'revisit'">
                        <div class="outcome_details_form">
                            <div class="form_group">
                                <label for="revisit_date">Choose Next Visit Date</label>
                                <input type="date" id="revisit_date" t-model="state.revisitDate" required="1"/>
                            </div>
                            <div class="form_actions">
                                <button class="btn_cancel" t-on-click="onCancelDetails">Cancel</button>
                                <button class="btn_submit" t-on-click="onSubmitDetails">Submit</button>
                            </div>
                        </div>
                    </t>

                    <!-- Details Input Form for Rejection -->
                    <t t-if="state.selectedOutcome === 'rejected'">
                        <div class="outcome_details_form">
                            <div class="form_group">
                                <label for="rejection_reason">Reason for Rejection</label>
                                <select id="rejection_reason" t-model="state.rejectionReason">
                                    <option value="price">Price too high</option>
                                    <option value="competitor">Prefers Competitor</option>
                                    <option value="not_interested">Not Interested</option>
                                    <option value="no_budget">No Budget</option>
                                    <option value="other">Other Reason</option>
                                </select>
                            </div>
                            <div class="form_actions">
                                <button class="btn_cancel" t-on-click="onCancelDetails">Cancel</button>
                                <button class="btn_submit" t-on-click="onSubmitDetails">Submit</button>
                            </div>
                        </div>
                    </t>

                    <!-- Details Input Form for Issue -->
                    <t t-if="state.selectedOutcome === 'issue'">
                        <div class="outcome_details_form">
                            <div class="form_group">
                                <label for="customer_issue">Customer Issue / Complaint Details</label>
                                <textarea id="customer_issue" t-model="state.customerIssue" placeholder="Describe the issue here..." rows="4" required="1"></textarea>
                            </div>
                            <div class="form_actions">
                                <button class="btn_cancel" t-on-click="onCancelDetails">Cancel</button>
                                <button class="btn_submit" t-on-click="onSubmitDetails">Submit</button>
                            </div>
                        </div>
                    </t>

                    <!-- Order Action Redirection Buttons -->
                    <t t-if="state.selectedOutcome === 'order'">
                        <div class="outcome_details_form">
                            <h3>Create Document in Odoo</h3>
                            <p class="text-center text-muted mb-4">You will be redirected to the standard Odoo Sales Form.</p>
                            <div class="order_actions_grid">
                                <button class="btn_choice choice_order mb-2" t-on-click="() => this.createSalesOrderAction('quotation')">
                                    <i class="fa fa-file-text-o fa-lg"></i> Create Quotation
                                </button>
                                <button class="btn_choice choice_approved mb-3" t-on-click="() => this.createSalesOrderAction('order')">
                                    <i class="fa fa-shopping-bag fa-lg"></i> Create Sales Order
                                </button>
                            </div>
                            <div class="form_actions">
                                <button class="btn_cancel w-100" t-on-click="onCancelDetails">Cancel</button>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </div>
    </t>
</templates>
