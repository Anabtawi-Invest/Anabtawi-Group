<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_sales_visit" model="ir.ui.view">
        <field name="name">res.partner.form.sales.visit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page string="Visit History"
                      name="visit_history"
                      groups="sales_visit_tracking.group_sales_representative">

                    <group>
                        <group string="Geolocation Info">
                            <field name="latitude" readonly="1"/>
                            <field name="longitude" readonly="1"/>
                            <field name="geo_verified" readonly="1"/>
                            <field name="geolocation_date" readonly="1"/>
                            <field name="lead_id" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Timeline of Visits"/>

                    <field name="visit_ids" readonly="1">
                        <tree string="Visits History">
                            <field name="check_in_time" string="Arrival Time"/>
                            <field name="check_out_time" string="Departure Time"/>
                            <field name="duration" widget="float_time" string="Duration"/>
                            <field name="verification_status"
                                   widget="badge"
                                   decoration-success="verification_status == 'valid'"
                                   decoration-warning="verification_status == 'warning'"
                                   decoration-danger="verification_status == 'invalid'"
                                   string="GPS Validation"/>

                            <field name="result"
                                   widget="badge"
                                   decoration-success="result == 'approved'"
                                   decoration-warning="result == 'revisit'"
                                   decoration-danger="result == 'rejected'"
                                   string="Result"/>
                        </tree>
                    </field>

                </page>

            </xpath>

        </field>
    </record>

</odoo>
