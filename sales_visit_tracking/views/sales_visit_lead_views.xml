<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- sales.visit.lead Form View -->
    <record id="view_sales_visit_lead_form" model="ir.ui.view">
        <field name="name">sales.visit.lead.form</field>
        <field name="model">sales.visit.lead</field>
        <field name="arch" type="xml">
            <form string="Lead Detail">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="lead,revisit,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Customer Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="mobile" widget="phone"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="partner_id" invisible="not partner_id"/>
                        </group>
                        <group string="Coordinates &amp; Location">
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                    <group string="Outcome Details" invisible="status not in ('revisit', 'rejected')">
                        <field name="next_visit_date" invisible="status != 'revisit'" required="status == 'revisit'"/>
                        <field name="rejection_reason" invisible="status != 'rejected'" required="status == 'rejected'"/>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Add optional details..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- sales.visit.lead List View -->
    <record id="view_sales_visit_lead_list" model="ir.ui.view">
        <field name="name">sales.visit.lead.list</field>
        <field name="model">sales.visit.lead</field>
        <field name="arch" type="xml">
            <list string="Leads" decoration-info="status == 'revisit'" decoration-success="status == 'approved'" decoration-danger="status == 'rejected'">
                <field name="name"/>
                <field name="mobile"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="status" widget="badge" decoration-info="status == 'revisit'" decoration-success="status == 'approved'" decoration-danger="status == 'rejected'" decoration-muted="status == 'lead'"/>
            </list>
        </field>
    </record>

    <!-- sales.visit.lead Search View -->
    <record id="view_sales_visit_lead_search" model="ir.ui.view">
        <field name="name">sales.visit.lead.search</field>
        <field name="model">sales.visit.lead</field>
        <field name="arch" type="xml">
            <search string="Search Leads">
                <field name="name" string="Customer Name"/>
                <field name="mobile" string="Mobile Number"/>
                <field name="user_id" string="Salesperson"/>
                <filter string="My Leads" name="my_leads" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Active Leads" name="active_leads" domain="[('status', 'in', ['lead', 'revisit'])]"/>
                <filter string="Revisit Required" name="revisit" domain="[('status', '=', 'revisit')]"/>
                <filter string="Approved" name="approved" domain="[('status', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('status', '=', 'rejected')]"/>
                <group>
                    <filter string="Salesperson" name="group_salesperson" context="{'group_by': 'user_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_sales_visit_lead" model="ir.actions.act_window">
        <field name="name">Leads</field>
        <field name="res_model">sales.visit.lead</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sales_visit_lead_search"/>
        <field name="context">{'search_default_active_leads': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new sales lead.
            </p>
            <p>
                Configure mobile numbers, assigned salespeople, and location coordinates.
            </p>
        </field>
    </record>
</odoo>
