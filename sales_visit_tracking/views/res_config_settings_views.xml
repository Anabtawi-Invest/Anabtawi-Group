<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_sales_visit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sales.visit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='sale_management']" position="inside">
                <block title="Sales Visit Tracking" id="sales_visit_tracking_settings">
                    <setting string="Allowed Geofence Radius" help="Configure maximum distance in meters for a valid check-in.">
                        <div class="content-group">
                            <div class="row mt-2">
                                <label for="sales_visit_allowed_radius" class="col-lg-3 o_light_label"/>
                                <field name="sales_visit_allowed_radius" class="oe_inline"/>
                                <span class="ml-2">meters</span>
                            </div>
                        </div>
                    </setting>
                    <setting string="Route Tracking Interval" help="Configure interval in minutes for GPS route log pings.">
                        <div class="content-group">
                            <div class="row mt-2">
                                <label for="sales_visit_tracking_interval" class="col-lg-3 o_light_label"/>
                                <field name="sales_visit_tracking_interval" class="oe_inline"/>
                                <span class="ml-2">minutes</span>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
