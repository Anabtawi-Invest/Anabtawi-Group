<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom OWL Client Actions -->
    <record id="action_sales_visit_mobile_client" model="ir.actions.client">
        <field name="name">Salesperson Mobile Home Screen</field>
        <field name="tag">sales_visit_mobile_app</field>
    </record>

    <record id="action_sales_visit_dashboard_client" model="ir.actions.client">
        <field name="name">Live Sales Dashboard</field>
        <field name="tag">sales_visit_dashboard</field>
    </record>

    <record id="action_sales_visit_map_client" model="ir.actions.client">
        <field name="name">Route Map Visualization</field>
        <field name="tag">sales_visit_route_map</field>
    </record>

    <!-- Menu Structure -->
    <menuitem id="menu_sales_visit_root"
              name="Sales Visits"
              web_icon="sales_visit_tracking,static/description/icon.png"
              sequence="15"/>

    <!-- Operations Category -->
    <menuitem id="menu_sales_visit_operations"
              name="Operations"
              parent="menu_sales_visit_root"
              sequence="10"/>

    <menuitem id="menu_sales_visit_mobile_app"
              name="Salesperson Screen"
              parent="menu_sales_visit_operations"
              action="action_sales_visit_mobile_client"
              sequence="5"/>

    <menuitem id="menu_sales_visit_lead"
              name="Leads Management"
              parent="menu_sales_visit_operations"
              action="action_sales_visit_lead"
              groups="sales_visit_tracking.group_sales_supervisor"
              sequence="10"/>

    <menuitem id="menu_sales_visit_logs"
              name="Visits History Logs"
              parent="menu_sales_visit_operations"
              action="action_sales_visit"
              groups="sales_visit_tracking.group_sales_supervisor"
              sequence="15"/>

    <menuitem id="menu_sales_visit_route_map"
              name="Route Tracking Map"
              parent="menu_sales_visit_operations"
              action="action_sales_visit_map_client"
              groups="sales_visit_tracking.group_sales_supervisor"
              sequence="20"/>

    <!-- Reporting Category -->
    <menuitem id="menu_sales_visit_reporting"
              name="Reporting"
              parent="menu_sales_visit_root"
              groups="sales_visit_tracking.group_sales_manager"
              sequence="20"/>

    <menuitem id="menu_sales_visit_dashboard"
              name="Analytics Dashboard"
              parent="menu_sales_visit_reporting"
              action="action_sales_visit_dashboard_client"
              sequence="10"/>

    <menuitem id="menu_sales_route_point"
              name="Route Coordinates Logs"
              parent="menu_sales_visit_reporting"
              action="action_sales_route_point"
              sequence="20"/>

    <!-- Configuration Category -->
    <menuitem id="menu_sales_visit_config"
              name="Configuration"
              parent="menu_sales_visit_root"
              groups="sales_visit_tracking.group_sales_director"
              sequence="30"/>

    <menuitem id="menu_sales_visit_settings"
              name="Settings"
              parent="menu_sales_visit_config"
              action="sale.action_sale_config_settings"
              sequence="10"/>
</odoo>
