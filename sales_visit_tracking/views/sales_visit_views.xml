<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- sales.visit Form View -->
    <record id="view_sales_visit_form" model="ir.ui.view">
        <field name="name">sales.visit.form</field>
        <field name="model">sales.visit</field>
        <field name="arch" type="xml">
            <form string="Visit Log" create="false">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="assigned,in_progress,completed,missed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="lead_id" invisible="customer_type == 'customer'"/>
                            <field name="partner_id" invisible="customer_type != 'customer'"/>
                            <field name="customer_type"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="employee_id"/>
                            <field name="visit_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Outcome Summary">
                            <field name="result" widget="badge" decoration-success="result in ['approved', 'order']" decoration-warning="result == 'revisit'" decoration-danger="result == 'rejected'" decoration-info="result == 'issue'"/>
                            <field name="next_visit_date" invisible="result != 'revisit'"/>
                            <field name="rejection_reason" invisible="result != 'rejected'"/>
                            <field name="customer_issue" invisible="result != 'issue'"/>
                            <field name="sale_order_id" invisible="result != 'order'"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>
                    <group string="GPS Validation Log">
                        <group string="Check-In Coordinates">
                            <field name="check_in_time"/>
                            <field name="check_in_latitude"/>
                            <field name="check_in_longitude"/>
                            <field name="distance_from_customer"/>
                            <field name="verification_status" widget="badge" decoration-success="verification_status == 'valid'" decoration-danger="verification_status == 'invalid'"/>
                        </group>
                        <group string="Check-Out Coordinates">
                            <field name="check_out_time"/>
                            <field name="check_out_latitude"/>
                            <field name="check_out_longitude"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- sales.visit List View -->
    <record id="view_sales_visit_list" model="ir.ui.view">
        <field name="name">sales.visit.list</field>
        <field name="model">sales.visit</field>
        <field name="arch" type="xml">
            <list string="Visit Logs" create="true" delete="true">
                <field name="name"/>
                <field name="lead_id" string="Lead" optional="show"/>
                <field name="partner_id" string="Customer" optional="show"/>
                <field name="customer_type"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="visit_date"/>
                <field name="state" widget="badge" decoration-info="state == 'assigned'" decoration-warning="state == 'in_progress'" decoration-success="state == 'completed'" decoration-danger="state == 'missed'"/>
                <field name="verification_status" widget="badge" decoration-success="verification_status == 'valid'" decoration-danger="verification_status == 'invalid'"/>
                <field name="result" widget="badge" decoration-success="result in ['approved', 'order']" decoration-warning="result == 'revisit'" decoration-danger="result == 'rejected'" decoration-info="result == 'issue'"/>
            </list>
        </field>
    </record>

    <!-- sales.visit Search View -->
    <record id="view_sales_visit_search" model="ir.ui.view">
        <field name="name">sales.visit.search</field>
        <field name="model">sales.visit</field>
        <field name="arch" type="xml">
            <search string="Search Visits">
                <field name="name"/>
                <field name="lead_id" string="Lead"/>
                <field name="partner_id" string="Customer"/>
                <field name="user_id" string="Salesperson"/>
                <separator/>
                <filter string="Assigned" name="assigned" domain="[('state', '=', 'assigned')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Missed" name="missed" domain="[('state', '=', 'missed')]"/>
                <separator/>
                <filter string="Valid GPS" name="valid" domain="[('verification_status', '=', 'valid')]"/>
                <filter string="Invalid GPS" name="invalid" domain="[('verification_status', '=', 'invalid')]"/>
                <separator/>
                <filter string="Approved/Converted" name="approved" domain="[('result', '=', 'approved')]"/>
                <filter string="Revisit Scheduled" name="revisit" domain="[('result', '=', 'revisit')]"/>
                <filter string="Rejected" name="rejected" domain="[('result', '=', 'rejected')]"/>
                <filter string="Order Generated" name="order" domain="[('result', '=', 'order')]"/>
                <filter string="Issue Reported" name="issue" domain="[('result', '=', 'issue')]"/>
                <group>
                    <filter string="Salesperson" name="group_salesperson" context="{'group_by': 'user_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Customer Type" name="group_customer_type" context="{'group_by': 'customer_type'}"/>
                    <filter string="Outcome" name="group_result" context="{'group_by': 'result'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action for sales.visit -->
    <record id="action_sales_visit" model="ir.actions.act_window">
        <field name="name">Customer Visits Log</field>
        <field name="res_model">sales.visit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sales_visit_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Customer visits logs will appear here.
            </p>
            <p>
                Create assignments or view existing salesperson logs.
            </p>
        </field>
    </record>

    <!-- sales.visit.audit.log List View -->
    <record id="view_sales_visit_audit_log_list" model="ir.ui.view">
        <field name="name">sales.visit.audit.log.list</field>
        <field name="model">sales.visit.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit Logs" create="false" edit="false" delete="false">
                <field name="timestamp"/>
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="event_type" widget="badge" decoration-info="event_type in ['assignment_change', 'system']" decoration-success="event_type in ['check_in', 'check_out', 'conversion']" decoration-warning="event_type in ['location_change', 'visit_result']" decoration-danger="event_type == 'blocked_check_in'"/>
                <field name="description"/>
                <field name="latitude" optional="hide"/>
                <field name="longitude" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- sales.visit.audit.log Form View -->
    <record id="view_sales_visit_audit_log_form" model="ir.ui.view">
        <field name="name">sales.visit.audit.log.form</field>
        <field name="model">sales.visit.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Details" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Log Header">
                            <field name="name"/>
                            <field name="user_id"/>
                            <field name="timestamp"/>
                            <field name="event_type"/>
                        </group>
                        <group string="GPS Coordinates">
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                    <group string="Log Details">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- sales.visit.audit.log Search View -->
    <record id="view_sales_visit_audit_log_search" model="ir.ui.view">
        <field name="name">sales.visit.audit.log.search</field>
        <field name="model">sales.visit.audit.log</field>
        <field name="arch" type="xml">
            <search string="Search Audit Logs">
                <field name="name"/>
                <field name="user_id" string="User"/>
                <separator/>
                <filter string="Blocked Check-Ins" name="blocked" domain="[('event_type', '=', 'blocked_check_in')]"/>
                <filter string="Location Changes" name="loc_change" domain="[('event_type', '=', 'location_change')]"/>
                <filter string="Assignments" name="assignments" domain="[('event_type', '=', 'assignment_change')]"/>
                <group>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Event Type" name="group_event_type" context="{'group_by': 'event_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action for sales.visit.audit.log -->
    <record id="action_sales_visit_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Logs</field>
        <field name="res_model">sales.visit.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sales_visit_audit_log_search"/>
        <field name="help" type="html">
            <p>
                System audit logs trace check-ins, check-outs, coordinate locks, reassignments, and blocked check-in attempts.
            </p>
            <p>
                These logs are immutable and cannot be modified or deleted.
            </p>
        </field>
    </record>
</odoo>
