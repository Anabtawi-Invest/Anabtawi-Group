<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- sales.visit Form View -->
    <record id="view_sales_visit_form" model="ir.ui.view">
        <field name="name">sales.visit.form</field>
        <field name="model">sales.visit</field>
        <field name="arch" type="xml">
            <form string="Visit Log" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="lead_id"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="employee_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Outcome Summary">
                            <field name="result" widget="badge" decoration-success="result == 'approved'" decoration-warning="result == 'revisit'" decoration-danger="result == 'rejected'"/>
                            <field name="next_visit_date" invisible="result != 'revisit'"/>
                            <field name="rejection_reason" invisible="result != 'rejected'"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>
                    <group string="GPS Validation Log">
                        <group string="Check-In Coordinates">
                            <field name="check_in_time"/>
                            <field name="check_in_latitude"/>
                            <field name="check_in_longitude"/>
                            <field name="distance_from_customer"/>
                            <field name="verification_status" widget="badge" decoration-success="verification_status == 'valid'" decoration-warning="verification_status == 'warning'" decoration-danger="verification_status == 'invalid'"/>
                        </group>
                        <group string="Check-Out Coordinates">
                            <field name="check_out_time"/>
                            <field name="check_out_latitude"/>
                            <field name="check_out_longitude"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- sales.visit List View -->
    <record id="view_sales_visit_tree" model="ir.ui.view">
        <field name="name">sales.visit.tree</field>
        <field name="model">sales.visit</field>
        <field name="arch" type="xml">
            <list string="Visit Logs" create="false" edit="false" delete="true">
                <field name="name"/>
                <field name="lead_id" string="Customer"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="check_in_time"/>
                <field name="check_out_time"/>
                <field name="duration" widget="float_time"/>
                <field name="verification_status" widget="badge" decoration-success="verification_status == 'valid'" decoration-warning="verification_status == 'warning'" decoration-danger="verification_status == 'invalid'"/>
                <field name="result" widget="badge" decoration-success="result == 'approved'" decoration-warning="result == 'revisit'" decoration-danger="result == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- sales.visit Search View -->
    <record id="view_sales_visit_search" model="ir.ui.view">
        <field name="name">sales.visit.search</field>
        <field name="model">sales.visit</field>
        <field name="arch" type="xml">
            <search string="Search Visits">
                <field name="name"/>
                <field name="lead_id" string="Customer"/>
                <field name="user_id" string="Salesperson"/>
                <filter string="Valid Visits" name="valid" domain="[('verification_status', '=', 'valid')]"/>
                <filter string="Warning Visits" name="warning" domain="[('verification_status', '=', 'warning')]"/>
                <filter string="Invalid Visits" name="invalid" domain="[('verification_status', '=', 'invalid')]"/>
                <filter string="Approved" name="approved" domain="[('result', '=', 'approved')]"/>
                <filter string="Revisit" name="revisit" domain="[('result', '=', 'revisit')]"/>
                <filter string="Rejected" name="rejected" domain="[('result', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Salesperson" name="group_salesperson" context="{'group_by': 'user_id'}"/>
                    <filter string="Customer" name="group_customer" context="{'group_by': 'lead_id'}"/>
                    <filter string="Outcome" name="group_result" context="{'group_by': 'result'}"/>
                    <filter string="GPS Validation" name="group_verification" context="{'group_by': 'verification_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_sales_visit" model="ir.actions.act_window">
        <field name="name">Customer Visits Log</field>
        <field name="res_model">sales.visit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sales_visit_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Customer visits logs will appear here.
            </p>
            <p>
                Visits are automatically logged when salespeople check in/out via the mobile home page.
            </p>
        </field>
    </record>
</odoo>
