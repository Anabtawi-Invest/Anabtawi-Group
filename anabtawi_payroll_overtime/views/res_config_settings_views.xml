<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_overtime_rate" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.anabtawi.group.overtime</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_payroll.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='hr_payroll_settings']" position="inside">
                <setting string="Overtime Hourly Amount" id="anabtawi_group_overtime_hourly_amount">
                    <field name="overtime_hourly_amount"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
