<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="branches_template" name="Anabtawi Branches">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <!-- Page Banner -->
                <section class="anabtawi-page-banner">
                    <div class="container py-3">
                        <h1 class="mb-3" style="color: var(--anabtawi-primary); font-weight: 800; font-family: 'Cairo';">فروعنا</h1>
                        <p class="lead text-muted col-md-8 mx-auto" style="font-size: 1.1rem;">
                            نحن متواجدون بالقرب منك لخدمتك وتلبية طلباتك في الأردن وفلسطين. تفضل بزيارتنا.
                        </p>
                    </div>
                </section>

                <!-- Jordan Branches -->
                <section class="py-5 bg-white">
                    <div class="container">
                        <h2 class="title text-center mb-5" style="font-family: 'Cairo';">فروع المملكة الأردنية الهاشمية</h2>
                        
                        <div class="row g-4 text-end">
                            <!-- Branch 1 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="branch-list-card h-100">
                                    <h4 class="mb-3" style="color: var(--anabtawi-primary); font-weight: bold;"><i class="fa fa-map-marker me-2"></i> فرع شارع المدينة المنورة</h4>
                                    <p class="mb-2 text-muted"><i class="fa fa-map me-2"></i> عمان، شارع المدينة المنورة، بجانب مستشفى ابن الهيثم</p>
                                    <p class="mb-2 text-muted"><i class="fa fa-phone me-2"></i> +962 6 5800001</p>
                                    <p class="mb-4 text-muted"><i class="fa fa-clock-o me-2"></i> 9:00 ص - 11:30 م</p>
                                    <a href="https://maps.google.com" target="_blank" class="btn btn-more btn-sm w-100">عرض على الخريطة</a>
                                </div>
                            </div>
                            
                            <!-- Branch 2 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="branch-list-card h-100">
                                    <h4 class="mb-3" style="color: var(--anabtawi-primary); font-weight: bold;"><i class="fa fa-map-marker me-2"></i> فرع الكرك</h4>
                                    <p class="mb-2 text-muted"><i class="fa fa-map me-2"></i> الكرك، الثنية، الشارع الرئيسي</p>
                                    <p class="mb-2 text-muted"><i class="fa fa-phone me-2"></i> +962 3 2341234</p>
                                    <p class="mb-4 text-muted"><i class="fa fa-clock-o me-2"></i> 9:00 ص - 11:00 م</p>
                                    <a href="https://maps.google.com" target="_blank" class="btn btn-more btn-sm w-100">عرض على الخريطة</a>
                                </div>
                            </div>
                            
                            <!-- Branch 3 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="branch-list-card h-100">
                                    <h4 class="mb-3" style="color: var(--anabtawi-primary); font-weight: bold;"><i class="fa fa-map-marker me-2"></i> فرع مطار الملكة علياء</h4>
                                    <p class="mb-2 text-muted"><i class="fa fa-map me-2"></i> مبنى المغادرين، الطابق الثاني، المنطقة الحرة</p>
                                    <p class="mb-2 text-muted"><i class="fa fa-phone me-2"></i> +962 6 4452000</p>
                                    <p class="mb-4 text-muted"><i class="fa fa-clock-o me-2"></i> 24 ساعة طيلة أيام الأسبوع</p>
                                    <a href="https://maps.google.com" target="_blank" class="btn btn-more btn-sm w-100">عرض على الخريطة</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Palestine Branches -->
                <section class="py-5 bg-anabtawi-gray">
                    <div class="container">
                        <h2 class="title text-center mb-5" style="font-family: 'Cairo';">فروع فلسطين</h2>
                        
                        <div class="row g-4 text-end">
                            <!-- Branch 1 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="branch-list-card h-100">
                                    <h4 class="mb-3" style="color: var(--anabtawi-primary); font-weight: bold;"><i class="fa fa-map-marker me-2"></i> فرع طولكرم</h4>
                                    <p class="mb-2 text-muted"><i class="fa fa-map me-2"></i> طولكرم، شارع باريس، وسط المدينة</p>
                                    <p class="mb-2 text-muted"><i class="fa fa-phone me-2"></i> +970 9 2671234</p>
                                    <p class="mb-4 text-muted"><i class="fa fa-clock-o me-2"></i> 9:00 ص - 10:30 م</p>
                                    <a href="https://maps.google.com" target="_blank" class="btn btn-more btn-sm w-100">عرض على الخريطة</a>
                                </div>
                            </div>
                            
                            <!-- Branch 2 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="branch-list-card h-100">
                                    <h4 class="mb-3" style="color: var(--anabtawi-primary); font-weight: bold;"><i class="fa fa-map-marker me-2"></i> فرع عنبتا</h4>
                                    <p class="mb-2 text-muted"><i class="fa fa-map me-2"></i> عنبتا، الشارع الرئيسي، مقابل البلدية</p>
                                    <p class="mb-2 text-muted"><i class="fa fa-phone me-2"></i> +970 9 2684321</p>
                                    <p class="mb-4 text-muted"><i class="fa fa-clock-o me-2"></i> 9:00 ص - 10:00 م</p>
                                    <a href="https://maps.google.com" target="_blank" class="btn btn-more btn-sm w-100">عرض على الخريطة</a>
                                </div>
                            </div>
                            
                            <!-- Branch 3 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="branch-list-card h-100">
                                    <h4 class="mb-3" style="color: var(--anabtawi-primary); font-weight: bold;"><i class="fa fa-map-marker me-2"></i> فرع قلقيلية</h4>
                                    <p class="mb-2 text-muted"><i class="fa fa-map me-2"></i> قلقيلية، الشارع الشرقي، بجانب دوار الداخلية</p>
                                    <p class="mb-2 text-muted"><i class="fa fa-phone me-2"></i> +970 9 2940000</p>
                                    <p class="mb-4 text-muted"><i class="fa fa-clock-o me-2"></i> 9:00 ص - 11:00 م</p>
                                    <a href="https://maps.google.com" target="_blank" class="btn btn-more btn-sm w-100">عرض على الخريطة</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <record id="branches_page" model="website.page">
        <field name="name">فروعنا</field>
        <field name="url">/branches</field>
        <field name="view_id" ref="branches_template"/>
        <field name="is_published">True</field>
        <field name="website_indexed">True</field>
    </record>
</odoo>
