<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="contactus" inherit_id="website.contactus" name="Anabtawi Sweets - Contact" active="True" priority="50">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure anabtawi-theme">
                <section class="anabtawi-page-hero py-5" data-name="Contact title" data-snippet="s_title">
                    <div class="container py-4 text-center">
                        <span class="anabtawi-eyebrow">We are here to help</span>
                        <h1 class="display-4 mt-2 mb-3">Get in touch</h1>
                        <p class="lead mx-auto mb-0">Contact us about products, branches, events, corporate orders, or partnership opportunities.</p>
                    </div>
                </section>

                <section class="anabtawi-section py-5" data-name="Contact form" data-snippet="s_website_form">
                    <div class="container py-4">
                        <div class="row g-5">
                            <div class="col-lg-4">
                                <span class="anabtawi-eyebrow">Contact details</span>
                                <h2 class="h3 mt-2 mb-4">Anabtawi Sweets</h2>
                                <div class="anabtawi-contact-item mb-4">
                                    <i class="fa fa-phone fa-fw" role="presentation"/>
                                    <div><strong>Phone</strong><br/><a href="tel:+962797121121" class="o_force_ltr">+962 7 9712 1121</a></div>
                                </div>
                                <div class="anabtawi-contact-item mb-4">
                                    <i class="fa fa-envelope fa-fw" role="presentation"/>
                                    <div><strong>Email</strong><br/><a href="mailto:info@anabtawisweets.com">info@anabtawisweets.com</a></div>
                                </div>
                                <div class="anabtawi-contact-item mb-4">
                                    <i class="fa fa-map-marker fa-fw" role="presentation"/>
                                    <div><strong>Main branch</strong><br/>Al Madina Al Monawara St.<br/>Amman, Jordan</div>
                                </div>
                                <a href="https://maps.app.goo.gl/zDonDarr9R6AEv2w9" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">Open in Google Maps</a>
                            </div>

                            <div class="col-lg-8">
                                <div class="anabtawi-form-card p-4 p-lg-5">
                                    <h2 class="h3 mb-4">Send us a message</h2>
                                    <form id="contactus_form" action="/website/form/" method="post" enctype="multipart/form-data" class="o_mark_required" data-mark="*" data-model_name="mail.mail" data-success-mode="redirect" data-success-page="/contactus-thank-you" data-pre-fill="true">
                                        <div class="s_website_form_rows row s_col_no_bgcolor">
                                            <div class="mb-3 col-md-6 s_website_form_field s_website_form_custom s_website_form_required" data-type="char" data-name="Name">
                                                <label class="s_website_form_label" for="anabtawi_contact_name">
                                                    <span class="s_website_form_label_content">Name</span><span class="s_website_form_mark"> *</span>
                                                </label>
                                                <input id="anabtawi_contact_name" type="text" class="form-control s_website_form_input" name="name" required="required" data-fill-with="name"/>
                                            </div>
                                            <div class="mb-3 col-md-6 s_website_form_field s_website_form_custom" data-type="char" data-name="Phone">
                                                <label class="s_website_form_label" for="anabtawi_contact_phone"><span class="s_website_form_label_content">Phone number</span></label>
                                                <input id="anabtawi_contact_phone" type="tel" class="form-control s_website_form_input" name="phone" data-fill-with="phone"/>
                                            </div>
                                            <div class="mb-3 col-md-6 s_website_form_field s_website_form_required s_website_form_model_required" data-type="email" data-name="Email">
                                                <label class="s_website_form_label" for="anabtawi_contact_email">
                                                    <span class="s_website_form_label_content">Email</span><span class="s_website_form_mark"> *</span>
                                                </label>
                                                <input id="anabtawi_contact_email" type="email" class="form-control s_website_form_input" name="email_from" required="required" data-fill-with="email"/>
                                            </div>
                                            <div class="mb-3 col-md-6 s_website_form_field s_website_form_custom" data-type="char" data-name="Company">
                                                <label class="s_website_form_label" for="anabtawi_contact_company"><span class="s_website_form_label_content">Company</span></label>
                                                <input id="anabtawi_contact_company" type="text" class="form-control s_website_form_input" name="company" data-fill-with="commercial_company_name"/>
                                            </div>
                                            <div class="mb-3 col-12 s_website_form_field s_website_form_required s_website_form_model_required" data-type="char" data-name="Subject">
                                                <label class="s_website_form_label" for="anabtawi_contact_subject">
                                                    <span class="s_website_form_label_content">Subject</span><span class="s_website_form_mark"> *</span>
                                                </label>
                                                <input id="anabtawi_contact_subject" type="text" class="form-control s_website_form_input" name="subject" required="required"/>
                                            </div>
                                            <div class="mb-3 col-12 s_website_form_field s_website_form_custom s_website_form_required" data-type="text" data-name="Message">
                                                <label class="s_website_form_label" for="anabtawi_contact_message">
                                                    <span class="s_website_form_label_content">Message</span><span class="s_website_form_mark"> *</span>
                                                </label>
                                                <textarea id="anabtawi_contact_message" class="form-control s_website_form_input" name="description" required="required" rows="7"></textarea>
                                            </div>
                                            <div class="mb-3 col-12 s_website_form_field s_website_form_dnone">
                                                <label class="s_website_form_label" for="anabtawi_contact_email_to"><span class="s_website_form_label_content">Email To</span></label>
                                                <input id="anabtawi_contact_email_to" type="hidden" class="form-control s_website_form_input" name="email_to"/>
                                            </div>
                                            <div class="mb-0 pt-2 col-12 s_website_form_submit s_website_form_no_submit_label" data-name="Submit Button">
                                                <a href="#" role="button" class="btn btn-primary btn-lg s_website_form_send">Send message</a>
                                                <span id="s_website_form_result"/>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </xpath>
    </template>
</odoo>
