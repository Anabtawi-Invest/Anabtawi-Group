<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="layout_top_bar" inherit_id="website.layout" name="Anabtawi Sweets - Top Bar">
        <xpath expr="//header" position="before">
            <div class="anabtawi-topbar d-none d-lg-block" data-name="Anabtawi contact bar">
                <div class="container-fluid px-4 px-xl-5">
                    <div class="row align-items-center gy-1 py-2">
                        <div class="col-lg-3">
                            <i class="fa fa-phone fa-fw me-2" role="presentation"/>
                            <a href="tel:+962797121121" class="o_force_ltr">+962 7 9712 1121</a>
                        </div>
                        <div class="col-lg-3">
                            <i class="fa fa-envelope fa-fw me-2" role="presentation"/>
                            <a href="mailto:info@anabtawisweets.com">info@anabtawisweets.com</a>
                        </div>
                        <div class="col-lg-4">
                            <i class="fa fa-map-marker fa-fw me-2" role="presentation"/>
                            <a href="https://maps.app.goo.gl/zDonDarr9R6AEv2w9" target="_blank" rel="noopener noreferrer">
                                Al Madina Al Monawara St., Amman, Jordan
                            </a>
                        </div>
                        <div class="col-lg-2 text-end">
                            <i class="fa fa-globe fa-fw me-2" role="presentation"/>
                            <a href="/our-catalog">Product catalog</a>
                        </div>
                    </div>
                </div>
            </div>
            <nav class="anabtawi-social-rail d-none d-md-flex" aria-label="Anabtawi social media">
                <a class="anabtawi-social-link anabtawi-social-link--whatsapp" href="https://api.whatsapp.com/send?phone=962795212989" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
                    <i class="fa fa-whatsapp" role="presentation"/>
                </a>
                <a class="anabtawi-social-link anabtawi-social-link--facebook" href="https://facebook.com/anabtawisweets/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    <i class="fa fa-facebook" role="presentation"/>
                </a>
                <a class="anabtawi-social-link anabtawi-social-link--twitter" href="https://twitter.com/Anabtawi_Sweets" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
                    <i class="fa fa-twitter" role="presentation"/>
                </a>
                <a class="anabtawi-social-link anabtawi-social-link--linkedin" href="https://www.linkedin.com/company/anabtawi-sweets/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <i class="fa fa-linkedin" role="presentation"/>
                </a>
                <a class="anabtawi-social-link anabtawi-social-link--youtube" href="https://www.youtube.com/channel/UC6gc4a36YIUJ_kbroeenULw" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                    <i class="fa fa-youtube-play" role="presentation"/>
                </a>
                <a class="anabtawi-social-link anabtawi-social-link--instagram" href="https://www.instagram.com/anabtawisweets/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                    <i class="fa fa-instagram" role="presentation"/>
                </a>
            </nav>
        </xpath>
    </template>

    <template id="layout_footer" inherit_id="website.layout" name="Anabtawi Sweets - Footer" priority="50">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="oe_structure oe_structure_solo text-break" t-ignore="true" t-if="not no_footer">
                <footer class="anabtawi-footer" data-name="Anabtawi footer">
                    <div class="container py-5">
                        <div class="row g-4 align-items-start">
                            <div class="col-lg-4">
                                <a href="/" class="d-inline-block mb-3" aria-label="Anabtawi Sweets home">
                                    <img src="/theme_anabtawi_sweets/static/src/img/content/logo.png" alt="Anabtawi Sweets" class="anabtawi-footer-logo" loading="lazy"/>
                                </a>
                                <p class="mb-0">
                                    Distinctive sweets for memorable moments, crafted with care since 1983.
                                </p>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <h2 class="h5 anabtawi-footer-title">Visit us</h2>
                                <p class="mb-3">Al Madina Al Monawara St.<br/>Amman, Jordan</p>
                                <a href="https://maps.app.goo.gl/zDonDarr9R6AEv2w9" target="_blank" rel="noopener noreferrer">Open in Google Maps</a>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <h2 class="h5 anabtawi-footer-title">Contact</h2>
                                <p class="mb-2"><a href="mailto:info@anabtawisweets.com">info@anabtawisweets.com</a></p>
                                <p class="mb-3"><a href="tel:+962797121121" class="o_force_ltr">+962 7 9712 1121</a></p>
                                <a href="/contactus" class="btn btn-outline-light btn-sm">Get in touch</a>
                            </div>
                        </div>
                        <div class="anabtawi-certificates mt-5 pt-4" aria-label="Certifications">
                            <img t-foreach="range(1, 7)" t-as="certificate_index" t-att-src="'/theme_anabtawi_sweets/static/src/img/content/certificate-%s.png' % certificate_index" t-att-alt="'Anabtawi certification %s' % certificate_index" loading="lazy"/>
                        </div>
                    </div>
                    <div class="anabtawi-copyright py-3">
                        <div class="container d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
                            <span>Copyright © Anabtawi Sweets</span>
                            <img src="/theme_anabtawi_sweets/static/src/img/content/paypal.png" alt="Accepted payment methods" class="anabtawi-payment-image" loading="lazy"/>
                        </div>
                    </div>
                </footer>
            </div>
        </xpath>
    </template>
</odoo>
