<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="contact_template" name="Anabtawi Contact Us">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <!-- Page Banner -->
                <section class="anabtawi-page-banner">
                    <div class="container py-3">
                        <h1 class="mb-3" style="color: var(--anabtawi-primary); font-weight: 800; font-family: 'Cairo';">اتصل بنا</h1>
                        <p class="lead text-muted col-md-8 mx-auto" style="font-size: 1.1rem;">
                            يسعدنا سماع استفساراتك واقتراحاتك. تفضل بمراسلتنا أو الاتصال بنا مباشرة.
                        </p>
                    </div>
                </section>

                <!-- Contact Details and Form -->
                <section class="py-5 bg-white text-dark">
                    <div class="container">
                        <div class="row">
                            <!-- Contact Information -->
                            <div class="col-lg-5 mb-5 mb-lg-0 text-end">
                                <h3 class="mb-4" style="color: var(--anabtawi-primary); font-weight: 700; font-family: 'Cairo';">معلومات التواصل</h3>
                                <p class="text-muted mb-5" style="line-height: 1.7;">
                                    فريق دعم العملاء وخدمة التصدير متواجدون لمساعدتك والإجابة على أي أسئلة تتعلق بالطلبات المحلية أو الشحن الدولي.
                                </p>
                                
                                <div class="d-flex align-items-center mb-4">
                                    <div class="rounded-circle bg-light text-center d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; border: 1px solid #efebe9; margin-left: 15px;">
                                        <i class="fa fa-phone" style="color: var(--anabtawi-gold); font-size: 1.25rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1" style="color: var(--anabtawi-primary); font-weight: 600;">رقم الهاتف والاتصال الموحد</h5>
                                        <p class="mb-0 text-muted">+962 7 97121121</p>
                                    </div>
                                </div>
                                
                                <div class="d-flex align-items-center mb-4">
                                    <div class="rounded-circle bg-light text-center d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; border: 1px solid #efebe9; margin-left: 15px;">
                                        <i class="fa fa-envelope" style="color: var(--anabtawi-gold); font-size: 1.25rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1" style="color: var(--anabtawi-primary); font-weight: 600;">البريد الإلكتروني للشركة</h5>
                                        <p class="mb-0 text-muted">info@anabtawisweets.com</p>
                                    </div>
                                </div>
                                
                                <div class="d-flex align-items-center mb-4">
                                    <div class="rounded-circle bg-light text-center d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; border: 1px solid #efebe9; margin-left: 15px;">
                                        <i class="fa fa-map-marker" style="color: var(--anabtawi-gold); font-size: 1.25rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1" style="color: var(--anabtawi-primary); font-weight: 600;">المكتب الرئيسي والإدارة</h5>
                                        <p class="mb-0 text-muted">شارع المدينة المنورة، عمان، الأردن</p>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Contact Form -->
                            <div class="col-lg-7 text-end">
                                <div class="p-4 rounded bg-light border" style="border-color: #efebe9 !important;">
                                    <h3 class="mb-4" style="color: var(--anabtawi-primary); font-weight: 700; font-family: 'Cairo';">أرسل لنا رسالة</h3>
                                    
                                    <form action="#" method="post" class="contact-form">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label" style="color: var(--anabtawi-primary); font-weight: 600;">الاسم الكامل *</label>
                                                <input type="text" class="form-control" style="background-color:#fff !important; border:1px solid #ced4da !important; color:#495057 !important;" placeholder="أدخل اسمك الكريم" required="required" />
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label" style="color: var(--anabtawi-primary); font-weight: 600;">البريد الإلكتروني *</label>
                                                <input type="email" class="form-control" style="background-color:#fff !important; border:1px solid #ced4da !important; color:#495057 !important;" placeholder="example@domain.com" required="required" />
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label" style="color: var(--anabtawi-primary); font-weight: 600;">رقم الهاتف *</label>
                                            <input type="tel" class="form-control" style="background-color:#fff !important; border:1px solid #ced4da !important; color:#495057 !important;" placeholder="+962..." required="required" />
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label" style="color: var(--anabtawi-primary); font-weight: 600;">الموضوع *</label>
                                            <input type="text" class="form-control" style="background-color:#fff !important; border:1px solid #ced4da !important; color:#495057 !important;" placeholder="عنوان رسالتك" required="required" />
                                        </div>
                                        
                                        <div class="mb-4">
                                            <label class="form-label" style="color: var(--anabtawi-primary); font-weight: 600;">نص الرسالة *</label>
                                            <textarea class="form-control" style="background-color:#fff !important; border:1px solid #ced4da !important; color:#495057 !important;" rows="5" placeholder="اكتب هنا تفاصيل استفسارك..." required="required"></textarea>
                                        </div>
                                        
                                        <button type="submit" class="btn btn-more w-100">إرسال الرسالة</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Google Maps Frame -->
                <section class="w-100 p-0 m-0" style="height: 400px; border-top: 1px solid #efebe9;">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3384.341108226046!2d35.85871261516202!3d31.97881198121992!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x151ca1d49137452d%3A0xe51f28b7e2be67eb!2z2K3ZhNmI2KfZqiDYudmG2KjYqtin2YjZig!5e0!3m2!1sar!2sjo!4v1680000000000!5m2!1sar!2sjo" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </section>
            </div>
        </t>
    </template>

    <record id="contactus_page" model="website.page">
        <field name="name">اتصل بنا</field>
        <field name="url">/contactus</field>
        <field name="view_id" ref="contact_template"/>
        <field name="is_published">True</field>
        <field name="website_indexed">True</field>
    </record>
</odoo>
