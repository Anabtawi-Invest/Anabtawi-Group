<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="aboutus_template" name="About Us Anabtawi">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <!-- Page Banner -->
                <section class="anabtawi-page-banner">
                    <div class="container py-3">
                        <h1 class="mb-3" style="color: var(--anabtawi-primary); font-weight: 800; font-family: 'Cairo';">من نحن</h1>
                        <p class="lead text-muted col-md-8 mx-auto" style="font-size: 1.1rem;">
                            تعرف على قصة شغفنا بالحلويات الشرقية ومسيرتنا في تقديم الجودة والأصالة على مدار العقود.
                        </p>
                    </div>
                </section>

                <!-- Core Story Section -->
                <section class="py-5 bg-white">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6 mb-4 mb-lg-0 text-end">
                                <h2 class="mb-4" style="color: var(--anabtawi-primary); font-weight: 700; font-family: 'Cairo';">بداياتنا منذ عام 1984</h2>
                                <p class="mb-3 text-muted" style="line-height: 1.8; font-size: 1.05rem;">
                                    تأسست حلويات عنبتاوي عام 1984 كأحد الرواد في صناعة الحلويات الفاخرة بالأردن. كان الشغف بتقديم المذاق الأصيل هو دافعنا الدائم، حيث اعتمدنا على أجود المكونات الطبيعية والوصفات التقليدية المتوارثة.
                                </p>
                                <p class="mb-4 text-muted" style="line-height: 1.8; font-size: 1.05rem;">
                                    نحرص في كل قطعة حلوى نعدها على نقل إرث شرقي عريق يحاكي الضيافة العربية الكريمة، مدمجاً بأحدث التقنيات وأعلى معايير سلامة الغذاء العالمية لنوفر لكم تجربة لا تنسى.
                                </p>
                            </div>
                            <div class="col-lg-6 text-center">
                                <img src="https://images.unsplash.com/photo-1551024601-bec78aea704b?auto=format&amp;fit=crop&amp;w=600&amp;q=80" alt="تاريخ صناعتنا" class="img-fluid rounded shadow-sm" style="max-width: 90%; border: 1px solid #efebe9;" />
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Mission, Vision & Values -->
                <section class="py-5 bg-anabtawi-gray">
                    <div class="container text-center">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="amazingcarousel-item-container p-4">
                                    <div class="mb-3" style="font-size: 2.5rem; color: var(--anabtawi-gold);"><i class="fa fa-eye"></i></div>
                                    <h3 class="amazingcarousel-title mb-3">رؤيتنا</h3>
                                    <p class="text-muted" style="font-size: 0.95rem; line-height: 1.6;">أن نكون الخيار الأول والوجهة العالمية المفضلة لعشاق الحلويات الشرقية والغربية الفاخرة في جميع أنحاء العالم.</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="amazingcarousel-item-container p-4">
                                    <div class="mb-3" style="font-size: 2.5rem; color: var(--anabtawi-gold);"><i class="fa fa-rocket"></i></div>
                                    <h3 class="amazingcarousel-title mb-3">رسالتنا</h3>
                                    <p class="text-muted" style="font-size: 0.95rem; line-height: 1.6;">تقديم حلويات عالية الجودة بمذاق أصيل لا يُنسى، مع الحفاظ على النكهة التقليدية والابتكار المستمر لإسعاد زبائننا.</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="amazingcarousel-item-container p-4">
                                    <div class="mb-3" style="font-size: 2.5rem; color: var(--anabtawi-gold);"><i class="fa fa-heart"></i></div>
                                    <h3 class="amazingcarousel-title mb-3">قيمنا</h3>
                                    <p class="text-muted" style="font-size: 0.95rem; line-height: 1.6;">الجودة والاتقان، النزاهة والأمانة، الابتكار، وإسعاد العملاء والشركاء والموظفين في كل تفصيل نقوم به.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Milestones Timeline -->
                <section class="py-5 bg-white">
                    <div class="container">
                        <h2 class="title text-center mb-5" style="font-family: 'Cairo';">محطات رئيسية في مسيرتنا</h2>
                        
                        <div class="row">
                            <div class="col-md-3 text-center mb-4">
                                <h1 class="display-4 font-weight-bold" style="color: var(--anabtawi-gold); font-weight: 800;">1984</h1>
                                <h5 class="font-weight-bold" style="color: var(--anabtawi-primary);">التأسيس والبداية</h5>
                                <p class="text-muted" style="font-size: 0.9rem;">افتتاح الفرع الأول في الأردن لتقديم الكنافة النابلسية الشهيرة.</p>
                            </div>
                            <div class="col-md-3 text-center mb-4">
                                <h1 class="display-4 font-weight-bold" style="color: var(--anabtawi-gold); font-weight: 800;">2000</h1>
                                <h5 class="font-weight-bold" style="color: var(--anabtawi-primary);">التوسع المحلي</h5>
                                <p class="text-muted" style="font-size: 0.9rem;">الوصول إلى 10 فروع داخل الأردن وتوسيع خطوط المنتجات لتشمل الكيك الغربي.</p>
                            </div>
                            <div class="col-md-3 text-center mb-4">
                                <h1 class="display-4 font-weight-bold" style="color: var(--anabtawi-gold); font-weight: 800;">2015</h1>
                                <h5 class="font-weight-bold" style="color: var(--anabtawi-primary);">تصدير دولي</h5>
                                <p class="text-muted" style="font-size: 0.9rem;">إطلاق خط الشحن الدولي والتصدير لأكثر من 40 دولة في الخليج، أوروبا وأمريكا.</p>
                            </div>
                            <div class="col-md-3 text-center mb-4">
                                <h1 class="display-4 font-weight-bold" style="color: var(--anabtawi-gold); font-weight: 800;">2026</h1>
                                <h5 class="font-weight-bold" style="color: var(--anabtawi-primary);">العصر الرقمي الجديد</h5>
                                <p class="text-muted" style="font-size: 0.9rem;">إطلاق منصة الطلب والتصدير المتكاملة المعتمدة على أحدث التقنيات البرمجية.</p>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <record id="aboutus_page" model="website.page">
        <field name="name">من نحن</field>
        <field name="url">/aboutus</field>
        <field name="view_id" ref="aboutus_template"/>
        <field name="is_published">True</field>
        <field name="website_indexed">True</field>
    </record>
</odoo>
