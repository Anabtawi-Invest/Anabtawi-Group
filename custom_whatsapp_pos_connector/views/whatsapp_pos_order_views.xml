<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whatsapp_pos_order_tree" model="ir.ui.view">
        <field name="name">whatsapp.pos.order.tree</field>
        <field name="model">whatsapp.pos.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="phone_number"/>
                <field name="state"/>
                <field name="pos_config_id"/>
                <field name="total_amount"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_whatsapp_pos_order_form" model="ir.ui.view">
        <field name="name">whatsapp.pos.order.form</field>
        <field name="model">whatsapp.pos.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_loaded" string="Mark Loaded" type="object" invisible="state != 'ready_for_pos'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready_for_pos,loaded,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="phone_number"/>
                        </group>
                        <group>
                            <field name="pos_config_id"/>
                            <field name="pos_session_id" readonly="1"/>
                            <field name="total_amount" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_whatsapp_pos_conversation_tree" model="ir.ui.view">
        <field name="name">whatsapp.pos.conversation.tree</field>
        <field name="model">whatsapp.pos.conversation</field>
        <field name="arch" type="xml">
            <list>
                <field name="phone_number"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="last_message_at"/>
            </list>
        </field>
    </record>

    <record id="action_whatsapp_pos_orders" model="ir.actions.act_window">
        <field name="name">WhatsApp POS Orders</field>
        <field name="res_model">whatsapp.pos.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_whatsapp_pos_conversations" model="ir.actions.act_window">
        <field name="name">WhatsApp Conversations</field>
        <field name="res_model">whatsapp.pos.conversation</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
