<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_check_layout_list" model="ir.ui.view">
        <field name="name">account.check.layout.list</field>
        <field name="model">account.check.layout</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="paper_width"/>
                <field name="paper_height"/>
                <field name="dpi"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_account_check_layout_form" model="ir.ui.view">
        <field name="name">account.check.layout.form</field>
        <field name="model">account.check.layout</field>
        <field name="arch" type="xml">
            <form string="Check Layout">
                <header>
                    <button
                        name="action_open_designer"
                        type="object"
                        string="Open Visual Designer"
                        class="oe_highlight"
                        icon="fa-object-group"
                    />
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Arab Bank Standard Check"/></h1>
                    </div>
                    <group>
                        <group string="Paper">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="paper_width"/>
                            <field name="paper_height"/>
                            <field name="dpi"/>
                            <field name="font_size"/>
                            <field name="active" invisible="1"/>
                            <field name="paperformat_id" invisible="1"/>
                        </group>
                        <group string="Artwork">
                            <field name="background_image" filename="background_filename" widget="image"/>
                            <field name="background_filename" invisible="1"/>
                            <field name="logo_image" widget="image"/>
                            <field name="signature_image" widget="image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Text Fields" name="text_geometry">
                            <group col="4">
                                <separator string="Date" colspan="4"/>
                                <field name="date_x"/><field name="date_y"/>
                                <field name="date_width"/><field name="date_height"/>
                                <separator string="Payee" colspan="4"/>
                                <field name="payee_x"/><field name="payee_y"/>
                                <field name="payee_width"/><field name="payee_height"/>
                                <separator string="Numeric Amount" colspan="4"/>
                                <field name="amount_x"/><field name="amount_y"/>
                                <field name="amount_width"/><field name="amount_height"/>
                                <separator string="Amount in Words" colspan="4"/>
                                <field name="amount_words_x"/><field name="amount_words_y"/>
                                <field name="amount_words_width"/><field name="amount_words_height"/>
                                <separator string="Memo" colspan="4"/>
                                <field name="memo_x"/><field name="memo_y"/>
                                <field name="memo_width"/><field name="memo_height"/>
                                <separator string="Check Number" colspan="4"/>
                                <field name="check_number_x"/><field name="check_number_y"/>
                                <field name="check_number_width"/><field name="check_number_height"/>
                            </group>
                        </page>
                        <page string="Images" name="image_geometry">
                            <group col="4">
                                <separator string="Logo" colspan="4"/>
                                <field name="logo_x"/><field name="logo_y"/>
                                <field name="logo_width"/><field name="logo_height"/>
                                <separator string="Signature" colspan="4"/>
                                <field name="signature_x"/><field name="signature_y"/>
                                <field name="signature_width"/><field name="signature_height"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_account_check_layout_search" model="ir.ui.view">
        <field name="name">account.check.layout.search</field>
        <field name="model">account.check.layout</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_account_check_layout" model="ir.actions.act_window">
        <field name="name">Check Layouts</field>
        <field name="res_model">account.check.layout</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>

