<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_check_print" model="ir.ui.view">
        <field name="name">account.payment.form.check.print</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="can_print_check" invisible="1"/>
                <field name="can_preview_check" invisible="1"/>
                <button
                    name="action_print_check" type="object" string="Print Check"
                    class="oe_highlight" icon="fa-print"
                    groups="account.group_account_manager"
                    invisible="not can_print_check or printed or voided"
                />
                <button
                    name="action_preview_check" type="object" string="Preview Check"
                    icon="fa-eye" groups="account.group_account_user"
                    invisible="not can_preview_check or voided"
                />
                <button
                    name="action_open_reprint_wizard" type="object" string="Reprint Check"
                    icon="fa-copy" groups="account.group_account_manager"
                    invisible="not can_print_check or not printed or voided"
                />
                <button
                    name="action_open_void_wizard" type="object" string="Void Check"
                    icon="fa-ban" groups="account.group_account_manager"
                    invisible="not can_print_check or not printed or voided"
                />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_check_history" type="object"
                    class="oe_stat_button" icon="fa-history"
                    groups="account.group_account_user"
                    invisible="not check_history_count"
                >
                    <field name="check_history_count" widget="statinfo" string="Check History"/>
                </button>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group string="Business Check" invisible="not check_number">
                    <group>
                        <field name="check_number"/>
                        <field name="printed"/>
                        <field name="voided"/>
                    </group>
                    <group>
                        <field name="printed_date"/>
                        <field name="printed_by"/>
                        <field name="reprinted_count"/>
                    </group>
                    <field name="check_layout_snapshot" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_account_payment_list_check_print" model="ir.ui.view">
        <field name="name">account.payment.list.check.print</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="check_number" optional="show"/>
                <field name="printed" optional="hide"/>
                <field name="voided" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>

