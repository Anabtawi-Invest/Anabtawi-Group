<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_check_print_history_list" model="ir.ui.view">
        <field name="name">account.check.print.history.list</field>
        <field name="model">account.check.print.history</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="event_date"/>
                <field name="check_number"/>
                <field name="event_type"/>
                <field name="payment_id"/>
                <field name="journal_id"/>
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="reason" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_account_check_print_history_form" model="ir.ui.view">
        <field name="name">account.check.print.history.form</field>
        <field name="model">account.check.print.history</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="payment_id"/>
                            <field name="check_number"/>
                            <field name="event_type"/>
                        </group>
                        <group>
                            <field name="event_date"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Reason" invisible="not reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_account_check_print_history" model="ir.actions.act_window">
        <field name="name">Check History</field>
        <field name="res_model">account.check.print.history</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
    </record>
</odoo>

