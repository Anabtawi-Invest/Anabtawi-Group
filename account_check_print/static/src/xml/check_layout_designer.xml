<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="account_check_print.CheckLayoutDesigner">
        <div class="o_check_layout_designer h-100 d-flex flex-column">
            <div class="o_check_designer_toolbar d-flex align-items-center gap-2 px-3 py-2 border-bottom bg-white">
                <button class="btn btn-primary" t-on-click="save" t-att-disabled="state.saving">
                    <i class="fa fa-save me-1"/> Save
                </button>
                <label class="btn btn-outline-secondary mb-0">
                    <i class="fa fa-upload me-1"/> Upload Blank Check
                    <input class="d-none" type="file" accept="image/*" t-on-change="uploadBackground"/>
                </label>
                <button class="btn btn-outline-secondary" t-on-click="toggleGuides">
                    <i class="fa fa-eye me-1"/>
                    <t t-out="state.showGuides ? 'Hide Guides' : 'Show Guides'"/>
                </button>
                <span class="ms-auto fw-bold" t-out="state.name"/>
                <button class="btn btn-outline-secondary" t-on-click="close">Close</button>
            </div>

            <div t-if="state.loading" class="d-flex flex-grow-1 align-items-center justify-content-center">
                <i class="fa fa-spinner fa-spin fa-2x"/>
            </div>
            <div t-else="" class="o_check_designer_body d-flex flex-grow-1 overflow-hidden">
                <aside class="o_check_designer_sidebar border-end bg-white p-3 overflow-auto">
                    <h5>Fields</h5>
                    <p class="text-muted small">Drag fields on the check. Use the corner handle to resize.</p>
                    <div class="list-group mb-3">
                        <button
                            t-foreach="fieldEntries" t-as="field" t-key="field.name"
                            t-att-class="'list-group-item list-group-item-action ' + (state.selected === field.name ? 'active' : '')"
                            t-on-click="() => this.selectField(field.name)"
                        >
                            <t t-out="field.label"/>
                        </button>
                    </div>
                    <t t-foreach="fieldEntries" t-as="field" t-key="field.name">
                        <div t-if="state.selected === field.name" class="row g-2">
                            <div t-foreach="['x', 'y', 'width', 'height']" t-as="key" t-key="key" class="col-6">
                                <label class="form-label text-uppercase small" t-out="key + ' (mm)'"/>
                                <input
                                    class="form-control form-control-sm" type="number" min="0" step="0.1"
                                    t-att-value="field.geometry[key]"
                                    t-on-change="(ev) => this.updateGeometry(field.name, key, ev)"
                                />
                            </div>
                        </div>
                    </t>
                </aside>

                <main class="o_check_designer_workspace flex-grow-1 overflow-auto p-4">
                    <div
                        class="o_check_designer_canvas mx-auto"
                        t-att-class="state.showGuides ? 'o_check_designer_canvas mx-auto show-guides' : 'o_check_designer_canvas mx-auto'"
                        t-att-style="canvasStyle()" t-ref="canvas"
                    >
                        <img
                            t-if="state.backgroundUrl" class="o_check_designer_background"
                            t-att-src="state.backgroundUrl" alt="Blank check"
                        />
                        <div
                            t-foreach="fieldEntries" t-as="field" t-key="field.name"
                            t-att-class="'o_check_designer_field ' + (state.selected === field.name ? 'selected' : '')"
                            t-att-style="fieldStyle(field)"
                            t-on-pointerdown="(ev) => this.startPointerTracking(ev, field.name, 'move')"
                        >
                            <span t-out="field.sample"/>
                            <span
                                class="o_check_designer_resize_handle"
                                t-on-pointerdown="(ev) => this.startPointerTracking(ev, field.name, 'resize')"
                            />
                        </div>
                    </div>
                    <div class="text-center text-muted mt-3 small">
                        Live preview — <t t-out="state.paperWidth"/> × <t t-out="state.paperHeight"/> mm
                    </div>
                </main>
            </div>
        </div>
    </t>
</templates>

