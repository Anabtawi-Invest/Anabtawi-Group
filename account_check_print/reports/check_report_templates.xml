<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_check_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="layout" t-value="o.journal_id.check_layout_id"/>
                <t t-set="geometry" t-value="o.check_layout_values()"/>
                <article
                    class="o_check_print_page"
                    t-att-data-oe-model="o._name"
                    t-att-data-oe-id="o.id"
                    t-att-style="'position:relative;margin:0;padding:0;overflow:hidden;width:%smm;height:%smm;font-family:Arial, sans-serif;' % (geometry['paper_width'], geometry['paper_height'])"
                >
                    <img
                        t-if="o.journal_id.stock_type == 'blank' and layout.background_image"
                        t-att-src="image_data_uri(layout.background_image)"
                        alt="Check background"
                        t-att-style="'position:absolute;left:0;top:0;width:%smm;height:%smm;z-index:0;' % (geometry['paper_width'], geometry['paper_height'])"
                    />
                    <div
                        t-if="o.env.context.get('check_preview')"
                        style="position:absolute;left:15%;top:35%;width:70%;text-align:center;transform:rotate(-20deg);font-size:32pt;font-weight:bold;color:rgba(180,0,0,.22);z-index:5;"
                    >PREVIEW</div>

                    <div t-att-style="o.check_field_style('check_number') + 'z-index:2;text-align:right;font-weight:bold;'">
                        <span t-out="o.check_number or 'PREVIEW'"/>
                    </div>
                    <div t-att-style="o.check_field_style('date') + 'z-index:2;text-align:center;'">
                        <span t-out="o.date.strftime('%d/%m/%Y') if o.date else ''"/>
                    </div>
                    <div
                        t-att-dir="'rtl' if o.journal_id.print_language == 'ar' else 'ltr'"
                        t-att-style="o.check_field_style('payee') + 'z-index:2;font-weight:bold;'"
                    >
                        <span t-out="o.check_payee_name()"/>
                    </div>
                    <div t-att-style="o.check_field_style('amount') + 'z-index:2;text-align:right;font-weight:bold;'">
                        <span t-out="o.check_formatted_amount()"/>
                    </div>
                    <div
                        t-att-dir="'rtl' if o.journal_id.print_language == 'ar' else 'ltr'"
                        t-att-style="o.check_field_style('amount_words') + 'z-index:2;'"
                    >
                        <span t-out="o.check_amount_in_words()"/>
                    </div>
                    <div
                        t-att-dir="'rtl' if o.journal_id.print_language == 'ar' else 'ltr'"
                        t-att-style="o.check_field_style('memo') + 'z-index:2;'"
                    >
                        <span t-out="o.memo or o.payment_reference or ''"/>
                    </div>
                    <div t-att-style="o.check_field_style('logo') + 'z-index:2;'">
                        <img
                            t-if="layout.logo_image"
                            t-att-src="image_data_uri(layout.logo_image)"
                            alt="Logo"
                            style="max-width:100%;max-height:100%;"
                        />
                    </div>
                    <div t-att-style="o.check_field_style('signature') + 'z-index:2;text-align:center;'">
                        <img
                            t-if="layout.signature_image"
                            t-att-src="image_data_uri(layout.signature_image)"
                            alt="Signature"
                            style="max-width:100%;max-height:100%;"
                        />
                    </div>
                    <div
                        t-if="o.voided"
                        style="position:absolute;left:15%;top:38%;width:70%;text-align:center;transform:rotate(-20deg);font-size:36pt;font-weight:bold;color:rgba(180,0,0,.35);z-index:6;"
                    >VOID</div>
                </article>
            </t>
        </t>
    </template>
</odoo>
