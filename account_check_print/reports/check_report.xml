<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_check" model="ir.actions.report">
        <field name="name">Business Check</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_check_print.report_check_document</field>
        <field name="report_file">account_check_print.report_check_document</field>
        <field name="paperformat_id" ref="paperformat_check_default"/>
        <field name="multi" eval="True"/>
        <field name="group_ids" eval="[(4, ref('account.group_account_user'))]"/>
        <field name="print_report_name">'Check - %s' % (object.check_number or 'Preview')</field>
    </record>
</odoo>

