<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_check_void_wizard_form" model="ir.ui.view">
        <field name="name">account.check.void.wizard.form</field>
        <field name="model">account.check.void.wizard</field>
        <field name="arch" type="xml">
            <form string="Void Check">
                <group>
                    <field name="payment_id"/>
                    <field name="check_number"/>
                    <field name="reason" placeholder="Explain why this check must be voided..."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Void Check" class="btn-danger"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

