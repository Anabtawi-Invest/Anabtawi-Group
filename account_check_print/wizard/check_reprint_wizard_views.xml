<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_check_reprint_wizard_form" model="ir.ui.view">
        <field name="name">account.check.reprint.wizard.form</field>
        <field name="model">account.check.reprint.wizard</field>
        <field name="arch" type="xml">
            <form string="Reprint Check">
                <group>
                    <field name="payment_id"/>
                    <field name="check_number"/>
                    <field name="reason" placeholder="Explain why another copy is required..."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Reprint" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

