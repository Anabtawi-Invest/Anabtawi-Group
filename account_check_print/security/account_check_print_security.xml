<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_check_layout_company" model="ir.rule">
        <field name="name">Check layouts by company</field>
        <field name="model_id" ref="model_account_check_layout"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="rule_check_history_company" model="ir.rule">
        <field name="name">Check history by company</field>
        <field name="model_id" ref="model_account_check_print_history"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
    </record>
</odoo>

