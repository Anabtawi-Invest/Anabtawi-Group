<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_transfer_driver_action" model="ir.actions.act_window">
        <field name="name">Truck Drivers</field>
        <field name="res_model">stock.transfer.driver</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_stock_transfer_driver_config"
        name="Truck Drivers"
        parent="stock.menu_warehouse_config"
        action="stock_transfer_driver_action"
        sequence="9"
        groups="stock.group_stock_manager"
    />

    <record id="stock_transfer_driver_view_tree" model="ir.ui.view">
        <field name="name">stock.transfer.driver.list</field>
        <field name="model">stock.transfer.driver</field>
        <field name="arch" type="xml">
            <list string="Truck Drivers" editable="bottom">
                <field name="employee_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="is_blocked"/>
            </list>
        </field>
    </record>

    <record id="stock_transfer_driver_view_form" model="ir.ui.view">
        <field name="name">stock.transfer.driver.form</field>
        <field name="model">stock.transfer.driver</field>
        <field name="arch" type="xml">
            <form string="Truck Driver">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="is_blocked" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
