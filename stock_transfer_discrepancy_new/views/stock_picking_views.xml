<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Internal: full internal domain; open-discrepancy blocking is on driver, not location. -->
    <record id="stock_picking_view_form_inherit_truck_discrepancy" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.truck.discrepancy</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id' and contains(@groups, 'stock.group_stock_multi_locations')][1]" position="replace">
                <field
                    name="location_id"
                    options="{'no_create': True}"
                    string="From"
                    groups="stock.group_stock_multi_locations"
                    readonly="state == 'done'"
                    invisible="picking_type_code != 'internal'"
                    domain="[('usage', '=', 'internal')]"
                />
                <field
                    name="location_id"
                    options="{'no_create': True}"
                    string="From"
                    groups="stock.group_stock_multi_locations"
                    readonly="state == 'done'"
                    invisible="picking_type_code in ('incoming', 'internal')"
                />
            </xpath>
            <xpath expr="//sheet//field[@name='location_dest_id' and @groups='stock.group_stock_multi_locations']" position="attributes">
                <attribute name="domain">[('usage', '=', 'internal')]</attribute>
            </xpath>
            <xpath expr="//field[@name='backorder_id']" position="after">
                <field name="destination_is_truck" invisible="1"/>
                <field
                    name="driver_id"
                    invisible="picking_type_code != 'internal'"
                    required="picking_type_code == 'internal' and destination_is_truck"
                    readonly="state == 'done'"
                />
            </xpath>
        </field>
    </record>
</odoo>
