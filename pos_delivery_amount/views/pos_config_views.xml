<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_pos_config_form_delivery_amount" model="ir.ui.view">
            <field name="name">pos.config.form.delivery.amount</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet" position="inside">
                    <separator string="Delivery Amount Settings"/>
                    <group string="Delivery Amount" name="delivery_amount_config_group">
                        <field name="delivery_intermediate_account_id" options="{'no_create': True}" help="Temporary holding account for undeposited cash pending bank delivery."/>
                        <field name="delivery_journal_id" options="{'no_create': True}" domain="[('type', '=', 'general')]" help="Miscellaneous journal used to post the delivery amount accounting entry."/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
