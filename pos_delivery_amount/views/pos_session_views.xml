<?xml version="1.0" encoding="UTF-8"?>
<!-- pos_delivery_amount/views/pos_session_views.xml -->

<odoo>
    <data>

        <!-- ── Inherit POS Session Form – add read-only delivery fields ── -->
        <record id="view_pos_session_form_delivery_amount" model="ir.ui.view">
            <field name="name">pos.session.form.delivery.amount</field>
            <field name="model">pos.session</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='closing_control']" position="inside">
                    <separator string="Delivery Amount"/>
                    <group name="delivery_amount_summary">
                        <field name="delivery_amount" readonly="1"/>
                        <field
                            name="delivery_move_id"
                            readonly="1"
                            widget="many2one_avatar"
                            options="{'no_create': True}"
                        />
                    </group>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
