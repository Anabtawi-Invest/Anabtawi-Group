<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_delivery_amount_report_tree" model="ir.ui.view">
        <field name="name">pos.delivery.amount.report.tree</field>
        <field name="model">pos.delivery.amount.report</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="name"/>
                <field name="creation_date"/>
                <field name="total_delivery_amount" widget="monetary"/>
                <field name="total_real_arrived_amount" widget="monetary"/>
                <field name="total_difference" widget="monetary"/>
                <field name="state" widget="badge"/>
                <button name="action_transfer_all" type="object" string="Transfer" class="btn-primary" invisible="state == 'transferred'"/>
            </list>
        </field>
    </record>

    <record id="view_pos_delivery_amount_report_form" model="ir.ui.view">
        <field name="name">pos.delivery.amount.report.form</field>
        <field name="model">pos.delivery.amount.report</field>
        <field name="arch" type="xml">
            <form create="0">
                <header>
                    <button name="action_transfer_all" type="object" string="Transfer" class="btn-primary" invisible="state == 'transferred'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,transferred"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="creation_date" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="total_delivery_amount" widget="monetary" readonly="1"/>
                        <field name="total_real_arrived_amount" widget="monetary" readonly="1"/>
                        <field name="total_difference" widget="monetary" readonly="1"/>
                    </group>
                    <field name="line_ids" nolabel="1">
                        <list editable="bottom" create="0" delete="0">
                            <field name="session_id" string="Session Number" readonly="1"/>
                            <field name="pos_config_id" string="Point of Sale Name" readonly="1"/>
                            <field name="delivery_amount" widget="monetary" readonly="1"/>
                            <field name="real_arrived_amount" readonly="state == 'transferred'"/>
                            <field name="difference" widget="monetary" readonly="1"/>
                            <field name="settlement_move_id" readonly="1"/>
                            <field name="state" widget="badge"/>
                            <button name="action_transfer" type="object" string="Transfer" class="btn-primary" invisible="state == 'transferred'"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_delivery_amount_report_search" model="ir.ui.view">
        <field name="name">pos.delivery.amount.report.search</field>
        <field name="model">pos.delivery.amount.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="creation_date"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Transferred" name="transferred" domain="[('state', '=', 'transferred')]"/>
            </search>
        </field>
    </record>

    <record id="action_pos_delivery_amount_report" model="ir.actions.act_window">
        <field name="name">Delivery Amount Report</field>
        <field name="res_model">pos.delivery.amount.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pos_delivery_amount_report_search"/>
        <field name="context">{}</field>
    </record>

    <record id="action_pos_delivery_amount_report_generate" model="ir.actions.server">
        <field name="name">Generate Delivery Amount Reports</field>
        <field name="model_id" ref="model_pos_delivery_amount_report"/>
        <field name="state">code</field>
        <field name="code">
model.action_generate_reports()
action = {
    "type": "ir.actions.act_window",
    "name": "Delivery Amount Report",
    "res_model": "pos.delivery.amount.report",
    "view_mode": "list,form",
    "target": "current",
}
        </field>
    </record>

    <menuitem id="menu_pos_delivery_amount_report"
              name="Delivery Amount Report"
              parent="account.menu_finance_entries"
              action="action_pos_delivery_amount_report"
              groups="account.group_account_readonly,account.group_account_invoice,account.group_account_manager"
              sequence="90"/>

    <menuitem id="menu_pos_delivery_amount_report_generate"
              name="Generate Reports"
              parent="account.menu_finance_entries"
              action="action_pos_delivery_amount_report_generate"
              groups="account.group_account_readonly,account.group_account_invoice,account.group_account_manager"
              sequence="91"/>
</odoo>
