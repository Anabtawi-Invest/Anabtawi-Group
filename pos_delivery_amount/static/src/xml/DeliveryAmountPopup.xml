<?xml version="1.0" encoding="UTF-8"?>
<!-- pos_delivery_amount/static/src/xml/DeliveryAmountPopup.xml -->

<templates>

    <t t-name="pos_delivery_amount.DeliveryAmountPopup">
        <div class="popup delivery-amount-popup">

            <!-- ── Header ─────────────────────────────────────────────── -->
            <div class="popup-header">
                <h2 class="popup-title">
                    <t t-esc="props.title"/>
                </h2>
            </div>

            <!-- ── Body ──────────────────────────────────────────────── -->
            <div class="popup-body">

                <!-- Cash balance reference -->
                <div class="cash-balance-info mb-3">
                    <span class="text-muted">
                        Available Cash Balance:
                        <strong>
                            <t t-esc="props.cashBalance ? props.cashBalance.toFixed(2) : '0.00'"/>
                        </strong>
                    </span>
                </div>

                <!-- Amount input -->
                <div class="input-group delivery-amount-input-group">
                    <label class="form-label fw-bold" for="delivery_amount_input">
                        Delivery Amount
                    </label>
                    <input
                        id="delivery_amount_input"
                        type="number"
                        class="form-control delivery-amount-input"
                        t-att-value="state.deliveryAmount"
                        t-on-input="onAmountInput"
                        min="0"
                        step="0.01"
                        placeholder="0.00"
                        autofocus="autofocus"
                    />
                </div>

                <!-- Validation error message -->
                <div t-if="state.validationError" class="delivery-amount-error mt-2">
                    <span class="text-danger">
                        <t t-esc="state.validationError"/>
                    </span>
                </div>

            </div>

            <!-- ── Footer / Buttons ───────────────────────────────────── -->
            <div class="popup-footer">
                <button
                    class="btn btn-secondary delivery-btn-cancel"
                    t-on-click="cancel"
                >
                    Cancel
                </button>
                <button
                    class="btn btn-primary delivery-btn-confirm"
                    t-on-click="confirm"
                >
                    Confirm
                </button>
            </div>

        </div>
    </t>

</templates>
