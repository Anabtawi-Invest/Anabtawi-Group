#. Model: pos.config / Field: delivery_intermediate_account_id
msgid "Intermediate Account"
msgstr "الحساب الوسيط"

#. Model: pos.config / Field: delivery_journal_id
msgid "Delivery Journal"
msgstr "دفتر يومية التوريد"

#. Model: pos.session / Field: delivery_amount
msgid "Delivery Amount"
msgstr "مبلغ التوريد"

#. Model: pos.session / Field: delivery_move_id
msgid "Delivery Journal Entry"
msgstr "قيد يومية التوريد"

#. UI: Popup title
msgid "Delivery Amount"
msgstr "مبلغ التوريد"

#. UI: Available cash balance label
msgid "Available Cash Balance:"
msgstr "الرصيد النقدي المتاح:"

#. UI: Input label
msgid "Delivery Amount"
msgstr "مبلغ التوريد"

#. UI: Confirm button
msgid "Confirm"
msgstr "تأكيد"

#. UI: Cancel button
msgid "Cancel"
msgstr "إلغاء"

#. UI: Zero confirmation popup title
msgid "Confirm Zero Amount"
msgstr "تأكيد مبلغ صفر"

#. UI: Zero confirmation popup body
msgid "Are you sure the Delivery Amount is zero?"
msgstr "هل أنت متأكد أن مبلغ التوريد يساوي صفر؟"

#. UI: Yes button
msgid "Yes"
msgstr "نعم"

#. UI: No button
msgid "No"
msgstr "لا"

#. Validation: amount exceeds cash balance
msgid "Delivery Amount cannot exceed counted cash balance."
msgstr "لا يمكن أن يكون مبلغ التوريد أكبر من الرصيد النقدي الفعلي."

#. Validation: negative amount
msgid "Delivery Amount cannot be negative."
msgstr "لا يمكن أن يكون مبلغ التوريد سالباً."

#. Validation: intermediate account missing
msgid "Intermediate Account is not configured on the POS settings. Please configure it before closing the session."
msgstr "لم يتم تكوين الحساب الوسيط في إعدادات نقطة البيع. يرجى تكوينه قبل إغلاق الجلسة."

#. Validation: delivery journal missing
msgid "Delivery Journal is not configured on the POS settings. Please configure it before closing the session."
msgstr "لم يتم تكوين دفتر يومية التوريد في إعدادات نقطة البيع. يرجى تكوينه قبل إغلاق الجلسة."

#. Validation: POS session not found
msgid "POS session not found."
msgstr "لم يتم العثور على جلسة نقطة البيع."

#. Validation: invalid amount value
msgid "Invalid delivery amount value."
msgstr "قيمة مبلغ التوريد غير صالحة."

#. Accounting: journal entry label
msgid "Deliver Amount From %(pos)s - %(date)s"
msgstr "توريد المبلغ من %(pos)s - %(date)s"

#. Chatter: success heading
msgid "Delivery Amount processed successfully."
msgstr "تمت معالجة مبلغ التوريد بنجاح."

#. Chatter: no journal entry note
msgid "No journal entry (amount is zero)"
msgstr "لا يوجد قيد يومية (المبلغ يساوي صفر)"

#. Chatter: amount label
msgid "Amount:"
msgstr "المبلغ:"

#. Chatter: user label
msgid "Processed by:"
msgstr "تمت المعالجة بواسطة:"

#. Chatter: journal entry label
msgid "Journal Entry:"
msgstr "قيد اليومية:"

#. Chatter: datetime label
msgid "Date & Time:"
msgstr "التاريخ والوقت:"

#. UI: Error popup title
msgid "Error"
msgstr "خطأ"

#. UI: Unexpected server error
msgid "An unexpected server error occurred. Session closing aborted."
msgstr "حدث خطأ غير متوقع في الخادم. تم إيقاف إغلاق الجلسة."

#. Backend: journal entry creation failure
msgid "Journal entry creation failed. Session closing aborted."
msgstr "فشل إنشاء قيد اليومية. تم إيقاف إغلاق الجلسة."

#. Backend: no cash payment method
msgid "No cash payment method found for this POS configuration."
msgstr "لم يتم العثور على طريقة دفع نقدي لتكوين نقطة البيع هذا."

#. Backend: no cash account
msgid "No default account configured on the cash journal \"%s\"."
msgstr "لم يتم تكوين حساب افتراضي في دفتر يومية النقد \"%s\"."

#. View: section separator
msgid "Delivery Amount Settings"
msgstr "إعدادات مبلغ التوريد"

#. View: group label
msgid "Delivery Amount"
msgstr "مبلغ التوريد"

#. View: closing control separator
msgid "Delivery Amount"
msgstr "مبلغ التوريد"
