<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_pos_debt" model="ir.ui.view">
        <field name="name">hr.employee.form.pos.debt</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_contact_id']" position="after">
                <field name="pos_debt_partner_id"/>
                <field name="pos_debt_monthly_limit"/>
            </xpath>
        </field>
    </record>
</odoo>
