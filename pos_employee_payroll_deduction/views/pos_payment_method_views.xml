<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_payment_method_form_payroll_due" model="ir.ui.view">
        <field name="name">pos.payment.method.form.payroll.due</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="is_payroll_due_method" invisible="type != 'pay_later'"/>
            </xpath>
        </field>
    </record>
</odoo>
