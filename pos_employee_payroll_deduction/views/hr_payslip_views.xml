<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_pos_debt" model="ir.ui.view">
        <field name="name">hr.payslip.form.pos.debt</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="termination_clearance"/>
            </xpath>
            <xpath expr="//field[@name='input_line_ids']" position="before">
                <group string="POS Debt">
                    <field name="pos_debt_total_open" readonly="1"/>
                    <field name="pos_debt_deduction_amount" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
