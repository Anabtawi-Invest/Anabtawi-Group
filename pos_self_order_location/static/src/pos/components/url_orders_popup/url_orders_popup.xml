<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order_location.UrlOrdersPopup">
        <Dialog title.translate="URL Self-Orders" size="'lg'" footer="false">
            <div class="d-flex flex-column gap-3">
                <div t-if="state.loading" class="text-center py-4 text-muted">
                    Loading...
                </div>
                <div t-elif="state.requests.length === 0" class="text-center py-4 text-muted">
                    No open URL self-orders.
                </div>
                <t t-else="">
                    <div t-foreach="state.requests" t-as="request" t-key="request.id"
                        class="border rounded-3 p-3">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-bold" t-esc="request.name"/>
                                <div class="text-muted small">
                                    <t t-if="request.tracking_number" t-esc="request.tracking_number"/>
                                    <t t-if="request.pos_reference"> · <t t-esc="request.pos_reference"/></t>
                                </div>
                                <div class="mt-2 d-flex flex-wrap align-items-center gap-2">
                                    <span class="badge text-bg-secondary" t-esc="formatState(request.state)"/>
                                    <span t-if="request.payment_preference"
                                        class="badge"
                                        t-att-class="formatPaymentBadgeClass(request)"
                                        t-esc="formatPaymentBadge(request)"/>
                                    <span class="fw-bold" t-esc="formatAmount(request)"/>
                                </div>
                            </div>
                            <div class="d-flex flex-wrap gap-2 justify-content-end">
                                <button class="btn btn-secondary btn-sm" t-if="request.location_url"
                                    t-on-click="() => this.openMap(request)">
                                    Map
                                </button>
                                <button class="btn btn-primary btn-sm" t-if="request.state === 'new'"
                                    t-on-click="() => this.acceptRequest(request)">
                                    Accept
                                </button>
                                <button class="btn btn-success btn-sm"
                                    t-if="request.state === 'new' || request.state === 'accepted'"
                                    t-on-click="() => this.doneRequest(request)">
                                    Done
                                </button>
                            </div>
                        </div>
                        <pre t-if="request.line_summary" class="mt-3 mb-0 small bg-light rounded p-2" t-esc="request.line_summary"/>
                        <div t-if="request.customer_latitude and request.customer_longitude" class="small text-muted mt-2">
                            <t t-esc="request.customer_latitude"/> , <t t-esc="request.customer_longitude"/>
                        </div>
                    </div>
                </t>
                <div class="d-flex justify-content-end">
                    <button class="btn btn-secondary" t-on-click="() => this.loadRequests()">Refresh</button>
                    <button class="btn btn-primary ms-2" t-on-click="props.close">Close</button>
                </div>
            </div>
        </Dialog>
    </t>
</templates>
