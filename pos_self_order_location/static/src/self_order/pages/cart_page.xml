<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="pos_self_order.CartPage" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('cart_container')]//h1" position="after">
            <div t-if="showOrderStatusBanner" class="ms-3 ms-sm-0 mb-3">
                <div class="alert mb-0 d-flex flex-column gap-2" t-att-class="orderStatusAlertClass" role="status">
                    <strong t-esc="orderStatusTitle"/>
                    <span t-esc="orderStatusMessage"/>
                </div>
            </div>
            <div t-if="requiresCustomerPhone and !isOrderLocked" class="ms-3 ms-sm-0 mb-3">
                <div class="alert alert-light border mb-0">
                    <strong>Your phone number</strong>
                    <div class="text-muted mb-3">Enter your phone to place orders and see your order history on any device.</div>
                    <div t-if="hasVerifiedCustomer" class="d-flex flex-column flex-md-row align-items-md-center gap-3">
                        <div class="text-success flex-grow-1">
                            <i class="fa fa-check-circle me-2"/>
                            <t t-esc="verifiedCustomerLabel"/>
                        </div>
                        <button type="button" class="btn btn-outline-secondary" t-on-click="() => this.changeCustomerPhone()">
                            Change phone
                        </button>
                    </div>
                    <div t-else="" class="d-flex flex-column gap-3">
                        <input type="text" class="form-control form-control-lg" placeholder="Your name (optional)"
                            t-model="phoneState.name" t-att-disabled="phoneState.loading"/>
                        <input type="tel" class="form-control form-control-lg" placeholder="Phone number"
                            t-model="phoneState.phone" t-att-disabled="phoneState.loading or phoneState.otpSent"/>
                        <div t-if="requiresPhoneOtp and phoneState.otpSent" class="d-flex flex-column gap-2">
                            <input type="text" class="form-control form-control-lg" placeholder="Verification code"
                                t-model="phoneState.otpCode" t-att-disabled="phoneState.loading" maxlength="6"/>
                            <button type="button" class="btn btn-primary btn-lg"
                                t-att-disabled="phoneState.loading"
                                t-on-click="() => this.verifyCustomerOtp()">
                                Verify code
                            </button>
                            <button type="button" class="btn btn-link"
                                t-att-disabled="phoneState.loading"
                                t-on-click="() => this.sendCustomerOtp()">
                                Resend code
                            </button>
                        </div>
                        <button t-if="requiresPhoneOtp and !phoneState.otpSent" type="button"
                            class="btn btn-primary btn-lg"
                            t-att-disabled="phoneState.loading"
                            t-on-click="() => this.sendCustomerOtp()">
                            Send verification code
                        </button>
                        <button t-if="!requiresPhoneOtp" type="button"
                            class="btn btn-primary btn-lg"
                            t-att-disabled="phoneState.loading"
                            t-on-click="() => this.identifyCustomerByPhone()">
                            Continue
                        </button>
                        <div t-if="phoneState.error" class="text-danger" t-esc="phoneState.error"/>
                    </div>
                </div>
            </div>
            <div t-if="requiresCustomerLocation and !isOrderLocked" class="ms-3 ms-sm-0 mb-3">
                <div class="alert alert-light border d-flex flex-column flex-md-row align-items-md-center gap-3 mb-0">
                    <div class="flex-grow-1">
                        <strong>Delivery location required</strong>
                        <div class="text-muted">Share your location before confirming the order.</div>
                        <div t-if="locationState.error" class="text-danger mt-1" t-esc="locationState.error"/>
                        <div t-if="hasCustomerLocation" class="text-success mt-1">
                            Location captured
                            (<t t-esc="selfOrder.currentOrder.customer_latitude.toFixed(5)"/>,
                            <t t-esc="selfOrder.currentOrder.customer_longitude.toFixed(5)"/>)
                        </div>
                    </div>
                    <button type="button"
                        class="btn btn-secondary btn-lg text-nowrap"
                        t-att-disabled="locationState.loading or hasCustomerLocation"
                        t-on-click="() => this.captureCustomerLocation()">
                        <i t-if="hasCustomerLocation" class="fa fa-check me-2"/>
                        <i t-else="" class="fa fa-map-marker me-2"/>
                        <t t-esc="locationButtonLabel"/>
                    </button>
                </div>
            </div>
            <div t-if="requiresPaymentChoice and !isOrderLocked" class="ms-3 ms-sm-0 mb-3">
                <div class="alert alert-light border mb-0">
                    <strong>How would you like to pay?</strong>
                    <div class="text-muted mb-3">Choose before confirming your delivery order.</div>
                    <div class="d-flex flex-column gap-2">
                        <label t-if="showCashOnDeliveryOption"
                            class="btn btn-outline-secondary text-start d-flex align-items-center gap-2 mb-0"
                            t-att-class="selectedPaymentPreference === 'cash_on_delivery' ? 'btn btn-secondary text-start d-flex align-items-center gap-2 mb-0' : 'btn btn-outline-secondary text-start d-flex align-items-center gap-2 mb-0'">
                            <input type="radio"
                                class="form-check-input mt-0"
                                name="customer_payment_preference"
                                value="cash_on_delivery"
                                t-att-checked="selectedPaymentPreference === 'cash_on_delivery'"
                                t-on-change="() => this.selectPaymentPreference('cash_on_delivery')"/>
                            <span>
                                <strong>Cash on delivery</strong>
                                <span class="d-block small text-muted">Pay with cash when your order arrives.</span>
                            </span>
                        </label>
                        <label t-if="showOnlineCardOption"
                            class="btn btn-outline-secondary text-start d-flex align-items-center gap-2 mb-0"
                            t-att-class="selectedPaymentPreference === 'online_card' ? 'btn btn-secondary text-start d-flex align-items-center gap-2 mb-0' : 'btn btn-outline-secondary text-start d-flex align-items-center gap-2 mb-0'">
                            <input type="radio"
                                class="form-check-input mt-0"
                                name="customer_payment_preference"
                                value="online_card"
                                t-att-checked="selectedPaymentPreference === 'online_card'"
                                t-on-change="() => this.selectPaymentPreference('online_card')"/>
                            <span>
                                <strong>Pay by card online</strong>
                                <span class="d-block small text-muted">You will be redirected to a secure payment page.</span>
                            </span>
                        </label>
                    </div>
                    <div t-if="showOnlineCardUnavailableHint" class="text-muted small mt-3">
                        Online card payment is not configured yet. Cash on delivery is still available.
                    </div>
                    <div t-if="!hasAnyPaymentOption" class="text-danger small mt-3">
                        No payment options are available. Please contact the store.
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>
