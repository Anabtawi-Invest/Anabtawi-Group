<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_self_order_url" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_self_order_location</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="pos_self_order.res_config_settings_view_form_menu"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_self_ordering_mode']" position="after">
                <div class="content-group row mt-3" invisible="pos_self_ordering_mode == 'nothing'">
                    <label for="pos_self_ordering_url" class="col-lg-4" string="Self-Order URL"/>
                    <field name="pos_self_ordering_url" widget="CopyClipboardChar" readonly="1" class="w-100"/>
                </div>
                <div class="content-group row mt-3" invisible="pos_self_ordering_mode != 'mobile'">
                    <span class="col-lg-4 o_form_label">Customer phone</span>
                    <div class="col-lg-8">
                        <field name="pos_self_order_require_customer_phone"/>
                        <div invisible="not pos_self_order_require_customer_phone" class="ms-4 mt-2">
                            <div class="mb-1">
                                <field name="pos_self_order_require_phone_otp" class="oe_inline"/>
                                <span class="ms-2">Require OTP verification (optional, needs SMS)</span>
                            </div>
                            <div class="mb-1" invisible="not pos_self_order_require_phone_otp">
                                <field name="pos_self_order_otp_show_debug_code" class="oe_inline"/>
                                <span class="ms-2">Show OTP in API response (testing only)</span>
                            </div>
                            <div class="text-muted mt-2">
                                By default customers only enter their phone number — no SMS required.
                                Orders are linked to that phone and order history works across devices.
                            </div>
                        </div>
                    </div>
                </div>
                <div class="content-group row mt-3" invisible="pos_self_ordering_mode != 'mobile'">
                    <span class="col-lg-4 o_form_label">Payment choice</span>
                    <div class="col-lg-8">
                        <field name="pos_self_order_payment_choice_enabled"/>
                        <div invisible="not pos_self_order_payment_choice_enabled" class="ms-4 mt-2">
                            <div class="mb-1">
                                <field name="pos_self_order_allow_cash_on_delivery" class="oe_inline"/>
                                <span class="ms-2">Cash on delivery</span>
                            </div>
                            <div class="mb-1">
                                <field name="pos_self_order_allow_online_card" class="oe_inline"/>
                                <span class="ms-2">Pay by card online</span>
                            </div>
                            <div class="text-muted mt-2" invisible="not pos_self_order_allow_online_card">
                                Online card requires a published payment provider (e.g. Stripe or Amazon Payment Services),
                                a POS payment method with Online Payment enabled, and the Self Online Payment field set
                                on this POS configuration.
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
