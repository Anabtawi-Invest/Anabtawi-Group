<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_self_order_url" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_self_order_location</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="pos_self_order.res_config_settings_view_form_menu"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_self_ordering_mode']" position="after">
                <div class="content-group row mt-3" invisible="pos_self_ordering_mode == 'nothing'">
                    <label for="pos_self_ordering_url" class="col-lg-4" string="Self-Order URL"/>
                    <field name="pos_self_ordering_url" widget="CopyClipboardChar" readonly="1" class="w-100"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
