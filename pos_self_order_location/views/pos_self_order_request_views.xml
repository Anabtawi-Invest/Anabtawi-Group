<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_self_order_request_list" model="ir.ui.view">
        <field name="name">pos.self.order.request.list</field>
        <field name="model">pos.self.order.request</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'cancelled'" decoration-success="state == 'done'" decoration-info="state == 'accepted'">
                <field name="name"/>
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="partner_id"/>
                <field name="amount_total"/>
                <field name="customer_latitude"/>
                <field name="customer_longitude"/>
                <field name="pos_order_state"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'new'"
                    decoration-primary="state == 'accepted'"
                    decoration-success="state == 'done'"
                    decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_pos_self_order_request_form" model="ir.ui.view">
        <field name="name">pos.self.order.request.form</field>
        <field name="model">pos.self.order.request</field>
        <field name="arch" type="xml">
            <form string="Self-Order Request">
                <header>
                    <button name="action_mark_accepted" string="Accept" type="object"
                        invisible="state != 'new'" class="btn-primary"/>
                    <button name="action_mark_done" string="Mark Done" type="object"
                        invisible="state not in ('new', 'accepted')"/>
                    <button name="action_mark_cancelled" string="Cancel" type="object"
                        invisible="state in ('done', 'cancelled')"/>
                    <button name="action_open_map" string="Open Map" type="object"
                        invisible="not location_url"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,accepted,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="config_id" readonly="1"/>
                            <field name="session_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="source" readonly="1"/>
                            <field name="pos_order_id" readonly="1"/>
                            <field name="pos_order_state" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount_total" readonly="1"/>
                            <field name="customer_latitude" readonly="1"/>
                            <field name="customer_longitude" readonly="1"/>
                            <field name="location_url" widget="url" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Order Lines">
                        <field name="line_summary" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_self_order_request_search" model="ir.ui.view">
        <field name="name">pos.self.order.request.search</field>
        <field name="model">pos.self.order.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="config_id"/>
                <field name="partner_id"/>
                <field name="pos_order_id"/>
                <filter string="New" name="filter_new" domain="[('state', '=', 'new')]"/>
                <filter string="Accepted" name="filter_accepted" domain="[('state', '=', 'accepted')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Open" name="filter_open" domain="[('state', 'in', ('new', 'accepted'))]"/>
                <group>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="POS" name="group_config" context="{'group_by': 'config_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pos_self_order_request" model="ir.actions.act_window">
        <field name="name">URL Self-Orders</field>
        <field name="res_model">pos.self.order.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_open': 1}</field>
    </record>
</odoo>
