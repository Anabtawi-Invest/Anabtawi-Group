<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_pricelist_view_form_discount_cap" model="ir.ui.view">
        <field name="name">product.pricelist.form.discount.cap</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <field name="currency_id" position="after">
                <field name="cap_enabled"/>
            </field>
            <field name="cap_enabled" position="after">
                <field name="cap_amount" invisible="not cap_enabled" required="cap_enabled"/>
                <field name="has_fees"/>
            </field>
            <field name="min_quantity" position="after">
                <field name="cap_eligible" optional="show"/>
            </field>
        </field>
    </record>

    <record id="product_pricelist_item_form_discount_cap" model="ir.ui.view">
        <field name="name">product.pricelist.item.form.discount.cap</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_form_view"/>
        <field name="arch" type="xml">
            <field name="min_quantity" position="after">
                <field name="cap_eligible"/>
            </field>
        </field>
    </record>

    <record id="product_pricelist_item_tree_discount_cap" model="ir.ui.view">
        <field name="name">product.pricelist.item.tree.discount.cap</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_tree_view"/>
        <field name="arch" type="xml">
            <field name="min_quantity" position="after">
                <field name="cap_eligible" optional="show"/>
            </field>
        </field>
    </record>

    <record id="res_config_settings_view_form_fee_product" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.fee.product</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='iface_tipproduct']" position="after">
                <setting id="pos_fee_product_setting" string="Fees Product" help="Product used to add the fee line during POS order validation.">
                    <field name="pos_fee_product_id" options="{'no_create': True}"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
