<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='totalDiscount']" position="replace">
            <t t-if="totalDiscount and !hideStandardDiscountSummary">
                <div class="text-start">
                    <span class="label-discount">Discounts</span>
                    <span t-out="formatCurrency(totalDiscount)" class="pos-receipt-right-align font-monospace"/>
                </div>
            </t>
            <div t-if="showPromotionalDiscountNote" class="text-start pt-1">
                <span t-esc="promotionalDiscountNote"/>
            </div>
        </xpath>
    </t>
</templates>
