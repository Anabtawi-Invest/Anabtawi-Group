<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_order_form_adv" model="ir.ui.view">
        <field name="name">pos.order.form.advance.order</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Advance Order" name="advance_order" attrs="{'invisible':[('pos_adv_is_advance_order','=',False)]}">
                    <group>
                        <field name="pos_adv_is_advance_order"/>
                        <field name="pos_adv_type"/>
                        <field name="pos_adv_requested_datetime"/>
                        <field name="pos_adv_deposit"/>
                    </group>
                    <group>
                        <field name="pos_adv_contact_name"/>
                        <field name="pos_adv_phone"/>
                        <field name="pos_adv_address"/>
                        <field name="pos_adv_note"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
