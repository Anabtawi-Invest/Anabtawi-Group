<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="anabtawi_online_campaigns.OrderReceipt"
       t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//Orderline" position="inside">
            <t t-if="line.online_discount_amount">
                <li class="online-campaign-receipt-details w-100">
                    <div class="d-flex">
                        <span><t t-esc="line.onlineCampaignLabel"/> <t t-esc="line.online_discount_percent.toFixed(2)"/>%</span>
                        <span class="ms-auto font-monospace"><t t-esc="formatCurrency(line.online_discount_amount)"/></span>
                    </div>
                    <div class="d-flex online-campaign-net-line">
                        <span>Net Line</span>
                        <span class="ms-auto font-monospace"><t t-esc="formatCurrency(line.onlineNetAmount)"/></span>
                    </div>
                </li>
            </t>
        </xpath>
        <xpath expr="//div[contains(@class, 'receipt-total')]" position="before">
            <div t-if="hasOnlineCampaignDiscount" class="online-campaign-receipt-totals pt-2 pb-2">
                <div class="d-flex">
                    <span>Subtotal before campaign</span>
                    <span class="ms-auto font-monospace"><t t-esc="formatCurrency(order.amountBeforeOnlineDiscount)"/></span>
                </div>
                <div class="d-flex">
                    <span>Campaign discount</span>
                    <span class="ms-auto font-monospace"><t t-esc="formatCurrency(order.onlineDiscountTotal)"/></span>
                </div>
                <div class="d-flex fw-bolder">
                    <span>Customer payable total</span>
                    <span class="ms-auto font-monospace"><t t-esc="order.currencyDisplayPriceIncl"/></span>
                </div>
            </div>
        </xpath>
    </t>
</templates>
