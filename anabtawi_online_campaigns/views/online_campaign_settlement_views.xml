<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_online_campaign_settlement_list" model="ir.ui.view">
        <field name="name">online.campaign.settlement.list</field>
        <field name="model">online.campaign.settlement</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'reconciled'" decoration-warning="state == 'confirmed'"
                  default_order="date_end desc">
                <field name="name"/>
                <field name="aggregator_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="order_count"/>
                <field name="expected_net_settlement" widget="monetary" sum="Expected"/>
                <field name="actual_net_received" widget="monetary" sum="Actual"/>
                <field name="variance_amount" widget="monetary" sum="Variance"
                       decoration-danger="variance_amount != 0"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="statement_reference" optional="show"/>
                <field name="state" widget="badge"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_online_campaign_settlement_form" model="ir.ui.view">
        <field name="name">online.campaign.settlement.form</field>
        <field name="model">online.campaign.settlement</field>
        <field name="arch" type="xml">
            <form string="Aggregator Settlement">
                <header>
                    <button name="action_load_expected" type="object" string="Refresh Expected"
                            groups="anabtawi_online_campaigns.group_online_campaign_finance_manager"
                            invisible="state == 'reconciled'"/>
                    <button name="action_confirm" type="object" string="Confirm Statement" class="btn-primary"
                            groups="anabtawi_online_campaigns.group_online_campaign_finance_manager"
                            invisible="state != 'draft'"/>
                    <button name="action_mark_reconciled" type="object" string="Mark Reconciled" class="btn-primary"
                            groups="anabtawi_online_campaigns.group_online_campaign_finance_manager"
                            invisible="state != 'confirmed'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            groups="anabtawi_online_campaigns.group_online_campaign_finance_manager"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="state != 'draft'"/></h1>
                    </div>
                    <group>
                        <group string="Statement Scope">
                            <field name="company_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="currency_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="aggregator_id" domain="[('company_id', '=', company_id)]" readonly="state != 'draft'"/>
                            <field name="date_start" readonly="state != 'draft'"/>
                            <field name="date_end" readonly="state != 'draft'"/>
                            <field name="statement_reference" readonly="state == 'reconciled'"/>
                            <field name="statement_file" filename="statement_filename" readonly="state == 'reconciled'"/>
                            <field name="statement_filename" invisible="1"/>
                        </group>
                        <group string="Audit Links">
                            <field name="order_count"/>
                            <field name="line_count"/>
                            <field name="bank_statement_line_id" readonly="state == 'reconciled'"/>
                            <field name="account_move_id" readonly="state == 'reconciled'"/>
                            <field name="reconciled_by" invisible="state != 'reconciled'"/>
                            <field name="reconciled_at" invisible="state != 'reconciled'"/>
                        </group>
                    </group>
                    <group>
                        <group string="Expected from POS">
                            <field name="expected_customer_collections" widget="monetary"/>
                            <field name="expected_contribution" widget="monetary"/>
                            <field name="expected_commission" widget="monetary"/>
                            <field name="expected_net_settlement" widget="monetary" class="fw-bold"/>
                        </group>
                        <group string="Actual Aggregator Statement">
                            <field name="actual_customer_collections" widget="monetary" readonly="state == 'reconciled'"/>
                            <field name="actual_contribution" widget="monetary" readonly="state == 'reconciled'"/>
                            <field name="actual_commission" widget="monetary" readonly="state == 'reconciled'"/>
                            <field name="adjustment_amount" widget="monetary" readonly="state == 'reconciled'"/>
                            <field name="actual_net_received" widget="monetary" class="fw-bold"/>
                        </group>
                    </group>
                    <group string="Reconciliation Variance">
                        <field name="variance_amount" widget="monetary"/>
                        <field name="variance_percent"/>
                        <field name="variance_reason" readonly="state == 'reconciled'"
                               placeholder="Required when the actual statement differs from POS expectations."/>
                    </group>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_online_campaign_settlement_pivot" model="ir.ui.view">
        <field name="name">online.campaign.settlement.pivot</field>
        <field name="model">online.campaign.settlement</field>
        <field name="arch" type="xml">
            <pivot string="Settlement Reconciliation">
                <field name="aggregator_id" type="row"/>
                <field name="date_end" interval="month" type="col"/>
                <field name="expected_net_settlement" type="measure"/>
                <field name="actual_net_received" type="measure"/>
                <field name="variance_amount" type="measure"/>
                <field name="expected_commission" type="measure"/>
                <field name="actual_commission" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_online_campaign_settlement_graph" model="ir.ui.view">
        <field name="name">online.campaign.settlement.graph</field>
        <field name="model">online.campaign.settlement</field>
        <field name="arch" type="xml">
            <graph string="Expected vs Actual Settlements" type="bar">
                <field name="aggregator_id"/>
                <field name="expected_net_settlement" type="measure"/>
                <field name="actual_net_received" type="measure"/>
                <field name="variance_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_online_campaign_settlement_search" model="ir.ui.view">
        <field name="name">online.campaign.settlement.search</field>
        <field name="model">online.campaign.settlement</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="aggregator_id"/>
                <field name="statement_reference"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <filter name="to_reconcile" string="To Reconcile" domain="[('state', '=', 'confirmed')]"/>
                <filter name="reconciled" string="Reconciled" domain="[('state', '=', 'reconciled')]"/>
                <filter name="with_variance" string="With Variance" domain="[('variance_amount', '!=', 0)]"/>
                <filter name="group_aggregator" string="Aggregator" context="{'group_by': 'aggregator_id'}"/>
                <filter name="group_month" string="Statement Month" context="{'group_by': 'date_end:month'}"/>
                <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_online_campaign_settlements" model="ir.actions.act_window">
        <field name="name">Aggregator Settlements</field>
        <field name="res_model">online.campaign.settlement</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_online_campaign_settlement_search"/>
    </record>

    <record id="action_online_campaign_settlement_analysis" model="ir.actions.act_window">
        <field name="name">Settlement Analysis</field>
        <field name="res_model">online.campaign.settlement</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_online_campaign_settlement_search"/>
    </record>
</odoo>
