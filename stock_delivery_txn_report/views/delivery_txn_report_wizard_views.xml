<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_txn_report_wizard_form" model="ir.ui.view">
        <field name="name">delivery.txn.report.wizard.form</field>
        <field name="model">delivery.txn.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Delivery Transactions Report">
                <group>
                    <field name="report_date" required="1"/>
                    <field name="location_id" options="{'no_create_edit': True}"/>
                </group>
                <footer>
                    <button name="action_print_excel" type="object" string="Print Excel" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_delivery_txn_report_wizard" model="ir.actions.act_window">
        <field name="name">Delivery Transactions</field>
        <field name="res_model">delivery.txn.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_delivery_txn_report_wizard_form"/>
    </record>

    <menuitem
        id="menu_delivery_txn_report_wizard"
        name="Delivery Transactions"
        parent="stock.menu_warehouse_report"
        action="action_delivery_txn_report_wizard"
        sequence="40"
        groups="stock.group_stock_user,stock.group_stock_manager"
    />
</odoo>
