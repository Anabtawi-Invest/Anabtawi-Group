<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_form_inherit_ot_bank_hours" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.ot.bank.hours</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="Payroll Balances" groups="hr_payroll.group_hr_payroll_manager">
                    <field name="overtime_bank_hours" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
