<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_payslip_run_form_inherit_mass_recon_safe" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.inherit.mass.recon.safe</field>
        <field name="model">hr.payslip.run</field>

        <!-- ULTRA SAFE PAYRUN VIEW -->
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_run_form"/>

        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_mass_reconciliation"
                        type="object"
                        string="Mass Reconciliation"
                        class="btn-primary"
                        groups="hr_payroll.group_hr_payroll_manager"/>
            </xpath>

        </field>
    </record>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payslip form: button + dashboard -->
    <record id="hr_payslip_form_inherit_recon_dashboard_v1922" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit.recon.dashboard.v1922</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_reconcile_lateness"
                        type="object"
                        string="Reconciliation"
                        class="btn-primary"
                        groups="hr_payroll.group_hr_payroll_manager"/>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <group string="Reconciliation Dashboard" groups="hr_payroll.group_hr_payroll_manager">
                    <field name="lateness_hours" readonly="1"/>
                    <field name="ot_total_hours" readonly="1"/>
                    <field name="annual_leave_hours" readonly="1"/>
                    <field name="remaining_after_reconciliation_hours" readonly="1"/>
                    <field name="recon_ot_used_hours" readonly="1"/>
                    <field name="recon_leave_used_hours" readonly="1"/>
                    <field name="recon_bank_delta_hours" readonly="1"/>
                    <field name="reconciliation_state" readonly="1"/>
                    <field name="reconciliation_date" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>

    <!-- Payslip list view: works if Odoo renders <list> OR <tree> -->
    <record id="hr_payslip_list_inherit_recon_columns_v1922" model="ir.ui.view">
        <field name="name">hr.payslip.list.inherit.recon.columns.v1922</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="arch" type="xml">

            <!-- FINAL STABLE: list/tree compatible -->
            <xpath expr="//list | //tree" position="inside">
                <field name="employee_barcode" optional="show"/>
                <field name="employee_identification_id" optional="show"/>
                <field name="lateness_hours" optional="show"/>
                <field name="ot_total_hours" optional="show"/>
                <field name="annual_leave_hours" optional="show"/>
                <field name="remaining_after_reconciliation_hours" optional="show"/>
            </xpath>

        </field>
    </record>

</odoo>
