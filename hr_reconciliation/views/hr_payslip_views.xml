<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payslip form: add dashboard fields + reconciliation button -->
    <record id="hr_payslip_form_inherit_recon_dashboard" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit.recon.dashboard</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_reconcile_lateness"
                        type="object"
                        string="Reconciliation"
                        class="btn-primary"
                        groups="hr_payroll.group_hr_payroll_manager"
                        attrs="{'invisible': [('state', 'not in', ['draft','verify'])]}"/>
            </xpath>

            <xpath expr="//sheet//group" position="inside">
                <group string="Reconciliation Dashboard" groups="hr_payroll.group_hr_payroll_manager">
                    <field name="lateness_hours" readonly="1"/>
                    <field name="ot_total_hours" readonly="1"/>
                    <field name="annual_leave_hours" readonly="1"/>
                    <field name="remaining_after_reconciliation_hours" readonly="1"/>
                    <field name="recon_ot_used_hours" readonly="1"/>
                    <field name="recon_leave_used_hours" readonly="1"/>
                    <field name="reconciliation_state" readonly="1"/>
                    <field name="reconciliation_date" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Payslip list: show the 4 simple columns -->
    <record id="hr_payslip_tree_inherit_recon_columns" model="ir.ui.view">
        <field name="name">hr.payslip.tree.inherit.recon.columns</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="employee_barcode" optional="show"/>
                <field name="employee_identification_id" optional="show"/>
                <field name="lateness_hours" optional="show"/>
                <field name="ot_total_hours" optional="show"/>
                <field name="annual_leave_hours" optional="show"/>
                <field name="remaining_after_reconciliation_hours" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
