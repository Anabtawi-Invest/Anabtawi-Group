<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_inherit_pos_hospitality_gift" model="ir.ui.view">
        <field name="name">pos.config.form.inherit.pos.hospitality.gift</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[field[@name='module_pos_hr']]" position="after">
                <setting
                    id="hospitality_payment_method"
                    string="Hospitality Payment Method"
                    help="Payment method used when the company sponsors POS gift orders."
                >
                    <field name="hospitality_payment_method_id" domain="[('id', 'in', payment_method_ids)]"/>
                    <div class="content-group mt16">
                        <field name="auto_suggest_hospitality_payment"/>
                        <label for="auto_suggest_hospitality_payment" string="Auto Suggest on Gift Orders" class="fw-normal me-1"/>
                    </div>
                    <div class="content-group mt16">
                        <div class="row">
                            <label for="hospitality_clearing_account_id" string="Hospitality Clearing" class="col-lg-4 o_light_label"/>
                            <field name="hospitality_clearing_account_id"/>
                        </div>
                        <div class="row mt16">
                            <label for="gift_expense_account_id" string="Gift Expense" class="col-lg-4 o_light_label"/>
                            <field name="gift_expense_account_id"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
