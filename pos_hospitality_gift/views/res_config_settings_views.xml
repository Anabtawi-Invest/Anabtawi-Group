<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_pos_hospitality_gift" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.hospitality.gift</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_accounting_section']/setting[@id='default_sales_tax_setting']" position="after">
                <setting
                    id="pos_hospitality_accounting_setting"
                    string="Hospitality Gift Expense"
                    help="Expense account used when posting stock cost of gifted POS lines."
                >
                    <div class="content-group mt16">
                        <div class="row">
                            <label for="gift_expense_account_id" string="Hospitality Expense" class="col-lg-3 o_light_label"/>
                            <field name="gift_expense_account_id" options="{'no_create': True}"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
