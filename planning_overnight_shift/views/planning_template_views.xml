<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="planning_slot_template_view_form_inherit" model="ir.ui.view">
        <field name="name">planning.slot.template.form.inherit</field>
        <field name="model">planning.slot.template</field>
        <field name="inherit_id" ref="planning.planning_slot_template_view_form"/>
        <field name="arch" type="xml">
            <!-- Hide original Start & End Hours fields -->
            <xpath expr="//label[@for='start_time']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//label[@for='start_time']/following-sibling::div[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Insert our custom AM/PM fields -->
            <xpath expr="//label[@for='start_time']" position="before">
                <label for="start_time_12" string="Start Hour"/>
                <div class="d-flex align-items-center mb-2">
                    <field name="start_time_12" widget="float_time" class="oe_inline me-2" style="max-width: 90px;"/>
                    <field name="start_am_pm" class="oe_inline" style="max-width: 80px;"/>
                </div>
                <label for="end_time_12" string="End Hour"/>
                <div class="d-flex align-items-center mb-2">
                    <field name="end_time_12" widget="float_time" class="oe_inline me-2" style="max-width: 90px;"/>
                    <field name="end_am_pm" class="oe_inline" style="max-width: 80px;"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
